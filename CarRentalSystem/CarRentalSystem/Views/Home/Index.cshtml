@model IEnumerable<CarRentalSystem.Models.Vehicle>
@{
    ViewData["Title"] = "Trang chủ - RoyalCar";
    Layout = "_Layout";
}

<section class="relative bg-slate-900 text-white overflow-hidden py-24 md:py-32">
    <div class="absolute inset-0 opacity-20">
        <img src="https://images.unsplash.com/photo-1503376780353-7e6692767b70?auto=format&fit=crop&w=1920&q=80" class="w-full h-full object-cover" alt="Hero Background" />
    </div>
    <div class="max-w-[1280px] mx-auto px-8 relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-6">
            <span class="inline-block bg-blue-600/20 text-blue-400 border border-blue-500/30 px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider">Trải nghiệm đẳng cấp thượng lưu</span>
            <h1 class="text-5xl md:text-6xl font-black tracking-tight leading-none text-white">
                Hành trình hoàn hảo <br />Bắt đầu từ <span class="text-[#316bf3]">RoyalCar</span>
            </h1>
            <p class="text-slate-300 text-lg font-medium max-w-md">
                Sở hữu bộ sưu tập xe cao cấp đời mới nhất. Thủ tục đơn giản, giao xe tận nơi nhanh chóng trong 30 phút.
            </p>
            <div class="pt-4 flex flex-wrap gap-4">
                <a href="/Vehicle/CustomerList" class="bg-[#316bf3] hover:bg-blue-700 text-white font-bold px-8 py-4 rounded-xl transition-all shadow-lg shadow-blue-500/20 active:scale-[0.98]">
                    Thuê xe ngay lập tức
                </a>
                <a href="#kham-pha" class="bg-white/10 hover:bg-white/20 border border-white/20 text-white font-bold px-8 py-4 rounded-xl transition-all">
                    Tìm hiểu thêm
                </a>
            </div>
        </div>
    </div>
</section>

<section id="kham-pha" class="max-w-[1280px] mx-auto py-20 px-8 space-y-12">
    <div class="text-center max-w-2xl mx-auto space-y-2">
        <h2 class="text-3xl font-black text-slate-900 tracking-tight">Tại sao nên chọn dịch vụ của chúng tôi?</h2>
        <p class="text-slate-500 font-medium text-sm">RoyalCar mang lại sự an tâm tuyệt đối trên mọi cung đường di chuyển.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition-shadow">
            <div class="w-12 h-12 bg-blue-50 text-[#00236f] rounded-xl flex items-center justify-center mb-6">
                <span class="material-symbols-outlined text-2xl">verified</span>
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">Đội xe chất lượng cao</h3>
            <p class="text-slate-500 text-sm font-medium leading-relaxed">
                Toàn bộ phương tiện đều thuộc các phân khúc đời mới, được kiểm tra và bảo dưỡng nghiêm ngặt trước mỗi chuyến đi.
            </p>
        </div>

        <div class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition-shadow">
            <div class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-xl flex items-center justify-center mb-6">
                <span class="material-symbols-outlined text-2xl">support_agent</span>
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">Hỗ trợ khẩn cấp 24/7</h3>
            <p class="text-slate-500 text-sm font-medium leading-relaxed">
                Đội ngũ kỹ thuật viên và nhân viên vận hành luôn sẵn sàng đồng hành, giải quyết mọi sự cố phát sinh trên đường.
            </p>
        </div>

        <div class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition-shadow">
            <div class="w-12 h-12 bg-amber-50 text-amber-600 rounded-xl flex items-center justify-center mb-6">
                <span class="material-symbols-outlined text-2xl">distance</span>
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">Không giới hạn số km</h3>
            <p class="text-slate-500 text-sm font-medium leading-relaxed">
                Thoải mái tận hưởng chuyến hành trình dài cùng gia đình và bạn bè mà không cần lo lắng về chi phí phát sinh phụ trội.
            </p>
        </div>
    </div>
</section>

<section class="max-w-[1280px] mx-auto py-4 px-8 space-y-12">
    <div class="text-center max-w-2xl mx-auto space-y-2">
        <h2 class="text-3xl font-black text-slate-900 tracking-tight">Mẫu xe nổi bật nổi bật</h2>
        <p class="text-slate-500 font-medium text-sm">Khám phá những dòng xe sang trọng có điểm đánh giá cao nhất từ khách hàng.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
        @foreach (var car in Model)
        {
            <div class="bg-white rounded-2xl overflow-hidden border border-slate-100 hover:shadow-xl transition-all duration-300 flex flex-col h-full group">
                <div class="relative aspect-[16/10] overflow-hidden">
                    <img alt="@car.VehicleName" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" src="@(car.HinhAnh ?? "https://images.unsplash.com/photo-1550355291-bbee04a92027")" />
                    <div class="absolute top-4 left-4">
                        <span class="bg-white/90 backdrop-blur-sm text-[#00236f] text-[10px] font-bold px-3 py-1 rounded-full uppercase">Sẵn sàng</span>
                    </div>
                </div>
                <div class="p-6 flex-1 flex flex-col">
                    <h3 class="text-lg font-bold text-on-surface truncate mb-4">@car.VehicleName</h3>
                    <div class="flex items-center gap-4 text-slate-500 mb-6 flex-nowrap overflow-hidden">
                        <div class="flex items-center gap-1 whitespace-nowrap">
                            <span class="material-symbols-outlined text-sm">event_seat</span>
                            <span class="text-xs font-medium">@car.Seats chỗ</span>
                        </div>
                        <div class="flex items-center gap-1 whitespace-nowrap">
                            <span class="material-symbols-outlined text-sm">local_gas_station</span>
                            <span class="text-xs font-medium">@(car.FuelType ?? "Xăng")</span>
                        </div>
                        <div class="flex items-center gap-1 whitespace-nowrap">
                            <span class="material-symbols-outlined text-sm">settings</span>
                            <span class="text-xs font-medium">@(car.Transmission ?? "Tự động")</span>
                        </div>
                    </div>
                    <div class="mt-auto">
                        <div class="flex items-center justify-between mb-4 border-t border-slate-50 pt-4">
                            <span class="text-xs font-medium text-slate-400 uppercase tracking-wider">Giá thuê</span>
                            <div class="text-[#00236f] font-bold whitespace-nowrap">
                                <span class="text-lg">@car.PricePerDay.ToString("N0")đ</span><span class="text-[10px] text-slate-400">/ngày</span>
                            </div>
                        </div>
                        <div class="grid grid-cols-2 gap-3">
                            <a href="/Vehicle/CustomerDetails/@car.VehicleId" class="border border-[#00236f] text-[#00236f] text-center px-3 py-2.5 rounded-lg font-bold text-xs hover:bg-blue-50 transition-colors block">
                                Xem chi tiết
                            </a>
                            <a href="/Booking/Create?vehicleId=@car.VehicleId" class="bg-[#00236f] text-center text-white px-3 py-2.5 rounded-lg font-bold text-xs hover:bg-blue-900 transition-colors shadow-sm block">
                                Đặt ngay
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

<section class="max-w-[1280px] mx-auto px-8 py-16">
    <div class="bg-[#00236f] rounded-3xl p-12 md:p-16 text-center text-white relative overflow-hidden shadow-xl">
        <div class="absolute inset-0 opacity-10 pointer-events-none">
            <img src="https://images.unsplash.com/photo-1549399542-7e3f8b79c341?auto=format&fit=crop&w=1200&q=80" class="w-full h-full object-cover" alt="CTA BG" />
        </div>
        <div class="relative z-10 max-w-xl mx-auto space-y-6">
            <h2 class="text-3xl md:text-4xl font-black tracking-tight">Sẵn sàng trải nghiệm chuyến đi của riêng bạn?</h2>
            <p class="text-blue-100 text-sm font-medium leading-relaxed">
                Chỉ mất chưa đầy 3 phút để chọn mẫu xe mong muốn và hoàn tất thủ tục giữ xe trực tuyến an toàn.
            </p>
            <div class="pt-4">
                <a href="/Vehicle/CustomerList" class="inline-block bg-white text-[#00236f] font-extrabold px-8 py-4 rounded-xl hover:bg-slate-50 transition-all active:scale-[0.98]">
                    Khám phá danh sách xe ngay
                </a>
            </div>
        </div>
    </div>
</section>