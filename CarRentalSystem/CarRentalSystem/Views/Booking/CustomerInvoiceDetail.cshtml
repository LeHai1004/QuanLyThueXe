@model CarRentalSystem.Models.Invoice
@using CarRentalSystem.Enums
@using CarRentalSystem.Helpers
@using CarRentalSystem.Business
@{
    ViewData["Title"] = "Chi tiết Hóa đơn " + Model.InvoiceNumber;
    Layout = "_Layout";

    var bookingBiz = new BookingBusiness();
    int days = Model.Booking != null
        ? bookingBiz.CalculateRentalDays(Model.Booking.PickupDateTime, Model.Booking.ReturnDateTime)
        : 1;

    decimal deposit = bookingBiz.CalculateDeposit(Model.SubTotal);
}

<main class="flex-grow py-16 px-4 md:px-10 max-w-[1280px] mx-auto w-full mt-4">
    <div class="max-w-[800px] mx-auto bg-white rounded-xl shadow-[0_8px_30px_rgba(30,58,138,0.12)] border border-[#c5c5d3]/30 overflow-hidden">
        <div class="bg-[#e5eeff] p-8 md:p-10 border-b border-[#c5c5d3]/20 flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
            <div>
                <h1 class="text-[36px] font-bold text-[#00236f] mb-2 tracking-tight">
                    Hóa đơn #@Model.InvoiceNumber
                </h1>
                <p class="text-[16px] text-[#444651]">
                    Ngày lập: @Model.IssueDate.ToVnFormat()
                </p>
            </div>
            <div class="text-right">
                @if (Model.Status == InvoiceStatus.Paid)
                {
                    <span class="inline-block bg-[#0058be] text-white px-4 py-2 rounded-full font-bold text-[14px] shadow-sm uppercase tracking-wider">Đã Thanh Toán</span>
                }
                else
                {
                    <span class="inline-block bg-[#ba1a1a] text-white px-4 py-2 rounded-full font-bold text-[14px] shadow-sm uppercase tracking-wider">Chưa Thanh Toán</span>
                }
            </div>
        </div>

        <div class="p-8 md:p-10">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mb-10">
                <div>
                    <h3 class="text-[12px] font-bold text-[#757682] uppercase tracking-wider mb-4 border-b border-[#c5c5d3]/30 pb-2">Thông tin Khách Hàng</h3>
                    <div class="space-y-2">
                        <p class="font-bold text-[#0b1c30] text-[18px]">@(Model.Customer?.UserProfile?.FullName)</p>
                        <p class="text-[#444651] text-[15px] flex items-center gap-2"><span class="material-symbols-outlined text-[18px] text-[#757682]">phone_iphone</span> @(Model.Customer?.UserProfile?.PhoneNumber)</p>
                        <p class="text-[#444651] text-[15px] flex items-center gap-2"><span class="material-symbols-outlined text-[18px] text-[#757682]">badge</span> @((Model.Customer?.NationalId ?? "N/A").MaskNationalId())</p>
                    </div>
                </div>
                <div>
                    <h3 class="text-[12px] font-bold text-[#757682] uppercase tracking-wider mb-4 border-b border-[#c5c5d3]/30 pb-2">Đơn Vị Cung Cấp</h3>
                    <div class="space-y-2">
                        <p class="font-bold text-[#0b1c30] text-[18px]">RoyalCar Co., Ltd</p>
                        <p class="text-[#444651] text-[15px]">123 Đường Cầu Giấy, Đống Đa, Hà Nội</p>
                        <p class="text-[#444651] text-[15px]">Mã số thuế: 0102938475</p>
                    </div>
                </div>
            </div>

            <div class="mb-10">
                <h3 class="text-[12px] font-bold text-[#757682] uppercase tracking-wider mb-4">Chi tiết Hóa Đơn</h3>
                <div class="border border-[#c5c5d3]/30 rounded-xl overflow-hidden">
                    <table class="w-full text-left">
                        <thead class="bg-[#f8f9ff]">
                            <tr>
                                <th class="py-4 px-6 text-[13px] font-bold text-[#444651]">Mô tả Dịch Vụ</th>
                                <th class="py-4 px-6 text-[13px] font-bold text-[#444651] text-center">Số lượng</th>
                                <th class="py-4 px-6 text-[13px] font-bold text-[#444651] text-right">Đơn giá</th>
                                <th class="py-4 px-6 text-[13px] font-bold text-[#444651] text-right">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-[#c5c5d3]/20">
                            <tr>
                                <td class="py-5 px-6">
                                    <p class="font-bold text-[#0b1c30]">Thuê xe @(Model.Booking?.Vehicle?.VehicleName)</p>
                                    <p class="text-[#757682] text-[13px] mt-1">Lịch trình: @(Model.Booking?.PickupDateTime.ToVnDate()) đến @(Model.Booking?.ReturnDateTime.ToVnDate())</p>
                                </td>
                                <td class="py-5 px-6 text-center text-[#444651] font-medium">@days Ngày</td>
                                <td class="py-5 px-6 text-right text-[#444651] font-medium">@CurrencyHelper.FormatVnd(Model.Booking?.Vehicle?.PricePerDay ?? 0)</td>
                                <td class="py-5 px-6 text-right font-bold text-[#0b1c30]">@CurrencyHelper.FormatVnd(Model.SubTotal)</td>
                            </tr>
                            <tr>
                                <td colspan="3" class="py-4 px-6 text-right text-[#757682] text-[14px]">Tổng trước thuế:</td>
                                <td class="py-4 px-6 text-right font-semibold text-[#0b1c30]">@CurrencyHelper.FormatVnd(Model.SubTotal)</td>
                            </tr>
                            <tr>
                                <td colspan="3" class="py-4 px-6 text-right text-[#757682] text-[14px]">Tiền cọc (10%):</td>
                                <td class="py-4 px-6 text-right font-semibold text-[#0b1c30]">@CurrencyHelper.FormatVnd(deposit)</td>
                            </tr>
                            @if (Model.DiscountAmount > 0)
                            {
                                <tr>
                                    <td colspan="3" class="py-4 px-6 text-right text-[#757682] text-[14px]">Chiết khấu/Giảm giá:</td>
                                    <td class="py-4 px-6 text-right font-semibold text-[#ba1a1a]">-@CurrencyHelper.FormatVnd(Model.DiscountAmount)</td>
                                </tr>
                            }
                            <tr class="bg-[#f8f9ff]">
                                <td colspan="3" class="py-5 px-6 text-right font-bold text-[#0b1c30] text-[16px]">TỔNG THANH TOÁN:</td>
                                <td class="py-5 px-6 text-[24px] font-bold text-[#00236f] text-right">@CurrencyHelper.FormatVnd(Model.GrandTotal)</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="flex flex-col sm:flex-row items-center justify-between pt-6 border-t border-[#c5c5d3]/20 gap-4">
                <a class="text-[14px] text-[#0058be] hover:text-[#00236f] font-semibold transition-colors flex items-center gap-2 hover:underline" href="#">
                    <span class="material-symbols-outlined">support_agent</span>
                    Liên hệ hỗ trợ
                </a>
                <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
                    <a href="/Booking/MyInvoices" class="px-6 py-3 border-2 border-[#00236f] text-[#00236f] text-[14px] font-semibold rounded-lg hover:bg-[#eff4ff] transition-colors w-full sm:w-auto text-center block">
                        Quay lại danh sách
                    </a>
                    <button class="px-6 py-3 bg-[#00236f] text-white text-[14px] font-semibold rounded-lg hover:bg-[#1e3a8a] transition-colors shadow-sm flex items-center justify-center gap-2 w-full sm:w-auto">
                        <span class="material-symbols-outlined">download</span>
                        Tải hóa đơn PDF
                    </button>
                </div>
            </div>
        </div>
    </div>
</main>