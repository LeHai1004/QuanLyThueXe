@model IEnumerable<CarRentalSystem.Models.Invoice>
@using CarRentalSystem.Constants
@using CarRentalSystem.Helpers
@{
    ViewData["Title"] = "Hóa đơn của tôi";
    Layout = "_Layout";
}

<main class="flex-grow pt-12 pb-20 px-4 md:px-10 max-w-[1280px] mx-auto w-full">
    <div class="mb-10">
        <h1 class="text-4xl font-bold text-[#0b1c30]">Hóa đơn của tôi</h1>
        <p class="text-lg text-[#444651] mt-2">
            Quản lý và theo dõi các khoản thanh toán của bạn.
        </p>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-[#c5c5d3]/30 overflow-hidden">
        <div class="flex border-b border-[#c5c5d3]/30 px-6 pt-6 gap-6">
            <button class="pb-4 text-sm font-semibold text-[#00236f] border-b-2 border-[#00236f]">
                Tất cả
            </button>
            <button class="pb-4 text-sm font-semibold text-[#444651] hover:text-[#00236f] transition-colors">
                Đã thanh toán
            </button>
            <button class="pb-4 text-sm font-semibold text-[#444651] hover:text-[#00236f] transition-colors">
                Chưa thanh toán
            </button>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-16">
                <span class="material-symbols-outlined text-[64px] text-[#c5c5d3] mb-4">receipt_long</span>
                <h3 class="text-xl font-semibold text-[#0b1c30]">Bạn chưa có hóa đơn nào</h3>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="bg-[#f8f9ff] border-b border-[#c5c5d3]/30">
                            <th class="py-4 px-6 text-xs font-bold text-[#757682] uppercase tracking-wider">Số Hóa Đơn</th>
                            <th class="py-4 px-6 text-xs font-bold text-[#757682] uppercase tracking-wider">Ngày lập</th>
                            <th class="py-4 px-6 text-xs font-bold text-[#757682] uppercase tracking-wider">Dịch vụ</th>
                            <th class="py-4 px-6 text-xs font-bold text-[#757682] uppercase tracking-wider text-right">Tổng tiền</th>
                            <th class="py-4 px-6 text-xs font-bold text-[#757682] uppercase tracking-wider text-center">Trạng thái</th>
                            <th class="py-4 px-6 text-xs font-bold text-[#757682] uppercase tracking-wider text-right">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-[#c5c5d3]/20">
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-[#f8f9ff] transition-colors">
                                <td class="py-5 px-6 font-bold text-[#0b1c30]">
                                    #@item.InvoiceNumber
                                </td>
                                <td class="py-5 px-6 text-[#444651] font-medium text-sm">
                                    @item.IssueDate.ToString("dd/MM/yyyy")
                                </td>
                                <td class="py-5 px-6 text-[#444651] font-medium text-sm">
                                    Thuê xe @(item.Booking?.Vehicle?.VehicleName)
                                </td>
                                <td class="py-5 px-6 text-base font-semibold text-[#00236f] text-right">
                                    @CurrencyHelper.FormatVnd(item.GrandTotal)
                                </td>
                                <td class="py-5 px-6 text-center">
                                    @if (item.Status == InvoiceStatus.Paid)
                                    {
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs bg-[#dce9ff] text-[#00236f] font-medium">Đã thanh toán</span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs bg-[#ffdad6] text-[#93000a] font-medium">Chưa thanh toán</span>
                                    }
                                </td>
                                <td class="py-5 px-6 text-right">
                                    <a href="/Booking/CustomerInvoiceDetail/@item.InvoiceId" class="text-[#00236f] hover:text-[#1e3a8a] text-sm font-semibold transition-colors">
                                        Xem chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</main>