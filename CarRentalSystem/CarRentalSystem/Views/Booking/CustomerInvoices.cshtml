@model IEnumerable<CarRentalSystem.Models.Invoice>
@{
    ViewData["Title"] = "Hóa đơn của tôi";
    Layout = "_Layout";
}

<main class="flex-grow pt-12 pb-20 px-4 md:px-10 max-w-[1280px] mx-auto w-full">
    <div class="mb-10">
        <h1 class="text-4xl font-bold text-[#0b1c30]">Hóa đơn của tôi</h1>
        <p class="text-lg text-[#444651] mt-2">
            Quản lý và theo dõi các khoản thanh toán của bạn.
        </p>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-[#c5c5d3]/30 overflow-hidden">
        <div class="flex border-b border-[#c5c5d3]/30 px-6 pt-6 gap-6">
            <button class="pb-4 text-sm font-semibold text-[#00236f] border-b-2 border-[#00236f]">
                Tất cả
            </button>
            <button class="pb-4 text-sm font-semibold text-[#444651] hover:text-[#00236f] transition-colors">
                Đã thanh toán
            </button>
            <button class="pb-4 text-sm font-semibold text-[#444651] hover:text-[#00236f] transition-colors">
                Chưa thanh toán
            </button>
        </div>

        @if (!Model.Any())
        {
            <div class="p-12 text-center">
                <span class="material-symbols-outlined text-6xl text-slate-300 mb-4">receipt_long</span>
                <h3 class="text-xl font-bold text-[#0b1c30] mb-2">Chưa có hóa đơn nào</h3>
                <p class="text-[#444651]">Bạn hiện chưa có giao dịch thanh toán nào trên hệ thống.</p>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-[#eff4ff]/50 border-b border-[#c5c5d3]/30">
                            <th class="py-4 px-6 text-sm font-semibold text-[#444651]">Mã hóa đơn</th>
                            <th class="py-4 px-6 text-sm font-semibold text-[#444651]">Ngày lập</th>
                            <th class="py-4 px-6 text-sm font-semibold text-[#444651]">Xe thuê</th>
                            <th class="py-4 px-6 text-sm font-semibold text-[#444651]">Khoảng thời gian</th>
                            <th class="py-4 px-6 text-sm font-semibold text-[#444651] text-right">Tổng tiền</th>
                            <th class="py-4 px-6 text-sm font-semibold text-[#444651] text-center">Trạng thái</th>
                            <th class="py-4 px-6 text-sm font-semibold text-[#444651] text-right">Hành động</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-[#c5c5d3]/20">
                        @foreach (var item in Model)
                        {
                            var days = 1;
                            if (item.Booking != null)
                            {
                                days = (int)Math.Ceiling((item.Booking.ReturnDateTime - item.Booking.PickupDateTime).TotalDays);
                                if (days <= 0) days = 1;
                            }

                            <tr class="hover:bg-[#eff4ff]/30 transition-colors">
                                <td class="py-5 px-6 text-base font-medium text-[#0b1c30]">
                                    @item.InvoiceNumber
                                </td>
                                <td class="py-5 px-6 text-base text-[#444651]">
                                    @item.IssueDate.ToString("dd/MM/yyyy")
                                </td>
                                <td class="py-5 px-6">
                                    <div class="text-base font-medium text-[#0b1c30]">
                                        @(item.Booking?.Vehicle?.VehicleName ?? "N/A")
                                    </div>
                                    <div class="text-xs text-[#444651] mt-1">
                                        Biển số: @(item.Booking?.Vehicle?.LicensePlate ?? "N/A")
                                    </div>
                                </td>
                                <td class="py-5 px-6 text-base text-[#444651]">
                                    @days ngày
                                </td>
                                <td class="py-5 px-6 text-base font-semibold text-[#00236f] text-right">
                                    @item.GrandTotal.ToString("N0") ₫
                                </td>
                                <td class="py-5 px-6 text-center">
                                    @if (item.Status == "Da thanh toan" || item.Status == "Đã thanh toán")
                                    {
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs bg-[#dce9ff] text-[#00236f] font-medium">Đã thanh toán</span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs bg-[#ffdad6] text-[#93000a] font-medium">Chưa thanh toán</span>
                                    }
                                </td>
                                <td class="py-5 px-6 text-right">
                                    <a href="/Booking/CustomerInvoiceDetail/@item.InvoiceId" class="text-[#00236f] hover:text-[#1e3a8a] text-sm font-semibold transition-colors">
                                        Xem chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</main>