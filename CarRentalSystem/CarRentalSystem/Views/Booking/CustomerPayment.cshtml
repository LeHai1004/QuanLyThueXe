@{
    ViewData["Title"] = "Thanh toán đơn hàng";
    Layout = "_Layout";
}

<main class="max-w-[600px] mx-auto my-16 px-6">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-8">
        <h2 class="text-2xl font-bold text-[#00236f] text-center mb-2">Phương thức thanh toán</h2>
        <p class="text-slate-500 text-center text-sm mb-8">Vui lòng chọn cách thức thanh toán cho chuyến đi của bạn</p>

        <div class="bg-slate-50 p-4 rounded-xl flex justify-between items-center mb-8 border border-slate-100">
            <span class="text-slate-600 font-medium">Tổng số tiền cần thanh toán:</span>
            <span class="text-xl font-extrabold text-[#0058be]">@Convert.ToDecimal(ViewBag.TotalAmount).ToString("N0")đ</span>
        </div>

        <div class="space-y-4">
            <a href="/Booking/PaymentProcessing?method=Cash" class="flex items-center gap-4 p-5 border-2 border-slate-200 rounded-xl hover:border-[#00236f] hover:bg-blue-50/30 transition-all group block">
                <div class="w-12 h-12 bg-amber-50 rounded-lg flex items-center justify-center text-amber-600 group-hover:bg-amber-100">
                    <span class="material-symbols-outlined text-2xl">payments</span>
                </div>
                <div class="flex-1">
                    <h3 class="font-bold text-slate-800 text-base">Thanh toán tiền mặt</h3>
                    <p class="text-slate-500 text-xs mt-0.5">Thanh toán trực tiếp khi nhận xe</p>
                </div>
                <span class="material-symbols-outlined text-slate-400 group-hover:text-[#00236f]">chevron_right</span>
            </a>

            <a href="/Booking/PaymentProcessing?method=Transfer" class="flex items-center gap-4 p-5 border-2 border-slate-200 rounded-xl hover:border-[#00236f] hover:bg-blue-50/30 transition-all group block">
                <div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center text-[#0058be] group-hover:bg-blue-100">
                    <span class="material-symbols-outlined text-2xl">account_balance</span>
                </div>
                <div class="flex-1">
                    <h3 class="font-bold text-slate-800 text-base">Chuyển khoản qua ngân hàng (QR Code)</h3>
                    <p class="text-slate-500 text-xs mt-0.5">Quét mã VietQR để thanh toán tức thì</p>
                </div>
                <span class="material-symbols-outlined text-slate-400 group-hover:text-[#00236f]">chevron_right</span>
            </a>
        </div>
    </div>
</main>