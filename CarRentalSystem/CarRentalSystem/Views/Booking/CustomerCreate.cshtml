@model CarRentalSystem.Models.Vehicle
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Xác nhận đặt xe";
    Layout = "_Layout";
}

<main class="mt-12 mb-24 max-w-[1280px] mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">

        <div class="lg:col-span-5 space-y-6 sticky top-28">
            <div class="bg-white rounded-2xl shadow-[0_8px_30px_rgba(30,58,138,0.06)] overflow-hidden border border-slate-100">
                <div class="p-6 md:p-8">
                    <h2 class="text-xl font-bold text-[#00236f] mb-6">Thông tin xe đã chọn</h2>

                    <div class="relative rounded-xl overflow-hidden mb-6 aspect-[16/10] bg-slate-100">
                        <img class="w-full h-full object-cover" src="@(Model.HinhAnh ?? "https://images.unsplash.com/photo-1550355291-bbee04a92027")" alt="@Model.VehicleName" />
                    </div>

                    <div class="flex justify-between items-start mb-8">
                        <div>
                            <h3 class="text-2xl font-black text-[#00236f]">@Model.VehicleName</h3>
                            <p class="text-slate-500 text-sm mt-1 font-medium">@(Model.Category?.CategoryName ?? "Phiên bản cao cấp")</p>
                        </div>
                        <span class="bg-emerald-50 text-emerald-600 border border-emerald-100 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider">
                            @Model.Status
                        </span>
                    </div>

                    <div class="grid grid-cols-3 gap-3 mb-8">
                        <div class="flex flex-col items-center p-3.5 bg-slate-50 rounded-xl border border-slate-100">
                            <span class="material-symbols-outlined text-[#316bf3] mb-1.5">settings</span>
                            <span class="text-[13px] font-bold text-slate-700">@(Model.Transmission ?? "Tự động")</span>
                        </div>
                        <div class="flex flex-col items-center p-3.5 bg-slate-50 rounded-xl border border-slate-100">
                            <span class="material-symbols-outlined text-[#316bf3] mb-1.5">airline_seat_recline_extra</span>
                            <span class="text-[13px] font-bold text-slate-700">@Model.Seats Chỗ</span>
                        </div>
                        <div class="flex flex-col items-center p-3.5 bg-slate-50 rounded-xl border border-slate-100">
                            <span class="material-symbols-outlined text-[#316bf3] mb-1.5">local_gas_station</span>
                            <span class="text-[13px] font-bold text-slate-700">@(Model.FuelType ?? "Xăng")</span>
                        </div>
                    </div>

                    <div class="bg-blue-50 border border-blue-100 p-6 rounded-xl">
                        <div class="flex justify-between items-center">
                            <span class="text-sm font-bold text-slate-600">Đơn giá thuê / ngày</span>
                            <div class="text-[#00236f] font-black flex items-baseline gap-1">
                                <span class="text-2xl" id="dailyPrice" data-price="@Model.PricePerDay">@Model.PricePerDay.ToString("N0")</span>
                                <span class="text-sm">đ</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div class="bg-white p-5 rounded-xl border border-slate-100 shadow-sm flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined text-[#316bf3] text-[20px]">verified_user</span>
                    </div>
                    <span class="text-sm font-bold text-slate-700">Bảo hiểm 100% chuyến đi</span>
                </div>
                <div class="bg-white p-5 rounded-xl border border-slate-100 shadow-sm flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined text-[#316bf3] text-[20px]">support_agent</span>
                    </div>
                    <span class="text-sm font-bold text-slate-700">Hỗ trợ khẩn cấp 24/7</span>
                </div>
            </div>
        </div>

        <div class="lg:col-span-7">
            <div class="bg-white rounded-2xl shadow-[0_8px_30px_rgba(30,58,138,0.06)] border border-slate-100 overflow-hidden">
                <div class="p-6 md:p-10">
                    <h2 class="text-2xl font-black text-[#00236f] mb-8 border-b border-slate-100 pb-5">Chi tiết thông tin đặt xe</h2>

                    <form asp-controller="Booking" asp-action="Create" method="post" class="space-y-8" id="bookingForm">
                        <input type="hidden" name="VehicleId" value="@Model.VehicleId" />

                        <div class="space-y-5">
                            <h3 class="text-sm font-bold uppercase tracking-wider text-slate-400">1. Thời gian thuê</h3>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="space-y-2">
                                    <label class="text-sm font-bold text-slate-700 block">Lấy xe lúc</label>
                                    <div class="relative">
                                        <input name="PickupDateTime" id="pickupDate" class="w-full bg-slate-50 border border-slate-200 rounded-xl pl-4 pr-10 py-3.5 focus:ring-2 focus:ring-[#316bf3] focus:border-[#316bf3] outline-none transition-all font-medium text-slate-700" type="datetime-local" required />
                                        <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none">calendar_today</span>
                                    </div>
                                </div>
                                <div class="space-y-2">
                                    <label class="text-sm font-bold text-slate-700 block">Trả xe lúc</label>
                                    <div class="relative">
                                        <input name="ReturnDateTime" id="returnDate" class="w-full bg-slate-50 border border-slate-200 rounded-xl pl-4 pr-10 py-3.5 focus:ring-2 focus:ring-[#316bf3] focus:border-[#316bf3] outline-none transition-all font-medium text-slate-700" type="datetime-local" required />
                                        <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none">event</span>
                                    </div>
                                </div>
                            </div>
                            <p class="text-rose-500 text-xs font-medium hidden" id="dateError">Thời gian trả xe phải sau thời gian nhận xe ít nhất 1 ngày.</p>
                        </div>

                        <div class="space-y-5 pt-4">
                            <h3 class="text-sm font-bold uppercase tracking-wider text-slate-400">2. Thông tin người thuê</h3>
                            <div class="space-y-2">
                                <label class="text-sm font-bold text-slate-700 block">Họ và tên</label>
                                <input class="w-full bg-slate-100/70 border border-slate-200 rounded-xl p-3.5 outline-none text-slate-500 font-medium cursor-not-allowed" value="@Context.Session.GetString("FullName")" type="text" readonly />
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="space-y-2">
                                    <label class="text-sm font-bold text-slate-700 block">Số điện thoại liên hệ <span class="text-rose-500">*</span></label>
                                    <input name="PhoneNumber" class="w-full bg-slate-50 border border-slate-200 rounded-xl p-3.5 focus:ring-2 focus:ring-[#316bf3] focus:border-[#316bf3] outline-none transition-all font-medium text-slate-700" type="tel" placeholder="Nhập SĐT để tài xế liên hệ" required />
                                </div>
                                <div class="space-y-2">
                                    <label class="text-sm font-bold text-slate-700 block">Email</label>
                                    <input class="w-full bg-slate-100/70 border border-slate-200 rounded-xl p-3.5 outline-none text-slate-500 font-medium cursor-not-allowed" value="@Context.Session.GetString("Email")" type="email" readonly />
                                </div>
                            </div>
                        </div>

                        <div class="mt-10 bg-[#00236f] p-8 rounded-2xl text-white relative overflow-hidden">
                            <div class="absolute inset-0 opacity-5 pointer-events-none">
                                <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
                                    <defs><pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse"><path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="1" /></pattern></defs>
                                    <rect width="100%" height="100%" fill="url(#grid)" />
                                </svg>
                            </div>

                            <div class="relative z-10 space-y-4">
                                <h3 class="text-sm font-bold text-blue-200 uppercase tracking-wider mb-6">Chi tiết dự toán</h3>

                                <div class="space-y-4 border-b border-white/20 pb-6">
                                    <div class="flex justify-between items-center">
                                        <span class="font-medium text-blue-100">Thời gian thuê</span>
                                        <span class="font-bold" id="lblDaysCount">0 ngày</span>
                                    </div>
                                    <div class="flex justify-between items-center">
                                        <span class="font-medium text-blue-100">Thành tiền tạm tính</span>
                                        <span class="font-bold" id="lblSubtotal">0 đ</span>
                                    </div>
                                </div>

                                <div class="flex justify-between items-end pt-4">
                                    <div>
                                        <span class="font-bold text-xl block">Tổng cộng</span>
                                        <span class="text-xs text-blue-200 font-medium">(Bao gồm VAT & Phí bảo hiểm)</span>
                                    </div>
                                    <div class="text-right">
                                        <span class="font-black text-3xl text-yellow-400" id="lblGrandTotal">0 đ</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="pt-4">
                            <button type="submit" id="btnSubmit" class="w-full bg-[#316bf3] py-4 rounded-xl text-white font-bold text-lg hover:bg-blue-700 transition-all shadow-xl shadow-blue-500/30 active:scale-[0.98] flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined">assignment_turned_in</span>
                                Gửi yêu cầu đặt xe
                            </button>
                            <p class="text-center text-xs font-medium text-slate-400 mt-4">
                                Bằng cách nhấn xác nhận, bạn đồng ý với <a href="#" class="text-[#316bf3] hover:underline">Quy định & Chính sách</a> của hệ thống.
                            </p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const pickupInput = document.getElementById('pickupDate');
            const returnInput = document.getElementById('returnDate');
            const dailyPrice = parseFloat(document.getElementById('dailyPrice').getAttribute('data-price'));

            const lblDaysCount = document.getElementById('lblDaysCount');
            const lblSubtotal = document.getElementById('lblSubtotal');
            const lblGrandTotal = document.getElementById('lblGrandTotal');
            const dateError = document.getElementById('dateError');
            const btnSubmit = document.getElementById('btnSubmit');

            // Format tiền tệ VNĐ
            const formatMoney = (amount) => {
                return new Intl.NumberFormat('vi-VN').format(amount) + ' đ';
            };

            // Khởi tạo ngày mặc định (Ngày mai và trả sau 2 ngày)
            const now = new Date();
            now.setDate(now.getDate() + 1);
            now.setHours(8, 0, 0, 0); // Setup nhận xe lúc 8h sáng mai

            const tzoffset = (new Date()).getTimezoneOffset() * 60000;
            const localISOTimePickup = (new Date(now - tzoffset)).toISOString().slice(0, 16);
            pickupInput.value = localISOTimePickup;

            const returnDate = new Date(now);
            returnDate.setDate(returnDate.getDate() + 2); // Mặc định thuê 2 ngày
            const localISOTimeReturn = (new Date(returnDate - tzoffset)).toISOString().slice(0, 16);
            returnInput.value = localISOTimeReturn;

            // Hàm tính toán giá tiền
            function calculatePrice() {
                if (!pickupInput.value || !returnInput.value) return;

                const start = new Date(pickupInput.value);
                const end = new Date(returnInput.value);

                // Tính số ngày (Chênh lệch ms -> ngày)
                const diffTime = Math.abs(end - start);
                let diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

                // Validate: Ngày trả phải sau ngày nhận
                if (end <= start) {
                    dateError.classList.remove('hidden');
                    btnSubmit.disabled = true;
                    btnSubmit.classList.add('opacity-50', 'cursor-not-allowed');
                    lblDaysCount.innerText = '0 ngày';
                    lblSubtotal.innerText = '0 đ';
                    lblGrandTotal.innerText = '0 đ';
                    return;
                } else {
                    dateError.classList.add('hidden');
                    btnSubmit.disabled = false;
                    btnSubmit.classList.remove('opacity-50', 'cursor-not-allowed');
                }

                // Nếu thuê trong ngày (dưới 24h) vẫn tính là 1 ngày
                if (diffDays === 0) diffDays = 1;

                const total = diffDays * dailyPrice;

                // Update UI
                lblDaysCount.innerText = diffDays + ' ngày';
                lblSubtotal.innerText = formatMoney(total);
                lblGrandTotal.innerText = formatMoney(total);
            }

            // Lắng nghe sự kiện đổi ngày
            pickupInput.addEventListener('change', calculatePrice);
            returnInput.addEventListener('change', calculatePrice);

            // Tính ngay lần đầu load trang
            calculatePrice();
        });
    </script>
}