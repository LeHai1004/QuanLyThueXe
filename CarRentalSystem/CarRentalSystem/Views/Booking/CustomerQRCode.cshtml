@{
    ViewData["Title"] = "Quét mã thanh toán";
    Layout = "_Layout";
}

<main class="max-w-[600px] mx-auto my-16 px-6">
    <div class="bg-white rounded-3xl shadow-lg border border-slate-100 overflow-hidden relative">
        <div class="bg-[#00236f] h-32 absolute top-0 left-0 w-full z-0"></div>

        <div class="relative z-10 p-8 pt-12 flex flex-col items-center text-center">
            <div class="bg-white p-4 rounded-2xl shadow-sm mb-6 inline-block">
                <h2 class="text-2xl font-bold text-[#00236f]">Quét mã QR để thanh toán</h2>
                <p class="text-slate-500 text-sm mt-2">Sử dụng ứng dụng Ngân hàng hoặc Ví điện tử</p>
            </div>

            <div class="bg-white p-6 rounded-3xl border-4 border-blue-50 shadow-md mb-8 inline-block">
                <img src="https://api.qrserver.com/v1/create-qr-code/?size=250x250&data=ThanhToanThueXe_LuxeDrive" alt="QR Code" class="w-64 h-64 object-contain rounded-xl" />
            </div>

            <div class="w-full bg-blue-50 rounded-2xl p-6 mb-8">
                <span class="text-sm font-semibold text-slate-500 block mb-1">SỐ TIỀN CẦN THANH TOÁN</span>
                <span class="text-3xl font-extrabold text-[#0058be]">@Convert.ToDecimal(ViewBag.TotalAmount).ToString("N0")đ</span>
            </div>

            <form asp-controller="Booking" asp-action="QRCodeConfirm" method="post" class="w-full grid grid-cols-2 gap-4">
                <button type="submit" class="w-full bg-[#00236f] text-white py-4 rounded-xl font-bold hover:bg-blue-900 transition-all flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined">check_circle</span>
                    TÔI ĐÃ THANH TOÁN
                </button>
                <a href="/Booking/Payment" class="w-full bg-white text-slate-600 border-2 border-slate-200 py-4 rounded-xl font-bold hover:bg-slate-50 transition-all flex items-center justify-center">
                    Đổi phương thức
                </a>
            </form>
        </div>
    </div>
</main>