@model CarRentalSystem.Models.Booking
@using CarRentalSystem.Helpers
@{
    ViewData["Title"] = "Đánh giá chuyến đi";
    Layout = "_Layout";
}

@section Styles {
    <style>
        .star-icon {
            font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24;
            color: #d1d5db;
            cursor: pointer;
            transition: transform 0.15s, color 0.15s;
            font-size: 2.5rem;
        }

            .star-icon:hover,
            .star-icon.active {
                font-variation-settings: "FILL" 1, "wght" 400, "GRAD" 0, "opsz" 24;
                color: #fbbf24;
                transform: scale(1.15);
            }

        .form-card-shadow {
            box-shadow: 0 10px 40px rgba(30,58,138,0.08);
        }
    </style>
}

<main class="py-16 px-4">
    <div class="max-w-3xl mx-auto">
        <h1 class="text-3xl font-bold text-center text-[#00236f] mb-10">
            Đánh giá chuyến đi — @Model.Vehicle?.VehicleName
        </h1>

        <div class="bg-white rounded-2xl form-card-shadow overflow-hidden border border-slate-100">

            @* Tóm tắt booking *@
            <div class="p-8 border-b border-slate-100 bg-slate-50/50">
                <div class="flex flex-col md:flex-row gap-8 items-center">
                    <div class="w-full md:w-1/3 aspect-[3/2] rounded-xl overflow-hidden shadow-sm flex-shrink-0">
                        <img src="@(Model.Vehicle?.HinhAnh ?? "https://images.unsplash.com/photo-1550355291-bbee04a92027")"
                             alt="@Model.Vehicle?.VehicleName"
                             class="w-full h-full object-cover" />
                    </div>
                    <div class="flex-1 text-center md:text-left">
                        <div class="flex items-center justify-center md:justify-start gap-2 mb-2">
                            <span class="material-symbols-outlined text-[#00236f]">directions_car</span>
                            <h2 class="text-xl font-bold text-slate-800">@Model.Vehicle?.VehicleName</h2>
                        </div>
                        <p class="text-slate-500 text-sm mb-1">Biển số: <strong>@Model.Vehicle?.LicensePlate</strong></p>
                        <div class="flex items-center justify-center md:justify-start gap-2 text-slate-500 text-sm mb-4">
                            <span class="material-symbols-outlined text-sm">calendar_today</span>
                            <span>@Model.PickupDateTime.ToString("dd/MM/yyyy") — @Model.ReturnDateTime.ToString("dd/MM/yyyy")</span>
                        </div>
                        <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-100 text-emerald-700 text-xs font-bold">
                            <span class="material-symbols-outlined text-sm">verified</span>
                            Chuyến đi hoàn tất
                        </span>
                    </div>
                </div>
            </div>

            @* Form đánh giá *@
            <form asp-action="Review" asp-controller="Booking" method="post" class="p-8 space-y-10">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.BookingId" />
                <input type="hidden" name="rating" id="ratingInput" value="0" />

                @* Đánh giá sao tổng *@
                <div class="text-center space-y-4">
                    <p class="text-xl font-bold text-slate-800">Bạn đánh giá thế nào về chuyến đi này?</p>
                    <div class="flex justify-center gap-2" id="starGroup">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span class="material-symbols-outlined star-icon" data-value="@i" onclick="setRating(@i)">star</span>
                        }
                    </div>
                    <p id="ratingLabel" class="text-slate-400 text-sm font-medium h-5"></p>
                </div>

                @* Nhận xét *@
                <div class="pt-6 border-t border-slate-100 space-y-3">
                    <label class="block text-sm font-bold text-slate-700 uppercase tracking-wider">
                        Nhận xét của bạn
                    </label>
                    <textarea name="content" rows="4"
                              placeholder="Chia sẻ trải nghiệm của bạn về chuyến đi, chất lượng xe và dịch vụ..."
                              class="w-full px-4 py-3 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-[#00236f]/30 resize-none"></textarea>
                </div>

                @* Buttons *@
                <div class="flex gap-4 pt-2">
                    <a href="/Booking/History"
                       class="flex-1 py-3.5 rounded-xl border-2 border-slate-200 text-slate-600 font-bold text-center hover:bg-slate-50 transition-all">
                        Bỏ qua
                    </a>
                    <button type="submit" id="submitBtn"
                            class="flex-1 py-3.5 rounded-xl bg-[#00236f] text-white font-bold hover:bg-blue-900 transition-all shadow-lg shadow-blue-900/20 active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed"
                            disabled>
                        Gửi đánh giá
                    </button>
                </div>
            </form>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        const labels = ['', 'Rất tệ', 'Tệ', 'Bình thường', 'Tốt', 'Tuyệt vời!'];

        function setRating(value) {
            document.getElementById('ratingInput').value = value;
            document.getElementById('ratingLabel').textContent = labels[value];
            document.getElementById('submitBtn').disabled = false;

            document.querySelectorAll('.star-icon').forEach(star => {
                const v = parseInt(star.dataset.value);
                if (v <= value) {
                    star.classList.add('active');
                } else {
                    star.classList.remove('active');
                }
            });
        }

        // Hover effect
        document.querySelectorAll('.star-icon').forEach(star => {
            star.addEventListener('mouseenter', () => {
                const v = parseInt(star.dataset.value);
                document.querySelectorAll('.star-icon').forEach(s => {
                    s.style.color = parseInt(s.dataset.value) <= v ? '#fbbf24' : '#d1d5db';
                });
                document.getElementById('ratingLabel').textContent = labels[v];
            });
            star.addEventListener('mouseleave', () => {
                const current = parseInt(document.getElementById('ratingInput').value);
                document.querySelectorAll('.star-icon').forEach(s => {
                    s.style.color = parseInt(s.dataset.value) <= current ? '#fbbf24' : '#d1d5db';
                });
                document.getElementById('ratingLabel').textContent = current > 0 ? labels[current] : '';
            });
        });
    </script>
}
