@model IEnumerable<CarRentalSystem.Models.Booking>
@{
    ViewData["Title"] = "Quản lý đơn đặt xe";
    Layout = "_AdminLayout";
}

<header class="pt-8 pb-6">
    <div class="flex justify-between items-end">
        <div>
            <h2 class="font-h1 text-h1 text-on-surface mb-1">
                Quản lý Đơn đặt xe toàn hệ thống
            </h2>
            <p class="font-body-md text-on-surface-variant">
                Giám sát và điều phối hoạt động thuê xe thời gian thực
            </p>
        </div>
        <button class="bg-secondary hover:bg-blue-700 text-white px-6 py-2.5 rounded-lg flex items-center gap-2 font-label-md transition-all active:scale-[0.98]">
            <span class="material-symbols-outlined text-[20px]">add</span>
            Tạo đơn mới
        </button>
    </div>
</header>

<section class="mb-6">
    <div class="bg-white p-4 rounded-xl shadow-sm border border-outline-variant flex flex-wrap gap-4 items-center">
        <div class="flex-1 min-w-[300px] relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline">search</span>
            <input class="w-full pl-10 pr-4 py-2 bg-surface-container-low border-outline-variant rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary text-body-md transition-all" placeholder="Tìm theo mã đơn, tên khách hàng hoặc biển số..." type="text" />
        </div>
        <div class="flex gap-3">
            <select class="bg-surface-container-low border-outline-variant rounded-lg py-2 px-3 text-label-md focus:ring-2 focus:ring-primary/20">
                <option>Chi nhánh: Tất cả</option>
            </select>
            <select class="bg-surface-container-low border-outline-variant rounded-lg py-2 px-3 text-label-md focus:ring-2 focus:ring-primary/20">
                <option>Trạng thái: Tất cả</option>
                <option>Chờ xác nhận</option>
                <option>Đang thuê</option>
                <option>Hoàn tất</option>
                <option>Đã hủy</option>
            </select>
            <div class="relative">
                <input class="bg-surface-container-low border-outline-variant rounded-lg py-2 px-3 text-label-md focus:ring-2 focus:ring-primary/20" type="date" />
            </div>
        </div>
        <button class="flex items-center gap-1 text-primary font-label-md px-3 py-2 hover:bg-primary/5 rounded-lg transition-colors">
            <span class="material-symbols-outlined text-[18px]">filter_list</span>
            Lọc nâng cao
        </button>
    </div>
</section>

<section class="flex-1 pb-8">
    <div class="bg-white rounded-xl shadow-sm border border-outline-variant overflow-hidden">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 border-b border-outline-variant">
                    <th class="px-6 py-4 text-[12px] font-semibold text-outline-variant uppercase tracking-wider text-on-surface-variant">Mã đơn</th>
                    <th class="px-6 py-4 text-[12px] font-semibold text-outline-variant uppercase tracking-wider text-on-surface-variant">Khách hàng</th>
                    <th class="px-6 py-4 text-[12px] font-semibold text-outline-variant uppercase tracking-wider text-on-surface-variant">Xe</th>
                    <th class="px-6 py-4 text-[12px] font-semibold text-outline-variant uppercase tracking-wider text-on-surface-variant">Thời gian nhận/trả</th>
                    <th class="px-6 py-4 text-[12px] font-semibold text-outline-variant uppercase tracking-wider text-on-surface-variant text-right">Tổng tiền</th>
                    <th class="px-6 py-4 text-[12px] font-semibold text-outline-variant uppercase tracking-wider text-on-surface-variant text-center">Trạng thái</th>
                    <th class="px-6 py-4 text-[12px] font-semibold text-outline-variant uppercase tracking-wider text-on-surface-variant text-center">Hành động</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant/30">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-slate-50 transition-colors group">
                        <td class="px-6 py-5 font-medium text-primary">#RC-@item.BookingId.ToString("D4")</td>
                        <td class="px-6 py-5">
                            <div class="font-semibold text-on-surface">@(item.Customer?.UserProfile?.FullName ?? "Khách ẩn")</div>
                            <div class="text-[12px] text-on-surface-variant">@(item.Customer?.UserProfile?.PhoneNumber ?? "N/A")</div>
                        </td>
                        <td class="px-6 py-5">
                            <div class="font-semibold text-on-surface">@(item.Vehicle?.VehicleName ?? "N/A")</div>
                            <div class="text-[12px] text-on-surface-variant">@(item.Vehicle?.LicensePlate ?? "N/A")</div>
                        </td>
                        <td class="px-6 py-5">
                            <div class="text-[13px]">@item.PickupDateTime.ToString("dd/MM/yyyy HH:mm") - @item.ReturnDateTime.ToString("dd/MM/yyyy HH:mm")</div>
                        </td>
                        <td class="px-6 py-5 text-right font-bold text-on-surface">
                            @item.TotalAmount.ToString("N0")đ
                        </td>
                        <td class="px-6 py-5 text-center">
                            @if (item.Status == "Cho xac nhan" || item.Status == "Chờ xác nhận")
                            {
                                <span class="px-3 py-1 rounded-full bg-orange-100 text-orange-700 text-[12px] font-semibold whitespace-nowrap">Chờ xử lý</span>
                            }
                            else if (item.Status == "Da xac nhan" || item.Status == "Đã xác nhận")
                            {
                                <span class="px-3 py-1 rounded-full bg-blue-100 text-blue-700 text-[12px] font-semibold whitespace-nowrap">Đã xác nhận</span>
                            }
                            else if (item.Status == "Dang thue" || item.Status == "Đang thuê")
                            {
                                <span class="px-3 py-1 rounded-full bg-purple-100 text-purple-700 text-[12px] font-semibold whitespace-nowrap">Đang thuê</span>
                            }
                            else if (item.Status == "Hoan thanh" || item.Status == "Hoàn thành")
                            {
                                <span class="px-3 py-1 rounded-full bg-green-100 text-green-700 text-[12px] font-semibold whitespace-nowrap">Hoàn tất</span>
                            }
                            else
                            {
                                <span class="px-3 py-1 rounded-full bg-red-100 text-red-700 text-[12px] font-semibold whitespace-nowrap">Đã hủy</span>
                            }
                        </td>
                        <td class="px-6 py-5 text-center">
                            <div class="flex justify-center gap-2">
                                <a href="/Booking/Details/@item.BookingId" class="p-1.5 hover:bg-primary/10 text-primary rounded transition-colors">
                                    <span class="material-symbols-outlined text-[20px]">visibility</span>
                                </a>
                                <button class="p-1.5 hover:bg-secondary/10 text-secondary rounded transition-colors">
                                    <span class="material-symbols-outlined text-[20px]">edit</span>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="flex justify-between items-center px-6 py-4 bg-white border-t border-outline-variant/30">
            <p class="text-label-md text-on-surface-variant">Hiển thị danh sách tự động</p>
            <div class="flex gap-1">
                <button class="px-3 py-1.5 border border-outline-variant rounded hover:bg-slate-50 text-label-md transition-colors">Trước</button>
                <button class="px-4 py-1.5 bg-primary text-white rounded text-label-md">1</button>
                <button class="px-3 py-1.5 border border-outline-variant rounded hover:bg-slate-50 text-label-md transition-colors">Tiếp</button>
            </div>
        </div>
    </div>
</section>