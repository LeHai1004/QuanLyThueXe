@model CarRentalSystem.Models.Booking
@{
    ViewData["Title"] = "Chi tiết Đơn đặt xe #" + Model.BookingId;
    Layout = "_Layout";

    var days = Math.Ceiling((Model.ReturnDateTime - Model.PickupDateTime).TotalDays);
    if (days <= 0) days = 1;

    var deposit = Model.TotalAmount * 0.1m;

    string statusColor = Model.Status switch
    {
        "Dang thue" => "bg-[#0058be] text-white",
        "Da xac nhan" => "bg-[#1e3a8a] text-blue-200",
        "Cho xac nhan" => "bg-amber-100 text-amber-700",
        "Hoan thanh" => "bg-green-600 text-white",
        "Da huy" => "bg-slate-500 text-white",
        _ => "bg-slate-100 text-slate-700"
    };
}

<main class="max-w-7xl mx-auto px-8 py-10 min-h-screen mt-8">
    <div class="flex flex-col md:flex-row md:items-center justify-between mb-10 gap-4">
        <div>
            <h1 class="text-3xl font-bold text-[#00236f]">
                Chi tiết Đơn đặt xe #RC-@Model.BookingId.ToString("D4")
            </h1>
            <p class="text-[16px] text-[#444651] mt-1">
                Quản lý và theo dõi thông tin chi tiết đơn hàng của bạn.
            </p>
        </div>
        <div class="flex items-center">
            <span class="px-6 py-2 rounded-full font-semibold text-[14px] shadow-sm flex items-center gap-2 @statusColor">
                <span class="w-2 h-2 rounded-full bg-white"></span>
                @Model.Status
            </span>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-10 gap-6 items-start">
        <div class="lg:col-span-4 space-y-6">
            <div class="bg-white rounded-xl shadow-sm overflow-hidden border border-[#c5c5d3]">
                <div class="relative h-64 overflow-hidden">
                    <img alt="@Model.Vehicle?.VehicleName"
                         class="w-full h-full object-cover transform hover:scale-105 transition-transform duration-500"
                         src="@(Model.Vehicle?.HinhAnh ?? "https://images.unsplash.com/photo-1550355291-bbee04a92027")" />
                    <div class="absolute top-4 left-4">
                        <span class="bg-[#00236f] px-3 py-1 text-white text-[12px] font-medium rounded-lg shadow-md">@Model.Vehicle?.VehicleName</span>
                    </div>
                </div>
                <div class="p-6">
                    <div class="flex justify-between items-start mb-4">
                        <div>
                            <h3 class="text-[24px] font-semibold text-[#00236f]">
                                @Model.Vehicle?.VehicleName
                            </h3>
                            <p class="text-[#0058be] font-semibold text-[14px] mt-1">
                                Biển số: @(Model.Vehicle?.LicensePlate ?? "Chờ cập nhật")
                            </p>
                        </div>
                        <span class="px-3 py-1 bg-[#dce9ff] rounded text-[#444651] font-semibold text-[14px]">@(Model.Vehicle?.Category?.CategoryName ?? "Xe cho thuê")</span>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div class="flex items-center gap-3 p-3 bg-[#eff4ff] rounded-lg">
                            <span class="material-symbols-outlined text-[#00236f]">airline_seat_recline_normal</span>
                            <span class="text-[16px]">@(Model.Vehicle?.Seats ?? 0) Chỗ</span>
                        </div>
                        <div class="flex items-center gap-3 p-3 bg-[#eff4ff] rounded-lg">
                            <span class="material-symbols-outlined text-[#00236f]">local_gas_station</span>
                            <span class="text-[16px]">@(Model.Vehicle?.FuelType ?? "Xăng")</span>
                        </div>
                        <div class="flex items-center gap-3 p-3 bg-[#eff4ff] rounded-lg">
                            <span class="material-symbols-outlined text-[#00236f]">settings_input_component</span>
                            <span class="text-[16px]">@(Model.Vehicle?.Transmission ?? "Tự động")</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-xl shadow-sm p-6 border border-[#c5c5d3]">
                <h4 class="text-[24px] font-semibold text-[#00236f] mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined">person</span>
                    Thông tin khách hàng
                </h4>
                <div class="space-y-4">
                    <div class="flex justify-between border-b border-[#c5c5d3] pb-2">
                        <span class="text-[#444651] text-[16px]">Họ và tên</span>
                        <span class="font-semibold text-[#00236f]">@(Model.Customer?.UserProfile?.FullName ?? "Khách hàng")</span>
                    </div>
                    <div class="flex justify-between border-b border-[#c5c5d3] pb-2">
                        <span class="text-[#444651] text-[16px]">Số điện thoại</span>
                        <span class="font-semibold text-[#00236f]">@(Model.Customer?.UserProfile?.PhoneNumber ?? "Chưa cập nhật")</span>
                    </div>
                    <div class="flex justify-between border-b border-[#c5c5d3] pb-2">
                        <span class="text-[#444651] text-[16px]">Căn cước công dân</span>
                        <span class="font-semibold text-[#00236f]">@(Model.Customer?.NationalId ?? "Chưa cập nhật")</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="lg:col-span-6 space-y-6">
            <div class="bg-white rounded-xl shadow-sm p-8 border border-[#c5c5d3]">
                <h4 class="text-[24px] font-semibold text-[#00236f] mb-8 flex items-center gap-2">
                    <span class="material-symbols-outlined">calendar_today</span>
                    Thông tin thuê xe
                </h4>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="flex items-start gap-4">
                        <div class="p-3 bg-[#1e3a8a]/10 rounded-full">
                            <span class="material-symbols-outlined text-[#00236f]">location_on</span>
                        </div>
                        <div>
                            <p class="text-[#444651] text-[12px] font-medium uppercase tracking-wider">
                                Địa điểm nhận & trả
                            </p>
                            <p class="font-semibold text-[#0b1c30] mt-1">
                                @Model.PickupLocation
                            </p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="p-3 bg-[#1e3a8a]/10 rounded-full">
                            <span class="material-symbols-outlined text-[#00236f]">timer</span>
                        </div>
                        <div>
                            <p class="text-[#444651] text-[12px] font-medium uppercase tracking-wider">
                                Thời gian thuê
                            </p>
                            <p class="font-semibold text-[#0b1c30] mt-1">@days ngày</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="p-3 bg-[#1e3a8a]/10 rounded-full">
                            <span class="material-symbols-outlined text-[#00236f]">event_available</span>
                        </div>
                        <div>
                            <p class="text-[#444651] text-[12px] font-medium uppercase tracking-wider">
                                Ngày nhận xe
                            </p>
                            <p class="font-semibold text-[#0b1c30] mt-1">@Model.PickupDateTime.ToString("dd/MM/yyyy")</p>
                            <p class="text-[12px] text-[#444651] font-medium">@Model.PickupDateTime.ToString("hh:mm tt")</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="p-3 bg-[#1e3a8a]/10 rounded-full">
                            <span class="material-symbols-outlined text-[#00236f]">event_busy</span>
                        </div>
                        <div>
                            <p class="text-[#444651] text-[12px] font-medium uppercase tracking-wider">
                                Ngày trả xe
                            </p>
                            <p class="font-semibold text-[#0b1c30] mt-1">@Model.ReturnDateTime.ToString("dd/MM/yyyy")</p>
                            <p class="text-[12px] text-[#444651] font-medium">@Model.ReturnDateTime.ToString("hh:mm tt")</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-xl shadow-sm p-8 border border-[#c5c5d3] relative overflow-hidden">
                <div class="absolute top-0 right-0 p-8 opacity-5">
                    <span class="material-symbols-outlined text-[120px]">receipt_long</span>
                </div>
                <h4 class="text-[24px] font-semibold text-[#00236f] mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined">payments</span>
                    Chi tiết thanh toán
                </h4>
                <div class="space-y-4">
                    <div class="flex justify-between items-center text-[16px] py-2">
                        <span class="text-[#444651]">Đơn giá ngày</span>
                        <span class="text-[#0b1c30]">@((Model.Vehicle?.PricePerDay ?? 0).ToString("N0"))đ / ngày</span>
                    </div>
                    <div class="flex justify-between items-center text-[16px] py-2 border-t border-[#c5c5d3]/30">
                        <span class="text-[#444651]">Tổng tiền thuê (@days ngày)</span>
                        <span class="text-[#0b1c30]">@Model.BasePrice.ToString("N0")đ</span>
                    </div>
                    <div class="flex justify-between items-center text-[16px] py-2 border-t border-[#c5c5d3]/30">
                        <span class="text-[#444651]">Tiền đặt cọc (10%)</span>
                        <span class="text-[#0b1c30]">@deposit.ToString("N0")đ</span>
                    </div>
                    <div class="mt-8 p-4 bg-[#00236f] rounded-xl flex justify-between items-center">
                        <span class="text-white font-semibold text-[24px]">Tổng cộng</span>
                        <span class="text-white font-bold text-[36px]">@Model.TotalAmount.ToString("N0")đ</span>
                    </div>
                    <p class="text-[12px] font-medium text-[#444651] italic mt-2 text-right">
                        * Giá trên đã bao gồm bảo hiểm cơ bản và phí VAT.
                    </p>
                </div>
            </div>

            <div class="flex flex-wrap gap-4 pt-4">
                <a href="/Booking/History" class="w-full px-8 py-4 bg-slate-100 text-[#444651] font-semibold text-[14px] rounded-xl flex items-center justify-center gap-2 hover:bg-slate-200 transition-colors cursor-pointer">
                    <span class="material-symbols-outlined">arrow_back</span>
                    Quay lại danh sách
                </a>
            </div>
        </div>
    </div>
</main>