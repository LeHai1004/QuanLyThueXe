@model CarRentalSystem.Models.Booking
@using CarRentalSystem.Enums
@using CarRentalSystem.Helpers
@using CarRentalSystem.Business
@{
    ViewData["Title"] = "Chi tiết Đơn đặt xe #" + Model.BookingId;
    Layout = "_Layout";

    var bookingBiz = new BookingBusiness();
    var days = bookingBiz.CalculateRentalDays(Model.PickupDateTime, Model.ReturnDateTime);

    var deposit = bookingBiz.CalculateDeposit(Model.TotalAmount);

    string statusColor = Model.Status switch
    {
        BookingStatus.Active => "bg-[#2170e4] text-white",
        BookingStatus.Confirmed => "bg-[#1e3a8a] text-blue-200",
        BookingStatus.Pending => "bg-amber-100 text-amber-700",
        BookingStatus.Completed => "bg-green-600 text-white",
        BookingStatus.Cancelled => "bg-slate-500 text-white",
        _ => "bg-slate-100 text-slate-700"
    };

    string statusIcon = Model.Status switch
    {
        BookingStatus.Completed => "check_circle",
        BookingStatus.Cancelled => "cancel",
        BookingStatus.Pending => "hourglass_empty",
        _ => "schedule"
    };
}

<style>
    body {
        background-color: #f8f9ff;
        font-family: 'Inter', sans-serif;
    }

    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }

    .info-icon {
        width: 2.75rem;
        height: 2.75rem;
        border-radius: 9999px;
        background: rgba(30,58,138,0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
</style>

<main class="max-w-7xl mx-auto px-6 md:px-8 py-10 min-h-screen mt-8">

    <div class="flex flex-col md:flex-row md:items-center justify-between mb-10 gap-4">
        <div>
            <div class="flex items-center gap-3 mb-1">
                <a href="/Booking/History"
                   class="text-[#757682] hover:text-[#00236f] transition-colors flex items-center gap-1 text-[14px] font-medium">
                    <span class="material-symbols-outlined text-base">arrow_back</span>
                    Danh sách đặt xe
                </a>
                <span class="text-[#c5c5d3]">/</span>
                <span class="text-[14px] font-medium text-[#00236f]">#RC-@Model.BookingId.ToString("D4")</span>
            </div>
            <h1 class="text-[36px] font-bold leading-[1.2] tracking-[-0.01em] text-[#00236f]">
                Chi tiết Đơn đặt xe #RC-@Model.BookingId.ToString("D4")
            </h1>
            <p class="text-[16px] text-[#444651] mt-1">Quản lý và theo dõi thông tin chi tiết đơn hàng của bạn.</p>
        </div>
        <span class="px-5 py-2.5 rounded-full @statusColor font-semibold text-[14px] inline-flex items-center gap-2 shadow-sm w-max">
            <span class="material-symbols-outlined text-[18px]" style="font-variation-settings:'FILL' 1">@statusIcon</span>
            @Model.Status
        </span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-10 gap-6 items-start">

        <div class="lg:col-span-4 space-y-6">

            <div class="bg-white rounded-xl shadow-sm overflow-hidden border border-[#c5c5d3]/40">
                <div class="relative h-80 overflow-hidden">
                    <img src="@(Model.Vehicle?.HinhAnh ?? "https://images.unsplash.com/photo-1550355291-bbee04a92027")"
                         alt="@Model.Vehicle?.VehicleName"
                         class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" />

                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>

                    <div class="absolute top-4 left-4">
                        <span class="bg-[#00236f] text-white text-[12px] font-bold px-3 py-1.5 rounded-lg shadow-md">
                            @Model.Vehicle?.LicensePlate
                        </span>
                    </div>

                    <div class="absolute bottom-0 left-0 right-0 p-5">
                        <h3 class="text-[22px] font-bold text-white leading-tight drop-shadow">
                            @Model.Vehicle?.VehicleName
                        </h3>
                        <p class="text-blue-300 text-[13px] font-semibold mt-0.5 mb-4">
                            @(Model.Vehicle?.Category?.CategoryName ?? "Xe cao cấp")
                        </p>
                        <div class="grid grid-cols-2 gap-2">
                            <div class="flex items-center gap-2 bg-white/15 backdrop-blur-sm px-3 py-2 rounded-lg">
                                <span class="material-symbols-outlined text-white text-[18px]">airline_seat_recline_normal</span>
                                <span class="text-[13px] font-semibold text-white">@Model.Vehicle?.Seats chỗ ngồi</span>
                            </div>
                            <div class="flex items-center gap-2 bg-white/15 backdrop-blur-sm px-3 py-2 rounded-lg">
                                <span class="material-symbols-outlined text-white text-[18px]">local_gas_station</span>
                                <span class="text-[13px] font-semibold text-white">
                                    @{
                                        var fuel = Model.Vehicle?.FuelType?.ToLower();
                                        var fuelVi = fuel switch
                                        {
                                            "xang" or "gasoline" or "petrol" => "Xăng",
                                            "diesel" => "Dầu diesel",
                                            "electric" or "dien" => "Điện",
                                            "hybrid" => "Hybrid",
                                            _ => Model.Vehicle?.FuelType ?? "Xăng"
                                        };
                                    }
                                    @fuelVi
                                </span>
                            </div>
                            <div class="flex items-center gap-2 bg-white/15 backdrop-blur-sm px-3 py-2 rounded-lg">
                                <span class="material-symbols-outlined text-white text-[18px]">settings</span>
                                <span class="text-[13px] font-semibold text-white">
                                    @{
                                        var trans = Model.Vehicle?.Transmission?.ToLower();
                                        var transVi = trans switch
                                        {
                                            "automatic" or "auto" => "Số tự động",
                                            "manual" => "Số sàn",
                                            "cvt" => "Số CVT",
                                            "so tu dong" => "Số tự động",
                                            "so san" => "Số sàn",
                                            _ => Model.Vehicle?.Transmission ?? "Số tự động"
                                        };
                                    }
                                    @transVi
                                </span>
                            </div>
                            <div class="flex items-center gap-2 bg-white/15 backdrop-blur-sm px-3 py-2 rounded-lg">
                                <span class="material-symbols-outlined text-white text-[18px]">directions_car</span>
                                <span class="text-[13px] font-semibold text-white">@(Model.Vehicle?.Brand ?? "—")</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-xl shadow-sm p-6 border border-[#c5c5d3]/40">
                <h4 class="text-[24px] font-semibold text-[#00236f] mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined">person</span>
                    Thông tin khách hàng
                </h4>
                <div class="space-y-3">
                    <div class="flex justify-between items-center py-2.5 border-b border-[#c5c5d3]/30">
                        <span class="text-[#444651] text-[15px]">Họ và tên</span>
                        <span class="text-[15px] font-semibold text-[#00236f]">
                            @(Model.Customer?.UserProfile?.FullName ?? "N/A")
                        </span>
                    </div>
                    <div class="flex justify-between items-center py-2.5 border-b border-[#c5c5d3]/30">
                        <span class="text-[#444651] text-[15px]">Số điện thoại</span>
                        <span class="text-[15px] font-semibold text-[#00236f]">
                            @(Model.Customer?.UserProfile?.PhoneNumber ?? "N/A")
                        </span>
                    </div>
                    <div class="flex justify-between items-center py-2.5 border-b border-[#c5c5d3]/30">
                        <span class="text-[#444651] text-[15px]">Số CCCD</span>
                        <span class="text-[15px] font-semibold text-[#00236f]">
                            @((Model.Customer?.NationalId ?? "N/A").MaskNationalId())
                        </span>
                    </div>
                    <div class="flex justify-between items-center py-2.5">
                        <span class="text-[#444651] text-[15px]">Địa điểm nhận xe</span>
                        <span class="text-[15px] font-semibold text-[#00236f] text-right max-w-[55%]">
                            @Model.PickupLocation
                        </span>
                    </div>
                </div>
            </div>

        </div>

        <div class="lg:col-span-6 space-y-6">

            <div class="bg-white rounded-xl shadow-sm p-8 border border-[#c5c5d3]/40">
                <h4 class="text-[24px] font-semibold text-[#00236f] mb-8 flex items-center gap-2">
                    <span class="material-symbols-outlined">calendar_today</span>
                    Thông tin thuê xe
                </h4>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="flex items-start gap-4">
                        <div class="info-icon">
                            <span class="material-symbols-outlined text-[#00236f]">location_on</span>
                        </div>
                        <div>
                            <p class="text-[12px] text-[#757682] uppercase tracking-wider font-bold">Địa điểm nhận &amp; trả</p>
                            <p class="text-[15px] font-semibold text-[#0b1c30] mt-1">@Model.PickupLocation</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="info-icon">
                            <span class="material-symbols-outlined text-[#00236f]">timer</span>
                        </div>
                        <div>
                            <p class="text-[12px] text-[#757682] uppercase tracking-wider font-bold">Thời gian thuê</p>
                            <p class="text-[15px] font-semibold text-[#0b1c30] mt-1">@days ngày</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="info-icon">
                            <span class="material-symbols-outlined text-[#00236f]">event_available</span>
                        </div>
                        <div>
                            <p class="text-[12px] text-[#757682] uppercase tracking-wider font-bold">Ngày nhận xe</p>
                            <p class="text-[15px] font-semibold text-[#0b1c30] mt-1">@Model.PickupDateTime.ToVnDate()</p>
                            <p class="text-[12px] text-[#757682] mt-0.5">@Model.PickupDateTime.ToString("HH:mm")</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="info-icon">
                            <span class="material-symbols-outlined text-[#00236f]">event_busy</span>
                        </div>
                        <div>
                            <p class="text-[12px] text-[#757682] uppercase tracking-wider font-bold">Ngày trả xe</p>
                            <p class="text-[15px] font-semibold text-[#0b1c30] mt-1">@Model.ReturnDateTime.ToVnDate()</p>
                            <p class="text-[12px] text-[#757682] mt-0.5">@Model.ReturnDateTime.ToString("HH:mm")</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-xl shadow-sm p-8 border border-[#c5c5d3]/40 relative overflow-hidden">
                <div class="absolute top-0 right-0 p-6 opacity-[0.04] pointer-events-none">
                    <span class="material-symbols-outlined" style="font-size:120px">receipt_long</span>
                </div>
                <h4 class="text-[24px] font-semibold text-[#00236f] mb-6 flex items-center gap-2 relative z-10">
                    <span class="material-symbols-outlined">payments</span>
                    Chi tiết thanh toán
                </h4>
                <div class="space-y-3 relative z-10">
                    <div class="flex justify-between items-center py-2.5 text-[16px]">
                        <span class="text-[#444651]">Đơn giá / ngày</span>
                        <span class="text-[#0b1c30] font-medium">@CurrencyHelper.FormatVnd(Model.Vehicle?.PricePerDay ?? 0)</span>
                    </div>
                    <div class="flex justify-between items-center py-2.5 text-[16px] border-t border-[#c5c5d3]/30">
                        <span class="text-[#444651]">Tổng tiền thuê (@days ngày)</span>
                        <span class="text-[#0b1c30] font-medium">@CurrencyHelper.FormatVnd(Model.BasePrice)</span>
                    </div>
                    <div class="flex justify-between items-center py-2.5 text-[16px] border-t border-[#c5c5d3]/30">
                        <span class="text-[#444651]">Tiền đặt cọc (10%)</span>
                        <span class="text-[#0b1c30] font-medium">@CurrencyHelper.FormatVnd(deposit)</span>
                    </div>
                    <div class="mt-6 p-5 bg-[#00236f] rounded-xl flex justify-between items-center">
                        <span class="text-white text-[24px] font-semibold">Tổng cộng</span>
                        <span class="text-white text-[36px] font-bold leading-none">@CurrencyHelper.FormatVnd(Model.TotalAmount)</span>
                    </div>
                    <p class="text-[12px] text-[#757682] italic text-right pt-1">
                        * Giá trên đã bao gồm bảo hiểm cơ bản và phí VAT.
                    </p>
                </div>
            </div>

            <div class="flex flex-wrap gap-4 pt-2">
                <a href="/Booking/History"
                   class="flex-1 min-w-[160px] border-2 border-[#c5c5d3] text-[#444651] py-4 px-6 rounded-xl text-[14px] font-semibold
                    flex items-center justify-center gap-2 hover:border-[#00236f] hover:text-[#00236f] transition-all active:scale-95">
                    <span class="material-symbols-outlined">arrow_back</span>
                    Quay lại danh sách
                </a>

                @if (Model.Status == BookingStatus.Completed)
                {
                    <a asp-controller="Invoice" asp-action="Details" asp-route-id="@Model.BookingId"
                       class="flex-1 min-w-[160px] bg-[#00236f] text-white py-4 px-6 rounded-xl text-[14px] font-semibold
                        flex items-center justify-center gap-2 hover:bg-[#1e3a8a] transition-all active:scale-95 shadow-md shadow-[#00236f]/20">
                        <span class="material-symbols-outlined">receipt_long</span>
                        Xem hóa đơn
                    </a>
                }

                @if (Model.Status == BookingStatus.Pending)
                {
                    <a href="/Booking/Edit/@Model.BookingId"
                       class="flex-1 min-w-[160px] bg-amber-50 border border-amber-200 text-amber-700 py-4 px-6 rounded-xl text-[14px] font-semibold
                        flex items-center justify-center gap-2 hover:bg-amber-100 transition-all active:scale-95">
                        <span class="material-symbols-outlined">edit_calendar</span>
                        Thay đổi lịch trình
                    </a>
                }
            </div>

        </div>
    </div>
</main>