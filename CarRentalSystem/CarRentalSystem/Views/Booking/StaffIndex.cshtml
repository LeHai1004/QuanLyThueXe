@model IEnumerable<CarRentalSystem.Models.Booking>
@using CarRentalSystem.Enums
@using CarRentalSystem.Helpers
@{
    ViewData["Title"] = "Danh sách đơn đặt xe";
    Layout = "_StaffLayout";
}

<div class="space-y-6">
    <form method="get" action="/Booking/Index" class="bg-white p-4 rounded-xl shadow-sm border border-outline-variant">
        <div class="flex flex-wrap gap-4 items-end mb-4">
            <div class="flex flex-col gap-1">
                <label class="text-[11px] font-bold text-outline uppercase tracking-wider px-1">
                    Trạng thái
                    <select name="status" class="bg-surface-container-low border-none rounded-lg px-4 py-2 text-[14px] focus:ring-1 focus:ring-primary min-w-[160px]">
                        <option value="">Tất cả trạng thái</option>
                        @{
                            var currentStatus = ViewBag.CurrentStatus as string;
                        }
                        <option value="@BookingStatus.Pending" selected="@(currentStatus == BookingStatus.Pending ? "selected" : null)">Chờ xác nhận</option>
                        <option value="@BookingStatus.Confirmed" selected="@(currentStatus == BookingStatus.Confirmed ? "selected" : null)">Đã xác nhận</option>
                        <option value="@BookingStatus.Active" selected="@(currentStatus == BookingStatus.Active ? "selected" : null)">Đang thuê</option>
                        <option value="@BookingStatus.Completed" selected="@(currentStatus == BookingStatus.Completed ? "selected" : null)">Hoàn thành</option>
                    </select>
                </label>
            </div>
            <div class="flex flex-col gap-1">
                <label class="text-[11px] font-bold text-outline uppercase tracking-wider px-1">
                    Từ ngày
                    <input name="fromDate" class="bg-surface-container-low border-none rounded-lg px-4 py-2 text-[14px] focus:ring-1 focus:ring-primary" type="date" value="@ViewBag.FromDate" />
                </label>
            </div>
            <div class="flex flex-col gap-1">
                <label class="text-[11px] font-bold text-outline uppercase tracking-wider px-1">
                    Đến ngày
                    <input name="toDate" class="bg-surface-container-low border-none rounded-lg px-4 py-2 text-[14px] focus:ring-1 focus:ring-primary" type="date" value="@ViewBag.ToDate" />
                </label>
            </div>
        </div>

        <div class="flex items-end gap-4">
            <div class="relative flex-1">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline">search</span>
                <input name="search" class="w-full pl-10 pr-4 py-2 bg-surface-container-low border-none rounded-lg focus:ring-1 focus:ring-primary transition-all text-[14px]" placeholder="Tìm theo mã đơn hoặc tên khách..." type="text" value="@ViewBag.SearchString" />
            </div>
            <button type="submit" class="px-6 py-2 bg-primary text-white font-semibold rounded-lg hover:bg-blue-700 transition-all flex items-center gap-2 text-sm whitespace-nowrap">
                <span class="material-symbols-outlined text-[18px]">search</span>
                Tìm kiếm
            </button>
            <a href="/Booking/Index" class="px-4 py-2 bg-slate-100 text-slate-600 font-semibold rounded-lg hover:bg-slate-200 transition-all text-sm whitespace-nowrap">
                Xóa bộ lọc
            </a>
        </div>
    </form>

    <div class="bg-white rounded-xl border border-outline-variant shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-surface-container-lowest border-b border-outline-variant text-[12px] font-bold text-on-surface-variant uppercase tracking-wider">
                        <th class="py-4 px-6">Mã đơn</th>
                        <th class="py-4 px-6">Khách hàng</th>
                        <th class="py-4 px-6">Xe thuê</th>
                        <th class="py-4 px-6">Thời gian</th>
                        <th class="py-4 px-6 text-right">Tổng tiền</th>
                        <th class="py-4 px-6 text-center">Trạng thái</th>
                        <th class="py-4 px-6 text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-outline-variant/50">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-surface-container-low/50 transition-colors">
                            <td class="py-4 px-6 font-bold text-primary">#RC-@item.BookingId.ToString("D4")</td>
                            <td class="py-4 px-6">
                                <p class="font-semibold text-on-surface">@(item.Customer?.UserProfile?.FullName ?? "N/A")</p>
                                <p class="text-[12px] text-outline">SĐT: @(item.Customer?.UserProfile?.PhoneNumber ?? "N/A")</p>
                            </td>
                            <td class="py-4 px-6">
                                <p class="font-medium text-on-surface">@(item.Vehicle?.VehicleName ?? "N/A")</p>
                                <p class="text-[12px] text-outline">Biển số: @(item.Vehicle?.LicensePlate ?? "N/A")</p>
                            </td>
                            <td class="py-4 px-6">
                                <p class="text-[13px] text-on-surface">@item.PickupDateTime.ToVnDate()</p>
                                <p class="text-[13px] text-on-surface-variant">đến @item.ReturnDateTime.ToVnDate()</p>
                            </td>
                            <td class="py-4 px-6 font-bold text-secondary text-right">@CurrencyHelper.FormatVnd(item.TotalAmount)</td>
                            <td class="py-4 px-6 text-center">
                                @if (item.Status == BookingStatus.Pending)
                                {
                                    <span class="px-3 py-1 rounded-full text-[11px] font-bold bg-amber-100 text-amber-700">Chờ xác nhận</span>
                                }
                                else if (item.Status == BookingStatus.Confirmed)
                                {
                                    <span class="px-3 py-1 rounded-full text-[11px] font-bold bg-[#1e3a8a] text-blue-200">Đã xác nhận</span>
                                }
                                else if (item.Status == BookingStatus.Active)
                                {
                                    <span class="px-3 py-1 rounded-full text-[11px] font-bold bg-[#0058be] text-white">Đang thuê</span>
                                }
                                else if (item.Status == BookingStatus.Completed)
                                {
                                    <span class="px-3 py-1 rounded-full text-[11px] font-bold bg-emerald-100 text-emerald-700">Hoàn thành</span>
                                }
                                else
                                {
                                    <span class="px-3 py-1 rounded-full text-[11px] font-bold bg-slate-100 text-slate-600">Đã hủy</span>
                                }
                            </td>
                            <td class="px-6 py-4 text-center">
                                <div class="flex items-center justify-center gap-2">
                                    <a href="/Booking/Details/@item.BookingId" class="p-1.5 text-blue-600 hover:bg-blue-50 rounded transition-colors" title="Xem chi tiết">
                                        <span class="material-symbols-outlined text-[20px]">visibility</span>
                                    </a>

                                    @if (item.Status == BookingStatus.Pending)
                                    {
                                        <form asp-action="Approve" method="post" class="m-0 p-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.BookingId" />
                                            <button type="submit" class="p-1.5 text-emerald-600 hover:bg-emerald-50 rounded transition-colors" title="Duyệt đơn">
                                                <span class="material-symbols-outlined text-[20px]">check_circle</span>
                                            </button>
                                        </form>
                                        <form asp-action="Reject" method="post" class="m-0 p-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.BookingId" />
                                            <button type="submit" class="p-1.5 text-red-600 hover:bg-red-50 rounded transition-colors" title="Từ chối">
                                                <span class="material-symbols-outlined text-[20px]">cancel</span>
                                            </button>
                                        </form>
                                    }
                                    else if (item.Status == BookingStatus.Confirmed)
                                    {
                                        <form asp-action="HandoverVehicle" method="post" class="m-0 p-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.BookingId" />
                                            <button type="submit" class="px-3 py-1 bg-[#00236f] text-white text-xs font-bold rounded-lg hover:bg-blue-900 transition-colors flex items-center gap-1 shadow-sm">
                                                <span class="material-symbols-outlined text-[14px]">key</span> Giao xe
                                            </button>
                                        </form>
                                    }
                                    else if (item.Status == BookingStatus.Active)
                                    {
                                        <form asp-action="ReturnVehicle" method="post" class="m-0 p-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.BookingId" />
                                            <button type="submit" class="px-3 py-1 bg-emerald-600 text-white text-xs font-bold rounded-lg hover:bg-emerald-700 transition-colors flex items-center gap-1 shadow-sm">
                                                <span class="material-symbols-outlined text-[14px]">task_alt</span> Nhận xe
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="px-6 py-4 bg-surface-container-low/30 border-t border-outline-variant flex items-center justify-between">
            <p class="text-[14px] text-outline">Hiển thị dữ liệu trực tiếp từ SQL Server</p>
        </div>
    </div>
</div>