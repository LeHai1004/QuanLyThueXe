@model IEnumerable<CarRentalSystem.Models.Booking>
@{
    ViewData["Title"] = "Đơn đặt của tôi";
    Layout = "_Layout";
}

@section Styles {
    <style>
        .booking-card-shadow {
            box-shadow: 0 10px 30px -10px rgba(30, 58, 138, 0.08);
        }
    </style>
}

<main class="flex-grow pt-12 pb-20">
    <div class="max-w-[1280px] mx-auto px-8">
        <div class="mb-10">
            <h1 class="text-4xl font-bold text-[#00236f] mb-4">Đơn đặt của tôi</h1>
            <p class="text-slate-500 max-w-2xl text-lg">
                Quản lý các chuyến đi của bạn, xem chi tiết lịch trình và theo dõi
                trạng thái thuê xe một cách dễ dàng.
            </p>
        </div>

        <div class="flex flex-wrap items-center gap-3 mb-8 bg-white p-2 rounded-xl border border-slate-200 shadow-sm overflow-x-auto whitespace-nowrap">
            <button class="px-6 py-2.5 rounded-lg bg-[#00236f] text-white font-semibold text-sm transition-all shadow-md">
                Tất cả
            </button>
            <button class="px-6 py-2.5 rounded-lg bg-slate-50 hover:bg-slate-100 text-slate-600 font-semibold text-sm transition-all">
                Chờ xác nhận
            </button>
            <button class="px-6 py-2.5 rounded-lg bg-slate-50 hover:bg-slate-100 text-slate-600 font-semibold text-sm transition-all">
                Đã xác nhận
            </button>
            <button class="px-6 py-2.5 rounded-lg bg-slate-50 hover:bg-slate-100 text-slate-600 font-semibold text-sm transition-all">
                Đang thuê
            </button>
            <button class="px-6 py-2.5 rounded-lg bg-slate-50 hover:bg-slate-100 text-slate-600 font-semibold text-sm transition-all">
                Hoàn thành
            </button>
            <button class="px-6 py-2.5 rounded-lg bg-slate-50 hover:bg-slate-100 text-slate-600 font-semibold text-sm transition-all">
                Đã hủy
            </button>
        </div>

        @if (!Model.Any())
        {
            <div class="bg-blue-50 rounded-2xl p-12 text-center border border-blue-100">
                <span class="material-symbols-outlined text-6xl text-blue-200 mb-4">directions_car</span>
                <h3 class="text-xl font-bold text-[#00236f] mb-2">Bạn chưa có chuyến đi nào</h3>
                <p class="text-slate-500 mb-6">Hãy bắt đầu hành trình đầu tiên của bạn cùng chúng tôi ngay hôm nay.</p>
                <a href="/Vehicle/CustomerList" class="inline-block bg-[#00236f] text-white px-6 py-3 rounded-xl font-bold hover:bg-blue-900 transition-all">
                    Khám phá xe ngay
                </a>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 gap-6">
                @foreach (var item in Model)
                {
                    // Logic C# tạo hiệu ứng Mờ / Trắng đen cho ảnh và thẻ tuỳ theo trạng thái
                    string cardOpacityClass = item.Status == "Da huy" ? "opacity-75" : (item.Status == "Hoan thanh" ? "opacity-90 hover:opacity-100" : "");
                    string imgGrayscaleClass = item.Status == "Da huy" ? "grayscale" : (item.Status == "Hoan thanh" ? "grayscale-[30%]" : "");
                    string lineThroughClass = item.Status == "Da huy" ? "line-through text-slate-400" : "text-slate-700";

                    <div class="bg-white rounded-xl overflow-hidden border border-slate-200 booking-card-shadow flex flex-col md:flex-row hover:border-[#00236f]/30 transition-all @cardOpacityClass">

                        <div class="md:w-1/3 relative h-64 md:h-auto overflow-hidden">
                            <img class="absolute inset-0 w-full h-full object-cover @imgGrayscaleClass"
                                 src="@(item.Vehicle?.HinhAnh ?? "https://images.unsplash.com/photo-1550355291-bbee04a92027?auto=format&fit=crop&w=800&q=80")"
                                 alt="@item.Vehicle?.VehicleName" />
                            <div class="absolute top-4 left-4">
                                @if (item.Status == "Dang thue")
                                {
                                    <span class="px-3 py-1.5 rounded-full bg-[#0058be] text-white font-semibold text-xs uppercase tracking-wider shadow-lg">Đang thuê</span>
                                }
                                else if (item.Status == "Da xac nhan")
                                {
                                    <span class="px-3 py-1.5 rounded-full bg-[#1e3a8a] text-blue-200 font-semibold text-xs uppercase tracking-wider shadow-lg">Đã xác nhận</span>
                                }
                                else if (item.Status == "Cho xac nhan")
                                {
                                    <span class="px-3 py-1.5 rounded-full bg-amber-100 text-amber-700 font-semibold text-xs uppercase tracking-wider shadow-lg">Chờ xác nhận</span>
                                }
                                else if (item.Status == "Hoan thanh")
                                {
                                    <span class="px-3 py-1.5 rounded-full bg-green-600 text-white font-semibold text-xs uppercase tracking-wider shadow-lg">Hoàn thành</span>
                                }
                                else
                                {
                                    <span class="px-3 py-1.5 rounded-full bg-slate-500 text-white font-semibold text-xs uppercase tracking-wider shadow-lg">Đã hủy</span>
                                }
                            </div>
                        </div>

                        <div class="md:w-2/3 p-8 flex flex-col justify-between">
                            <div>
                                <div class="flex justify-between items-start mb-4">
                                    <div>
                                        <h3 class="text-2xl font-bold @(item.Status == "Da huy" ? "text-slate-500" : "text-[#00236f]") mb-1">
                                            @item.Vehicle?.VehicleName
                                        </h3>
                                        <p class="text-slate-500 text-xs flex items-center gap-1 font-medium">
                                            <span class="material-symbols-outlined text-[16px]">fingerprint</span>
                                            Mã đặt: #RC-@item.BookingId.ToString("D4")
                                        </p>
                                    </div>
                                    <div class="text-right">
                                        <p class="@(item.Status == "Da huy" ? "text-slate-500" : "text-[#00236f]") text-2xl font-bold">
                                            @item.TotalAmount.ToString("N0")đ
                                        </p>
                                        <p class="text-slate-500 text-xs">Tổng chi phí</p>
                                    </div>
                                </div>

                                <div class="grid grid-cols-2 gap-4 mb-6">
                                    <div class="bg-slate-50 p-4 rounded-lg">
                                        <p class="text-xs text-slate-500 uppercase font-semibold mb-1">Ngày nhận</p>
                                        <p class="font-semibold @lineThroughClass">@item.PickupDateTime.ToString("dd/MM/yyyy")</p>
                                    </div>
                                    <div class="bg-slate-50 p-4 rounded-lg">
                                        <p class="text-xs text-slate-500 uppercase font-semibold mb-1">Ngày trả</p>
                                        <p class="font-semibold @lineThroughClass">@item.ReturnDateTime.ToString("dd/MM/yyyy")</p>
                                    </div>
                                </div>
                            </div>

                            <div class="flex justify-end gap-3 mt-auto">
                                @if (item.Status == "Hoan thanh")
                                {
                                    <button class="px-6 py-2.5 rounded-lg bg-[#0058be] text-white font-semibold text-sm hover:bg-[#00236f] transition-all shadow-md active:scale-95 flex items-center gap-2">
                                        <span class="material-symbols-outlined text-[18px]">star</span> Đánh giá
                                    </button>
                                    <button class="px-6 py-2.5 rounded-lg bg-[#00236f] text-white font-semibold text-sm hover:bg-blue-900 transition-all shadow-md active:scale-95">
                                        Thuê lại
                                    </button>
                                }
                                @if (item.Status == "Cho xac nhan" || item.Status == "Da xac nhan")
                                {
                                    <button class="px-6 py-2.5 rounded-lg text-red-600 font-semibold text-sm hover:bg-red-50 transition-all">
                                        Hủy đặt xe
                                    </button>
                                }
                                @if (item.Status != "Da huy")
                                {
                                    <a href="/Booking/CustomerDetails/@item.BookingId" class="px-6 py-2.5 rounded-lg border-2 border-[#00236f] text-[#00236f] font-semibold text-sm hover:bg-[#00236f] hover:text-white transition-all active:scale-95">
                                        Xem chi tiết
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</main>