@model IEnumerable<CarRentalSystem.Models.ImportReceipt>
@using CarRentalSystem.Enums
@using CarRentalSystem.Helpers
@{
    ViewData["Title"] = "Danh sách phiếu nhập xe";
    Layout = "_StaffLayout";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="mb-4 bg-emerald-50 border border-emerald-200 p-4 rounded-xl flex items-center gap-3">
        <span class="material-symbols-outlined text-emerald-500">check_circle</span>
        <p class="text-sm font-bold text-emerald-700">@TempData["SuccessMessage"]</p>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="mb-4 bg-red-50 border border-red-200 p-4 rounded-xl flex items-center gap-3">
        <span class="material-symbols-outlined text-red-500">error</span>
        <p class="text-sm font-bold text-red-700">@TempData["ErrorMessage"]</p>
    </div>
}

<div class="space-y-6">
    <div class="flex justify-between items-center bg-white p-6 rounded-2xl border border-outline-variant/50 shadow-sm">
        <div>
            <h3 class="text-lg font-bold text-primary">Lịch sử nhập phương tiện</h3>
            <p class="text-xs text-on-surface-variant">Quản lý và theo dõi trạng thái phê duyệt các phiếu nhập kho</p>
        </div>
        <a href="/ImportReceipt/Create" class="px-5 py-3 bg-secondary text-white font-bold rounded-xl shadow-lg shadow-blue-500/20 hover:bg-blue-700 transition-all flex items-center gap-2 text-sm">
            <span class="material-symbols-outlined text-[20px]">add</span>
            Lập phiếu nhập mới
        </a>
    </div>

    <div class="bg-white rounded-2xl border border-outline-variant/50 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-100 text-[11px] font-bold text-on-surface-variant uppercase tracking-wider">
                        <th class="py-4 px-6">Mã phiếu</th>
                        <th class="py-4 px-6">Nhà cung cấp</th>
                        <th class="py-4 px-6">Ngày tạo</th>
                        <th class="py-4 px-6">Chi phí</th>
                        <th class="py-4 px-6">Trạng thái</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-sm">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="py-4 px-6 font-bold text-primary">@(item.SoImportReceipt ?? "PN" + item.ImportReceiptId.ToString("D4"))</td>
                            <td class="py-4 px-6">@(item.Supplier?.SupplierName ?? "Chưa rõ")</td>
                            <td class="py-4 px-6 text-on-surface-variant">@item.ImportDate.ToVnFormat()</td>
                            <td class="py-4 px-6 font-bold text-secondary">@CurrencyHelper.FormatVnd(item.TotalAmount)</td>
                            <td class="py-4 px-6">
                                @if (item.Status == ImportReceiptStatus.Pending)
                                {
                                    <span class="px-2.5 py-1 rounded-lg bg-amber-50 text-amber-700 text-xs font-bold border border-amber-200">Chờ duyệt</span>
                                }
                                else if (item.Status == ImportReceiptStatus.Approved)
                                {
                                    <span class="px-2.5 py-1 rounded-lg bg-emerald-50 text-emerald-700 text-xs font-bold border border-emerald-200">Đã duyệt</span>
                                }
                                else
                                {
                                    <span class="px-2.5 py-1 rounded-lg bg-rose-50 text-rose-700 text-xs font-bold border border-rose-200">Từ chối</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>