@model IEnumerable<CarRentalSystem.Models.Vehicle>
@{
    ViewData["Title"] = "Danh sách xe";
    Layout = "_Layout";
    var categories = ViewBag.Categories as IEnumerable<CarRentalSystem.Models.VehicleCategory>;

    // Lấy thông tin phân trang từ Controller
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
    int totalItems = ViewBag.TotalItems;
}

@section Styles {
    <style>
        .filter-scrollbar::-webkit-scrollbar {
            width: 4px;
        }

        .filter-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }

        .filter-scrollbar::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }

            .filter-scrollbar::-webkit-scrollbar-thumb:hover {
                background: #94a3b8;
            }

        details > summary {
            list-style: none;
        }

            details > summary::-webkit-details-marker {
                display: none;
            }
    </style>
}

<main class="max-w-[1280px] mx-auto pt-8 pb-20 px-8 flex flex-col md:flex-row gap-8">

    <aside class="w-full md:w-72 flex-shrink-0">
        <form id="filterForm" method="get" action="/Vehicle/CustomerList" class="md:sticky md:top-24 bg-white p-5 rounded-2xl border border-slate-200 shadow-sm flex flex-col h-auto md:h-[calc(100vh-120px)]">

            <input type="hidden" name="page" id="pageInput" value="1" />

            <div class="flex items-center justify-between mb-4 pb-4 border-b border-slate-100">
                <h2 class="text-lg font-black text-[#00236f] flex items-center gap-2">
                    <span class="material-symbols-outlined text-[20px]">filter_alt</span> Bộ lọc xe
                </h2>
                <span class="bg-blue-50 text-[#00236f] px-2.5 py-1 rounded-md text-xs font-bold">@totalItems xe</span>
            </div>

            <div class="flex-1 overflow-y-auto pr-2 space-y-5 filter-scrollbar">

                <details class="group" open>
                    <summary class="flex justify-between items-center font-bold cursor-pointer text-sm text-slate-800 select-none">
                        Danh mục xe
                        <span class="transition-transform duration-300 group-open:rotate-180 material-symbols-outlined text-slate-400">expand_more</span>
                    </summary>
                    <div class="pt-4 space-y-2.5">
                        <label class="flex items-center gap-3 cursor-pointer group/item">
                            <input type="radio" name="categoryId" value="0" class="w-4 h-4 text-[#00236f] bg-slate-100 border-slate-300 focus:ring-[#00236f]" @(ViewBag.CurrentCategory == 0 ? "checked" : "") />
                            <span class="text-sm font-medium text-slate-600 group-hover/item:text-[#00236f] transition-colors">Tất cả xe</span>
                        </label>

                        @if (categories != null)
                        {
                            foreach (var cat in categories)
                            {
                                <label class="flex items-center gap-3 cursor-pointer group/item">
                                    <input type="radio" name="categoryId" value="@cat.CategoryId" class="w-4 h-4 text-[#00236f] bg-slate-100 border-slate-300 focus:ring-[#00236f]" @(ViewBag.CurrentCategory == cat.CategoryId ? "checked" : "") />
                                    <span class="text-sm font-medium text-slate-600 group-hover/item:text-[#00236f] transition-colors">@cat.CategoryName</span>
                                </label>
                            }
                        }
                    </div>
                </details>

                <hr class="border-slate-100" />

                <details class="group" open>
                    <summary class="flex justify-between items-center font-bold cursor-pointer text-sm text-slate-800 select-none">
                        Mức giá tối đa/ngày
                        <span class="transition-transform duration-300 group-open:rotate-180 material-symbols-outlined text-slate-400">expand_more</span>
                    </summary>
                    <div class="pt-4 pb-2">
                        <input type="range" name="maxPrice" min="500000" max="10000000" step="500000" value="@ViewBag.CurrentMaxPrice"
                               oninput="document.getElementById('priceDisplay').innerText = new Intl.NumberFormat('vi-VN').format(this.value) + ' VNĐ'"
                               class="w-full h-1.5 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-[#00236f]" />
                        <div class="text-center mt-3 text-sm font-bold text-[#00236f] bg-blue-50 py-1.5 rounded-lg" id="priceDisplay">
                            @(((decimal)ViewBag.CurrentMaxPrice).ToString("N0")) VNĐ
                        </div>
                    </div>
                </details>

                <hr class="border-slate-100" />

                <details class="group" open>
                    <summary class="flex justify-between items-center font-bold cursor-pointer text-sm text-slate-800 select-none">
                        Số chỗ ngồi
                        <span class="transition-transform duration-300 group-open:rotate-180 material-symbols-outlined text-slate-400">expand_more</span>
                    </summary>
                    <div class="pt-4 grid grid-cols-2 gap-2">
                        <label class="cursor-pointer">
                            <input type="radio" name="seats" value="0" class="hidden peer" @(ViewBag.CurrentSeats == 0 ? "checked" : "") />
                            <div class="py-2 rounded-lg border text-center text-xs font-bold transition-all peer-checked:border-[#00236f] peer-checked:bg-[#00236f] peer-checked:text-white border-slate-200 text-slate-600 hover:border-[#00236f]">Tất cả</div>
                        </label>
                        <label class="cursor-pointer">
                            <input type="radio" name="seats" value="4" class="hidden peer" @(ViewBag.CurrentSeats == 4 ? "checked" : "") />
                            <div class="py-2 rounded-lg border text-center text-xs font-bold transition-all peer-checked:border-[#00236f] peer-checked:bg-[#00236f] peer-checked:text-white border-slate-200 text-slate-600 hover:border-[#00236f]">4 chỗ</div>
                        </label>
                        <label class="cursor-pointer">
                            <input type="radio" name="seats" value="5" class="hidden peer" @(ViewBag.CurrentSeats == 5 ? "checked" : "") />
                            <div class="py-2 rounded-lg border text-center text-xs font-bold transition-all peer-checked:border-[#00236f] peer-checked:bg-[#00236f] peer-checked:text-white border-slate-200 text-slate-600 hover:border-[#00236f]">5 chỗ</div>
                        </label>
                        <label class="cursor-pointer">
                            <input type="radio" name="seats" value="7" class="hidden peer" @(ViewBag.CurrentSeats == 7 ? "checked" : "") />
                            <div class="py-2 rounded-lg border text-center text-xs font-bold transition-all peer-checked:border-[#00236f] peer-checked:bg-[#00236f] peer-checked:text-white border-slate-200 text-slate-600 hover:border-[#00236f]">7 chỗ</div>
                        </label>
                    </div>
                </details>
            </div>

            <div class="pt-4 mt-4 border-t border-slate-100 grid grid-cols-2 gap-3">
                <a href="/Vehicle/CustomerList" class="py-2.5 rounded-xl border border-slate-200 text-slate-600 text-center text-sm font-bold hover:bg-slate-50 transition-colors">
                    Xóa lọc
                </a>
                <button type="button" onclick="changePage(1)" class="py-2.5 rounded-xl bg-[#00236f] text-white text-center text-sm font-bold hover:bg-blue-900 transition-colors shadow-lg shadow-blue-900/20 active:scale-95">
                    Áp dụng
                </button>
            </div>
        </form>
    </aside>

    <div class="flex-1 flex flex-col">
        <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-8">
            <div>
                <h1 class="text-3xl font-black text-on-surface tracking-tight mb-1">Khám phá xe</h1>
                <p class="text-slate-500 font-medium text-sm">Tìm thấy <strong class="text-[#00236f]">@totalItems</strong> mẫu xe phù hợp tiêu chí</p>
            </div>

            <div class="flex items-center gap-3 bg-white px-3 py-1.5 rounded-xl border border-slate-200 shadow-sm w-fit">
                <span class="material-symbols-outlined text-slate-400 text-[20px]">sort</span>
                <select name="sortOrder" form="filterForm" onchange="changePage(1)" class="border-none bg-transparent text-sm font-bold text-[#00236f] focus:ring-0 cursor-pointer py-1 pr-8">
                    @if (ViewBag.CurrentSort == "default")
                    {
                        <option value="default" selected>Phổ biến nhất</option>
                    }
                    else
                    {
                        <option value="default">Phổ biến nhất</option>
                    }
                    @if (ViewBag.CurrentSort == "price_asc")
                    {
                        <option value="price_asc" selected>Giá: Thấp đến Cao</option>
                    }
                    else
                    {
                        <option value="price_asc">Giá: Thấp đến Cao</option>
                    }
                    @if (ViewBag.CurrentSort == "price_desc")
                    {
                        <option value="price_desc" selected>Giá: Cao xuống Thấp</option>
                    }
                    else
                    {
                        <option value="price_desc">Giá: Cao xuống Thấp</option>
                    }
                </select>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="bg-white py-16 px-6 rounded-3xl border border-slate-200 text-center shadow-sm">
                <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-4">
                    <span class="material-symbols-outlined text-4xl text-slate-400">directions_car_off</span>
                </div>
                <h3 class="text-xl font-bold text-slate-800">Không tìm thấy mẫu xe phù hợp</h3>
                <p class="text-slate-500 mt-2 text-sm max-w-md mx-auto">Thử mở rộng mức giá hoặc chọn lại số chỗ ngồi để xem thêm nhiều lựa chọn hấp dẫn khác.</p>
                <a href="/Vehicle/CustomerList" class="inline-block mt-6 px-6 py-2.5 bg-blue-50 text-[#00236f] font-bold rounded-xl hover:bg-blue-100 transition-colors text-sm">
                    Xóa toàn bộ bộ lọc
                </a>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-6 mb-12">
                @foreach (var car in Model)
                {
                    <div class="bg-white rounded-2xl overflow-hidden border border-slate-100 hover:shadow-[0_8px_30px_rgb(0,0,0,0.08)] hover:border-slate-200 transition-all duration-300 flex flex-col h-full group">
                        <div class="relative aspect-[16/10] overflow-hidden bg-slate-100">
                            <img alt="@car.VehicleName" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" src="@(car.HinhAnh ?? "https://images.unsplash.com/photo-1550355291-bbee04a92027")" />
                            <div class="absolute top-3 left-3">
                                <span class="bg-white/95 backdrop-blur-sm text-[#00236f] text-[10px] font-black px-3 py-1.5 rounded-lg uppercase tracking-wider shadow-sm">
                                    Sẵn sàng
                                </span>
                            </div>
                        </div>
                        <div class="p-5 flex-1 flex flex-col">
                            <h3 class="text-lg font-extrabold text-slate-800 truncate mb-4" title="@car.VehicleName">@car.VehicleName</h3>

                            <div class="flex items-center gap-3 text-slate-500 mb-6 flex-nowrap overflow-hidden">
                                <div class="flex items-center gap-1.5 bg-slate-50 px-2 py-1 rounded-md">
                                    <span class="material-symbols-outlined text-[16px]">event_seat</span>
                                    <span class="text-xs font-semibold">@car.Seats</span>
                                </div>
                                <div class="flex items-center gap-1.5 bg-slate-50 px-2 py-1 rounded-md">
                                    <span class="material-symbols-outlined text-[16px]">local_gas_station</span>
                                    <span class="text-xs font-semibold">@(car.FuelType ?? "Xăng")</span>
                                </div>
                                <div class="flex items-center gap-1.5 bg-slate-50 px-2 py-1 rounded-md">
                                    <span class="material-symbols-outlined text-[16px]">settings</span>
                                    <span class="text-xs font-semibold">@(car.Transmission ?? "TĐ")</span>
                                </div>
                            </div>

                            <div class="mt-auto">
                                <div class="flex items-end justify-between mb-5 border-t border-slate-50 pt-4">
                                    <span class="text-xs font-bold text-slate-400 uppercase tracking-widest">Giá / Ngày</span>
                                    <div class="text-[#00236f] font-black leading-none">
                                        <span class="text-xl">@car.PricePerDay.ToString("N0")</span><span class="text-sm">đ</span>
                                    </div>
                                </div>
                                <div class="grid grid-cols-2 gap-2.5">
                                    <a href="/Vehicle/CustomerDetails/@car.VehicleId" class="border-2 border-slate-100 text-slate-600 text-center px-3 py-2.5 rounded-xl font-bold text-sm hover:border-[#00236f] hover:text-[#00236f] transition-all">
                                        Chi tiết
                                    </a>
                                    <a href="/Booking/Create?vehicleId=@car.VehicleId" class="bg-[#00236f] text-center text-white px-3 py-2.5 rounded-xl font-bold text-sm hover:bg-blue-800 transition-all shadow-md shadow-blue-900/20">
                                        Đặt ngay
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (totalPages > 1)
            {
                <div class="mt-auto flex justify-center gap-2">
                    <button type="button" onclick="changePage(@(currentPage - 1))" class="w-10 h-10 flex items-center justify-center rounded-xl border border-slate-200 text-slate-400 hover:border-[#00236f] hover:text-[#00236f] transition-all disabled:opacity-30 disabled:cursor-not-allowed" @(currentPage == 1 ? "disabled" : "")>
                        <span class="material-symbols-outlined">chevron_left</span>
                    </button>

                    @for (int i = 1; i <= totalPages; i++)
                    {
                        if (i == currentPage)
                        {
                            <button type="button" class="w-10 h-10 flex items-center justify-center rounded-xl bg-[#00236f] text-white font-bold shadow-md shadow-blue-900/20">
                                @i
                            </button>
                        }
                        else
                        {
                            <button type="button" onclick="changePage(@i)" class="w-10 h-10 flex items-center justify-center rounded-xl border border-slate-200 text-slate-600 hover:border-[#00236f] hover:text-[#00236f] font-bold transition-all">
                                @i
                            </button>
                        }
                    }

                    <button type="button" onclick="changePage(@(currentPage + 1))" class="w-10 h-10 flex items-center justify-center rounded-xl border border-slate-200 text-slate-400 hover:border-[#00236f] hover:text-[#00236f] transition-all disabled:opacity-30 disabled:cursor-not-allowed" @(currentPage == totalPages ? "disabled" : "")>
                        <span class="material-symbols-outlined">chevron_right</span>
                    </button>
                </div>
            }
        }
    </div>
</main>

@section Scripts {
    <script>
        // Script giúp Submit Form khi bấm phân trang
        function changePage(page) {
            document.getElementById('pageInput').value = page;
            document.getElementById('filterForm').submit();
        }
    </script>
}