@model IEnumerable<CarRentalSystem.Models.Vehicle>
@using CarRentalSystem.Constants
@using CarRentalSystem.Helpers
@inject IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "Quản lý Đội xe";

    // Lấy Role từ Session
    var role = HttpContextAccessor.HttpContext?.Session.GetString("RoleName");

    // Chọn Layout dựa trên Role
    Layout = role == RoleConstants.Admin ? "_AdminLayout" : "_StaffLayout";

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<div class="space-y-8 mt-4">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
            <h1 class="text-2xl font-bold text-primary mb-1">Quản lý đội xe</h1>
            <p class="text-sm text-slate-500 font-medium">Giám sát và quản lý tình trạng phương tiện trong hệ thống</p>
        </div>
        <a href="/Vehicle/Create" class="px-6 py-2.5 bg-secondary text-white font-semibold rounded-xl shadow-lg shadow-blue-500/30 hover:bg-blue-700 transition-all active:scale-95 flex items-center gap-2 text-sm">
            <span class="material-symbols-outlined text-[20px]">add</span>
            Thêm xe mới
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm flex items-center justify-between hover:shadow-md transition-shadow">
            <div>
                <p class="text-slate-500 text-[11px] font-bold uppercase tracking-wider mb-1">Tổng số xe</p>
                <span class="text-3xl font-black text-primary">@ViewBag.TotalVehicles</span>
            </div>
            <div class="w-12 h-12 rounded-xl bg-slate-50 flex items-center justify-center text-slate-500 border border-slate-100">
                <span class="material-symbols-outlined text-2xl">directions_car</span>
            </div>
        </div>

        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm flex items-center justify-between hover:shadow-md transition-shadow">
            <div>
                <p class="text-slate-500 text-[11px] font-bold uppercase tracking-wider mb-1">Xe sẵn sàng</p>
                <span class="text-3xl font-black text-emerald-600">@ViewBag.AvailableVehicles</span>
            </div>
            <div class="w-12 h-12 rounded-xl bg-emerald-50 flex items-center justify-center text-emerald-600 border border-emerald-100">
                <span class="material-symbols-outlined text-2xl">check_circle</span>
            </div>
        </div>

        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm flex items-center justify-between hover:shadow-md transition-shadow">
            <div>
                <p class="text-slate-500 text-[11px] font-bold uppercase tracking-wider mb-1">Đang cho thuê</p>
                <span class="text-3xl font-black text-blue-600">@ViewBag.RentedVehicles</span>
            </div>
            <div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center text-blue-600 border border-blue-100">
                <span class="material-symbols-outlined text-2xl">key</span>
            </div>
        </div>

        <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm flex items-center justify-between hover:shadow-md transition-shadow">
            <div>
                <p class="text-slate-500 text-[11px] font-bold uppercase tracking-wider mb-1">Bảo dưỡng</p>
                <span class="text-3xl font-black text-amber-600">@ViewBag.MaintenanceVehicles</span>
            </div>
            <div class="w-12 h-12 rounded-xl bg-amber-50 flex items-center justify-center text-amber-600 border border-amber-100">
                <span class="material-symbols-outlined text-2xl">build</span>
            </div>
        </div>
    </div>

    <form method="get" action="/Vehicle/Index" class="bg-white p-4 rounded-2xl border border-slate-200 shadow-sm flex flex-col md:flex-row gap-4">
        <div class="relative flex-1">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">search</span>
            <input type="text" name="search" value="@ViewBag.SearchString" placeholder="Tìm kiếm theo tên xe, biển số..." class="w-full pl-12 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-secondary/20 focus:border-secondary outline-none transition-all text-sm font-medium text-slate-700" />
        </div>
        <button type="submit" class="px-8 py-3 bg-primary text-white font-bold text-sm rounded-xl hover:bg-slate-800 transition-all shadow-md active:scale-95">
            Tìm kiếm
        </button>
    </form>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        @foreach (var item in Model)
        {
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden flex flex-col group hover:shadow-lg transition-all duration-300">
                <div class="h-52 overflow-hidden relative bg-slate-100">
                    <img src="@(item.HinhAnh ?? "https://images.unsplash.com/photo-1550355291-bbee04a92027")" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" alt="@item.VehicleName" />
                    <div class="absolute top-4 right-4">
                        @if (item.Status == VehicleStatus.Available)
                        {
                            <span class="bg-emerald-100 text-emerald-700 px-3 py-1 rounded-full text-[11px] font-bold border border-emerald-200 shadow-sm">Sẵn sàng</span>
                        }
                        else if (item.Status == VehicleStatus.Rented)
                        {
                            <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-[11px] font-bold border border-blue-200 shadow-sm">Đang thuê</span>
                        }
                        else if (item.Status == VehicleStatus.Maintenance)
                        {
                            <span class="bg-amber-100 text-amber-700 px-3 py-1 rounded-full text-[11px] font-bold border border-amber-200 shadow-sm">Bảo dưỡng</span>
                        }
                        else
                        {
                            <span class="bg-rose-100 text-rose-700 px-3 py-1 rounded-full text-[11px] font-bold border border-rose-200 shadow-sm">Ngừng HĐ</span>
                        }
                    </div>
                </div>
                <div class="p-6 flex-grow flex flex-col justify-between">
                    <div>
                        <div class="flex justify-between items-start mb-2">
                            <h3 class="font-bold text-lg text-slate-800 truncate pr-2" title="@item.VehicleName">@item.VehicleName</h3>
                            <span class="text-[11px] bg-slate-50 border border-slate-200 px-2 py-1 rounded-md font-bold text-slate-600 whitespace-nowrap">@item.LicensePlate</span>
                        </div>
                        <p class="text-xs text-slate-500 font-medium mb-6">@item.Category?.CategoryName</p>
                        <div class="flex justify-between items-center pt-4 border-t border-slate-100">
                            <span class="text-xs text-slate-400 font-bold uppercase tracking-wider">Giá thuê / ngày</span>
                            <span class="text-xl font-black text-secondary tracking-tight">@CurrencyHelper.FormatVnd(item.PricePerDay)</span>
                        </div>
                    </div>
                </div>
                <div class="p-5 pt-0 grid grid-cols-2 gap-3 border-t border-slate-50 mt-2">
                    <a href="/Vehicle/Edit/@item.VehicleId" class="py-2.5 bg-white border-2 border-slate-100 text-slate-600 font-bold text-xs rounded-xl hover:border-primary hover:text-primary hover:bg-blue-50/50 transition-all flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-[18px]">edit</span> Chỉnh sửa
                    </a>
                    <a href="/Maintenance/Index?vehicleId=@item.VehicleId" class="py-2.5 bg-slate-50 border border-slate-100 text-primary font-bold text-xs rounded-xl hover:bg-blue-50 transition-all flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-[18px]">build</span> Bảo dưỡng
                    </a>
                </div>
            </div>
        }
    </div>

    @if (totalPages > 1)
    {
        <div class="flex justify-center mt-10">
            <div class="flex items-center gap-2">
                <a href="/Vehicle/Index?page=@(currentPage - 1)&search=@ViewBag.SearchString" class="w-10 h-10 flex items-center justify-center rounded-xl border border-slate-200 text-slate-400 hover:border-primary hover:text-primary transition-all @(currentPage == 1 ? "pointer-events-none opacity-50" : "")">
                    <span class="material-symbols-outlined">chevron_left</span>
                </a>

                @for (int i = 1; i <= totalPages; i++)
                {
                    if (i == currentPage)
                    {
                        <span class="w-10 h-10 flex items-center justify-center rounded-xl bg-primary text-white font-bold shadow-md shadow-blue-900/20">@i</span>
                    }
                    else
                    {
                        <a href="/Vehicle/Index?page=@i&search=@ViewBag.SearchString" class="w-10 h-10 flex items-center justify-center rounded-xl border border-slate-200 text-slate-600 font-bold hover:border-primary hover:text-primary transition-all">@i</a>
                    }
                }

                <a href="/Vehicle/Index?page=@(currentPage + 1)&search=@ViewBag.SearchString" class="w-10 h-10 flex items-center justify-center rounded-xl border border-slate-200 text-slate-400 hover:border-primary hover:text-primary transition-all @(currentPage == totalPages ? "pointer-events-none opacity-50" : "")">
                    <span class="material-symbols-outlined">chevron_right</span>
                </a>
            </div>
        </div>
    }

</div>
