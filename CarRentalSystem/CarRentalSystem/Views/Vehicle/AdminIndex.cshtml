@model IEnumerable<CarRentalSystem.Models.Vehicle>
@{
    ViewData["Title"] = "Quản lý Danh mục Xe";
    Layout = "_AdminLayout";
}

@section Styles {
    <style>
        .car-card-shadow {
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.05);
        }
    </style>
}

<div class="flex flex-col h-full">
    <header class="pt-8 pb-6 flex items-center justify-between">
        <h2 class="text-2xl font-extrabold text-[#1E293B]">
            Quản lý Danh mục Xe
        </h2>
    </header>

    <div class="flex flex-wrap items-center justify-between gap-4 mb-8">
        <div class="flex items-center gap-3 flex-1">
            <div class="relative flex-1 max-w-md">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xl">search</span>
                <input class="w-full pl-10 pr-4 py-2.5 bg-white border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all outline-none" placeholder="Tìm kiếm theo biển số, tên xe..." type="text" />
            </div>
            <select class="bg-white border border-slate-200 rounded-xl text-sm py-2.5 px-4 focus:ring-2 focus:ring-blue-500/20 cursor-pointer min-w-[140px] outline-none">
                <option>Tất cả Loại xe</option>
                <option>Sedan</option>
                <option>SUV</option>
            </select>
            <select class="bg-white border border-slate-200 rounded-xl text-sm py-2.5 px-4 focus:ring-2 focus:ring-blue-500/20 cursor-pointer min-w-[140px] outline-none">
                <option>Tất cả Trạng thái</option>
                <option>Sẵn sàng</option>
                <option>Đang thuê</option>
                <option>Bảo dưỡng</option>
            </select>
        </div>
        <a href="/Vehicle/Create" class="bg-[#316bf3] text-white px-6 py-2.5 rounded-xl font-bold flex items-center gap-2 hover:bg-blue-700 transition-all shadow-md">
            <span class="material-symbols-outlined text-[20px]">add</span>
            Thêm xe mới
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
        @foreach (var item in Model)
        {
            <div class="bg-white rounded-2xl overflow-hidden car-card-shadow border border-slate-200/60 group transition-all hover:-translate-y-1">
                <div class="relative h-56 overflow-hidden bg-slate-100">
                    <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                         src="@item.HinhAnh"
                         onerror="this.src='https://images.unsplash.com/photo-1550355291-bbee04a92027'"
                         alt="@item.VehicleName" />

                    <div class="absolute top-4 right-4">
                        @if (item.Status == "San sang" || item.Status == "Sẵn sàng")
                        {
                            <span class="bg-emerald-500 text-white px-3 py-1 rounded-full text-[11px] font-bold shadow-lg">Sẵn sàng</span>
                        }
                        else if (item.Status == "Dang thue" || item.Status == "Đang thuê")
                        {
                            <span class="bg-blue-500 text-white px-3 py-1 rounded-full text-[11px] font-bold shadow-lg">Đang thuê</span>
                        }
                        else if (item.Status == "Bao duong" || item.Status == "Bảo dưỡng")
                        {
                            <span class="bg-orange-500 text-white px-3 py-1 rounded-full text-[11px] font-bold shadow-lg">Bảo dưỡng</span>
                        }
                        else
                        {
                            <span class="bg-slate-500 text-white px-3 py-1 rounded-full text-[11px] font-bold shadow-lg">@item.Status</span>
                        }
                    </div>
                </div>
                <div class="p-6">
                    <div class="flex justify-between items-start mb-2">
                        <h3 class="text-lg font-bold text-[#1E293B] truncate pr-2" title="@item.VehicleName">@item.VehicleName</h3>
                        <span class="bg-slate-100 text-slate-600 px-2 py-0.5 rounded text-[11px] font-bold border border-slate-200 shrink-0">@item.LicensePlate</span>
                    </div>
                    <p class="text-[#316bf3] font-extrabold text-xl mb-6">@item.PricePerDay.ToString("N0")đ<span class="text-sm font-medium text-slate-400">/ngày</span></p>

                    <div class="flex items-center justify-between pt-4 border-t border-slate-50">
                        <div class="flex gap-4 text-slate-500 text-[13px] font-medium">
                            <span class="flex items-center gap-1">
                                <span class="material-symbols-outlined text-[18px]">event_seat</span>
                                @item.Seats chỗ
                            </span>
                            <span class="flex items-center gap-1">
                                <span class="material-symbols-outlined text-[18px]">settings</span>
                                @(item.Transmission ?? "Tự động")
                            </span>
                        </div>
                        <div class="flex gap-2">
                            <a href="/Vehicle/Edit/@item.VehicleId" class="w-8 h-8 flex items-center justify-center rounded-lg bg-slate-50 text-slate-400 hover:text-[#316bf3] hover:bg-blue-50 transition-all" title="Chỉnh sửa">
                                <span class="material-symbols-outlined text-[18px]">edit_square</span>
                            </a>
                            <a href="/Vehicle/Details/@item.VehicleId" class="w-8 h-8 flex items-center justify-center rounded-lg bg-slate-50 text-slate-400 hover:text-[#1E293B] hover:bg-slate-100 transition-all" title="Chi tiết">
                                <span class="material-symbols-outlined text-[18px]">visibility</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="flex flex-col md:flex-row items-center justify-between py-8 border-t border-slate-200 mt-auto">
        <span class="text-sm text-slate-500 font-medium">Hiển thị danh sách xe</span>
        <div class="flex items-center gap-2 mt-4 md:mt-0">
            <button class="px-4 py-2 bg-white border border-slate-200 rounded-xl text-sm font-medium hover:bg-slate-50 transition-colors">Trước</button>
            <button class="w-10 h-10 flex items-center justify-center bg-[#316bf3] text-white rounded-xl text-sm font-bold shadow-md">1</button>
            <button class="px-4 py-2 bg-white border border-slate-200 rounded-xl text-sm font-medium hover:bg-slate-50 transition-colors">Tiếp</button>
        </div>
    </div>
</div>