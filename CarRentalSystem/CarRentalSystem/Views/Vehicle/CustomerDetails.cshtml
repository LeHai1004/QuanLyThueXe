@model CarRentalSystem.Models.Vehicle
@using CarRentalSystem.Helpers
@{
    ViewData["Title"] = Model.VehicleName + " - Chi tiết xe";
    Layout = "_Layout";
}

<style>
    body {
        background-color: #f8f9ff;
        font-family: 'Inter', sans-serif;
    }

    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }

    .spec-badge {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 1rem 0.75rem;
        background: #f8f9ff;
        border: 1px solid #e5eeff;
        border-radius: 0.75rem;
        gap: 0.375rem;
        transition: all 0.3s ease;
    }

        .spec-badge:hover {
            border-color: #0058be;
            background-color: #f0f5ff;
            transform: translateY(-2px);
        }
</style>

<main class="max-w-[1280px] mx-auto pt-10 pb-24 px-6 md:px-12">

    @* ===== HEADER & BREADCRUMB ===== *@
    <div class="mb-8">
        <div class="flex items-center gap-2 text-sm text-slate-500 font-medium mb-4">
            <a href="/" class="hover:text-[#00236f] transition-colors">Trang chủ</a>
            <span class="material-symbols-outlined text-base">chevron_right</span>
            <a href="/Vehicle/CustomerList" class="hover:text-[#00236f] transition-colors">Đặt xe</a>
            <span class="material-symbols-outlined text-base">chevron_right</span>
            <span class="text-[#00236f] font-semibold">@Model.VehicleName</span>
        </div>

        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div>
                <div class="inline-flex items-center gap-2 mb-2">
                    <span class="w-2 h-2 rounded-full bg-[#316bf3] inline-block"></span>
                    <span class="text-[13px] font-bold text-[#316bf3] tracking-widest uppercase">
                        @(Model.Category?.CategoryName ?? "Xe cao cấp")
                    </span>
                </div>
                <h1 class="text-4xl md:text-5xl font-black leading-tight tracking-tight text-[#0b1c30] mb-4">
                    @Model.VehicleName
                </h1>

                <div class="flex items-center gap-3 flex-wrap">
                    @if (Model.Status == "Sẵn sàng" || Model.Status == "Available")
                    {
                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[12px] font-bold bg-emerald-100 text-emerald-700 border border-emerald-200">
                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 inline-block"></span>
                            Sẵn sàng cho thuê
                        </span>
                    }
                    else
                    {
                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[12px] font-bold bg-slate-100 text-slate-600 border border-slate-200">
                            <span class="w-1.5 h-1.5 rounded-full bg-slate-400 inline-block"></span>
                            @Model.Status
                        </span>
                    }

                    <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-[12px] font-bold bg-slate-100 text-slate-700 border border-slate-200">
                        <span class="material-symbols-outlined text-[14px]">pin</span>
                        @Model.LicensePlate
                    </span>

                    @if (Model.AverageRating > 0)
                    {
                        <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-[12px] font-bold bg-amber-50 text-amber-600 border border-amber-200">
                            <span class="material-symbols-outlined text-[14px]" style="font-variation-settings:'FILL' 1">star</span>
                            @Model.AverageRating.ToString("0.0")
                        </span>
                    }
                </div>
            </div>
        </div>
    </div>

    @* ===== CONTENT GRID ===== *@
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-10 items-start">

        @* ========== CỘT TRÁI: Hình ảnh & Chi tiết ========== *@
        <div class="space-y-10">

            @* Ảnh xe nguyên bản *@
            <div class="w-full aspect-[16/10] rounded-2xl overflow-hidden bg-slate-100 border border-slate-200 shadow-sm relative group">
                <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                     src="@(Model.HinhAnh ?? "https://images.unsplash.com/photo-1550355291-bbee04a92027")"
                     alt="@Model.VehicleName" />
            </div>

            @* Thông số nhanh *@
            <div class="grid grid-cols-3 sm:grid-cols-5 gap-3">
                <div class="spec-badge">
                    <span class="material-symbols-outlined text-[#0058be]">airline_seat_recline_extra</span>
                    <span class="text-[12px] text-[#757682] font-medium">Số chỗ</span>
                    <span class="text-[14px] font-bold text-[#0b1c30]">@Model.Seats chỗ</span>
                </div>
                <div class="spec-badge">
                    <span class="material-symbols-outlined text-[#0058be]">settings</span>
                    <span class="text-[12px] text-[#757682] font-medium">Hộp số</span>
                    <span class="text-[14px] font-bold text-[#0b1c30]">@(Model.Transmission ?? "Tự động")</span>
                </div>
                <div class="spec-badge">
                    <span class="material-symbols-outlined text-[#0058be]">local_gas_station</span>
                    <span class="text-[12px] text-[#757682] font-medium">Nhiên liệu</span>
                    <span class="text-[14px] font-bold text-[#0b1c30]">@(Model.FuelType ?? "Xăng")</span>
                </div>
                @if (!string.IsNullOrEmpty(Model.Color))
                {
                    <div class="spec-badge">
                        <span class="material-symbols-outlined text-[#0058be]">palette</span>
                        <span class="text-[12px] text-[#757682] font-medium">Màu sắc</span>
                        <span class="text-[14px] font-bold text-[#0b1c30]">@Model.Color</span>
                    </div>
                }
                @if (Model.ManufactureYear > 0)
                {
                    <div class="spec-badge">
                        <span class="material-symbols-outlined text-[#0058be]">calendar_today</span>
                        <span class="text-[12px] text-[#757682] font-medium">Năm SX</span>
                        <span class="text-[14px] font-bold text-[#0b1c30]">@Model.ManufactureYear</span>
                    </div>
                }
            </div>

            @* Thông số kỹ thuật *@
            <section class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200">
                <h2 class="text-[20px] font-bold text-[#0b1c30] mb-6 flex items-center gap-2">
                    <span class="material-symbols-outlined text-[#316bf3]">list_alt</span>
                    Thông số kỹ thuật
                </h2>
                <div class="grid grid-cols-2 md:grid-cols-3 gap-y-6 gap-x-4">
                    <div class="flex flex-col border-l-2 border-slate-100 pl-4">
                        <span class="text-[12px] text-[#757682] uppercase tracking-wide mb-1 font-semibold">Hãng xe</span>
                        <span class="text-[14px] font-bold text-[#0b1c30]">@(Model.Brand ?? "—")</span>
                    </div>
                    <div class="flex flex-col border-l-2 border-slate-100 pl-4">
                        <span class="text-[12px] text-[#757682] uppercase tracking-wide mb-1 font-semibold">Số chỗ ngồi</span>
                        <span class="text-[14px] font-bold text-[#0b1c30]">@Model.Seats chỗ</span>
                    </div>
                    <div class="flex flex-col border-l-2 border-slate-100 pl-4">
                        <span class="text-[12px] text-[#757682] uppercase tracking-wide mb-1 font-semibold">Hộp số</span>
                        <span class="text-[14px] font-bold text-[#0b1c30]">@(Model.Transmission ?? "Tự động")</span>
                    </div>
                    <div class="flex flex-col border-l-2 border-slate-100 pl-4">
                        <span class="text-[12px] text-[#757682] uppercase tracking-wide mb-1 font-semibold">Nhiên liệu</span>
                        <span class="text-[14px] font-bold text-[#0b1c30]">@(Model.FuelType ?? "Xăng")</span>
                    </div>
                    <div class="flex flex-col border-l-2 border-slate-100 pl-4">
                        <span class="text-[12px] text-[#757682] uppercase tracking-wide mb-1 font-semibold">Màu sắc</span>
                        <span class="text-[14px] font-bold text-[#0b1c30]">@(Model.Color ?? "—")</span>
                    </div>
                    <div class="flex flex-col border-l-2 border-slate-100 pl-4">
                        <span class="text-[12px] text-[#757682] uppercase tracking-wide mb-1 font-semibold">Loại xe</span>
                        <span class="text-[14px] font-bold text-[#0b1c30]">@(Model.Category?.CategoryName ?? "—")</span>
                    </div>
                </div>
            </section>

            @* Đánh giá *@
            @if (Model.AverageRating > 0)
            {
                <section class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200 flex items-center justify-between">
                    <div>
                        <h2 class="text-[20px] font-bold text-[#0b1c30] mb-1">Đánh giá từ khách hàng</h2>
                        <p class="text-[14px] text-[#757682]">Dựa trên các chuyến đi đã hoàn thành</p>
                    </div>
                    <div class="flex items-center gap-4 bg-amber-50 px-6 py-4 rounded-xl border border-amber-100">
                        <div class="text-[36px] font-black text-amber-600 leading-none">@Model.AverageRating.ToString("0.0")</div>
                        <div class="flex items-center gap-1">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <span class="material-symbols-outlined text-amber-500 text-xl"
                                      style="font-variation-settings:'FILL' @(i <= Math.Round((double)Model.AverageRating) ? "1" : "0")">star</span>
                            }
                        </div>
                    </div>
                </section>
            }
        </div>

        @* ========== CỘT PHẢI: Booking Card (STICKY) ========== *@
        <div class="relative">
            <div class="sticky top-28 space-y-6">

                @* Card đặt xe tinh gọn *@
                <div class="bg-white p-8 rounded-2xl shadow-lg border border-slate-200">

                    @* Giá / ngày *@
                    <div class="text-center mb-8 pb-6 border-b border-slate-100">
                        <span class="text-[#757682] text-[14px] font-bold uppercase tracking-wider block mb-2">Giá thuê cơ bản</span>
                        <div class="flex items-center justify-center gap-1 text-[#00236f]">
                            <span class="text-[36px] font-black leading-none">@CurrencyHelper.FormatVnd(Model.PricePerDay)</span>
                            <span class="text-[14px] font-bold text-[#757682] mt-2">/ngày</span>
                        </div>
                    </div>

                    @* Nút đặt xe *@
                    <a href="/Booking/Create?vehicleId=@Model.VehicleId"
                       class="w-full py-4 bg-[#00236f] text-white font-bold text-[16px] rounded-xl
                        hover:bg-[#1e3a8a] transition-all shadow-xl shadow-[#00236f]/20
                        active:scale-95 flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">directions_car</span>
                        Tiến hành đặt xe ngay
                    </a>

                    <p class="text-center text-xs text-slate-400 mt-4 font-medium">Bạn sẽ không bị trừ tiền cho đến khi xác nhận đơn.</p>
                </div>

                @* Cam kết dịch vụ xếp dọc *@
                <div class="bg-slate-50 p-6 rounded-2xl border border-slate-200 space-y-5">
                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center shrink-0">
                            <span class="material-symbols-outlined text-[#0058be] text-[20px]" style="font-variation-settings:'FILL' 1">verified_user</span>
                        </div>
                        <div>
                            <p class="text-[14px] font-bold text-[#0b1c30]">Bảo hiểm 100% chuyến đi</p>
                            <p class="text-[12px] text-[#757682] mt-1 leading-relaxed">Gói bảo hiểm tiêu chuẩn được bao gồm trong giá thuê xe.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 rounded-full bg-emerald-100 flex items-center justify-center shrink-0">
                            <span class="material-symbols-outlined text-emerald-600 text-[20px]" style="font-variation-settings:'FILL' 1">check_circle</span>
                        </div>
                        <div>
                            <p class="text-[14px] font-bold text-[#0b1c30]">Hủy chuyến miễn phí</p>
                            <p class="text-[12px] text-[#757682] mt-1 leading-relaxed">Không thu phụ phí nếu hủy trước 48 giờ kể từ lúc nhận xe.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 rounded-full bg-amber-100 flex items-center justify-center shrink-0">
                            <span class="material-symbols-outlined text-amber-600 text-[20px]" style="font-variation-settings:'FILL' 1">support_agent</span>
                        </div>
                        <div>
                            <p class="text-[14px] font-bold text-[#0b1c30]">Hỗ trợ kỹ thuật 24/7</p>
                            <p class="text-[12px] text-[#757682] mt-1 leading-relaxed">Đội ngũ CSKH và cứu hộ luôn túc trực mọi lúc mọi nơi.</p>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</main>