@model IEnumerable<CarRentalSystem.Models.Vehicle>
@{
    ViewData["Title"] = "Quản lý Đội xe";
    Layout = "_StaffLayout";
}

<div class="space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="bg-white p-6 rounded-xl border border-outline-variant/30 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-on-surface-variant text-label-md font-medium uppercase tracking-wider mb-1">Tổng số xe</p>
                <span class="text-3xl font-bold text-primary">@ViewBag.TotalVehicles</span>
            </div>
            <div class="w-12 h-12 rounded-xl bg-slate-50 flex items-center justify-center text-slate-600">
                <span class="material-symbols-outlined text-2xl">directions_car</span>
            </div>
        </div>

        <div class="bg-white p-6 rounded-xl border border-outline-variant/30 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-on-surface-variant text-label-md font-medium uppercase tracking-wider mb-1">Xe sẵn sàng</p>
                <span class="text-3xl font-bold text-emerald-600">@ViewBag.AvailableVehicles</span>
            </div>
            <div class="w-12 h-12 rounded-xl bg-emerald-50 flex items-center justify-center text-emerald-600">
                <span class="material-symbols-outlined text-2xl">check_circle</span>
            </div>
        </div>

        <div class="bg-white p-6 rounded-xl border border-outline-variant/30 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-on-surface-variant text-label-md font-medium uppercase tracking-wider mb-1">Xe đang thuê</p>
                <span class="text-3xl font-bold text-blue-600">@ViewBag.RentedVehicles</span>
            </div>
            <div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center text-blue-600">
                <span class="material-symbols-outlined text-2xl">sync_alt</span>
            </div>
        </div>

        <div class="bg-white p-6 rounded-xl border border-outline-variant/30 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-on-surface-variant text-label-md font-medium uppercase tracking-wider mb-1">Đang bảo trì</p>
                <span class="text-3xl font-bold text-amber-600">@ViewBag.MaintenanceVehicles</span>
            </div>
            <div class="w-12 h-12 rounded-xl bg-amber-50 flex items-center justify-center text-amber-600">
                <span class="material-symbols-outlined text-2xl">build</span>
            </div>
        </div>
    </div>

    <div class="bg-white p-4 rounded-xl shadow-sm border border-outline-variant/30 flex flex-wrap gap-4 items-center">
        <div class="flex-1 min-w-[240px] relative">
            <span class="material-symbols-outlined absolute left-3 top-2.5 text-outline text-[20px]">search</span>
            <input type="text" placeholder="Tìm kiếm xe theo tên, biển số..." class="w-full bg-surface-container-low border-none rounded-lg pl-10 pr-4 py-2 text-[14px] focus:ring-1 focus:ring-primary outline-none" />
        </div>
        <div class="flex items-center gap-3">
            <select class="bg-surface-container-low border-none rounded-lg px-4 py-2 text-[14px] focus:ring-1 focus:ring-primary min-w-[160px]">
                <option>Tất cả trạng thái</option>
                <option>Sẵn sàng</option>
                <option>Đang thuê</option>
                <option>Bảo dưỡng</option>
            </select>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        @foreach (var item in Model)
        {
            <div class="bg-white rounded-xl overflow-hidden border border-outline-variant/30 shadow-sm hover:shadow-md transition-shadow flex flex-col justify-between">
                <div>
                    <div class="h-48 relative">
                        <img src="@(item.HinhAnh ?? "https://images.unsplash.com/photo-1550355291-bbee04a92027?auto=format&fit=crop&w=600&q=80")" class="w-full h-full object-cover" alt="@item.VehicleName" />
                        <div class="absolute top-3 left-3">
                            @if (item.Status == "San sang" || item.Status == "Sẵn sàng")
                            {
                                <span class="px-3 py-1.5 rounded-full bg-emerald-100 text-emerald-800 text-xs font-bold shadow-md">Sẵn sàng</span>
                            }
                            else if (item.Status == "Dang thue" || item.Status == "Đang thuê")
                            {
                                <span class="px-3 py-1.5 rounded-full bg-blue-100 text-blue-800 text-xs font-bold shadow-md">Đang thuê</span>
                            }
                            else
                            {
                                <span class="px-3 py-1.5 rounded-full bg-amber-100 text-amber-800 text-xs font-bold shadow-md">Bảo dưỡng</span>
                            }
                        </div>
                    </div>
                    <div class="p-6">
                        <div class="flex justify-between items-start mb-2">
                            <h3 class="text-lg font-bold text-primary">@item.VehicleName</h3>
                            <span class="text-xs bg-slate-100 px-2 py-1 rounded font-semibold text-slate-600">@item.LicensePlate</span>
                        </div>
                        <p class="text-xs text-on-surface-variant font-medium mb-4">Loại xe: @(item.Category?.CategoryName ?? "Chưa phân loại")</p>
                        <div class="flex justify-between items-center pt-4 border-t border-slate-100">
                            <span class="text-xs text-outline font-medium">Giá thuê ngày</span>
                            <span class="text-base font-bold text-secondary">@item.PricePerDay.ToString("N0")đ</span>
                        </div>
                    </div>
                </div>
                <div class="p-6 pt-0 grid grid-cols-2 gap-3">
                    <button class="py-2 border border-outline-variant/50 text-primary font-semibold text-xs rounded-lg hover:bg-slate-50 transition-colors flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-base">edit</span> Trạng thái
                    </button>
                    <button class="py-2 bg-surface-container-low text-primary font-semibold text-xs rounded-lg hover:bg-surface-container transition-colors flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-base">history</span> Bảo dưỡng
                    </button>
                </div>
            </div>
        }
    </div>
</div>