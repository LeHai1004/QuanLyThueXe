@model IEnumerable<CarRentalSystem.Models.Supplier>
@{
    ViewData["Title"] = "Quản lý Nhà cung cấp";
    Layout = "_AdminLayout";
}

<div class="space-y-8 mt-4">
    <section class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div class="space-y-1">
            <h1 class="font-h1 text-2xl font-bold text-primary">
                Quản lý Đối tác / Nhà cung cấp
            </h1>
            <p class="text-on-surface-variant font-body-md text-sm">
                Danh sách các đối tác cung cấp xe và linh kiện chính thức.
            </p>
        </div>
        <div class="flex flex-wrap items-center gap-4">
            <form method="get" action="/Supplier/Index" class="flex gap-2 items-center">
                <div class="relative group">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-blue-600 transition-colors text-lg">search</span>
                    <input name="search" value="@ViewBag.SearchString" class="pl-10 pr-4 py-2 w-72 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-600/20 focus:border-blue-600 font-body-md text-sm outline-none transition-all shadow-sm" placeholder="Tìm tên NCC, MST..." type="text" />
                </div>
                <button type="submit" class="px-5 py-2 bg-slate-800 text-white rounded-lg font-bold text-sm hover:bg-slate-900 transition-all shadow-md">Lọc</button>
                @if (!string.IsNullOrEmpty(ViewBag.SearchString))
                {
                    <a href="/Supplier/Index" class="px-3 py-2 text-slate-500 hover:text-slate-800 font-bold text-sm transition-colors">Xóa</a>
                }
            </form>
            <a href="/Supplier/Create" class="flex items-center gap-1.5 px-4 py-2 bg-secondary text-white text-sm font-bold rounded-lg hover:bg-blue-700 shadow-md shadow-blue-500/20 active:scale-95 transition-all">
                <span class="material-symbols-outlined text-[18px]">add</span>
                Thêm mới
            </a>
        </div>
    </section>

    <section class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="bg-white p-5 rounded-xl shadow-sm border border-slate-200">
            <div class="flex items-center justify-between mb-2">
                <span class="text-slate-500 text-xs font-bold uppercase tracking-wider">Tổng nhà cung cấp</span>
                <div class="p-2 bg-blue-50 text-blue-700 rounded-lg">
                    <span class="material-symbols-outlined text-xl">inventory</span>
                </div>
            </div>
            <div class="flex items-end gap-2">
                <span class="text-3xl font-black text-slate-800">@ViewBag.TotalSuppliers</span>
                <span class="text-emerald-600 text-[11px] font-bold pb-1">Hệ thống</span>
            </div>
        </div>
        <div class="bg-white p-5 rounded-xl shadow-sm border border-slate-200">
            <div class="flex items-center justify-between mb-2">
                <span class="text-slate-500 text-xs font-bold uppercase tracking-wider">Đang hợp tác</span>
                <div class="p-2 bg-emerald-50 text-emerald-600 rounded-lg">
                    <span class="material-symbols-outlined text-xl">handshake</span>
                </div>
            </div>
            <div class="flex items-end gap-2">
                <span class="text-3xl font-black text-slate-800">@ViewBag.ActiveSuppliers</span>
                <span class="text-slate-500 text-[11px] font-bold pb-1">Đối tác tích cực</span>
            </div>
        </div>
        <div class="bg-white p-5 rounded-xl shadow-sm border border-slate-200">
            <div class="flex items-center justify-between mb-2">
                <span class="text-slate-500 text-xs font-bold uppercase tracking-wider">Tạm dừng</span>
                <div class="p-2 bg-rose-50 text-rose-600 rounded-lg">
                    <span class="material-symbols-outlined text-xl">block</span>
                </div>
            </div>
            <div class="flex items-end gap-2">
                <span class="text-3xl font-black text-slate-800">@ViewBag.InactiveSuppliers</span>
                <span class="text-slate-500 text-[11px] font-bold pb-1">Cần xem xét</span>
            </div>
        </div>
        <div class="bg-white p-5 rounded-xl shadow-sm border border-slate-200">
            <div class="flex items-center justify-between mb-2">
                <span class="text-slate-500 text-xs font-bold uppercase tracking-wider">Lượt nhập kho</span>
                <div class="p-2 bg-blue-50 text-secondary rounded-lg">
                    <span class="material-symbols-outlined text-xl">local_shipping</span>
                </div>
            </div>
            <div class="flex items-end gap-2">
                <span class="text-3xl font-black text-slate-800">@ViewBag.MonthlyImports</span>
                <span class="text-slate-500 text-[11px] font-bold pb-1">Trong tháng @DateTime.Now.Month</span>
            </div>
        </div>
    </section>

    <section class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead class="bg-slate-50 text-slate-500 text-[11px] font-bold uppercase tracking-wider">
                    <tr>
                        <th class="px-6 py-5 border-b border-slate-100">Mã NCC</th>
                        <th class="px-6 py-5 border-b border-slate-100">Tên Nhà cung cấp</th>
                        <th class="px-6 py-5 border-b border-slate-100">Mã số thuế</th>
                        <th class="px-6 py-5 border-b border-slate-100">Liên hệ</th>
                        <th class="px-6 py-5 border-b border-slate-100">Người đại diện</th>
                        <th class="px-6 py-5 border-b border-slate-100">Trạng thái</th>
                        <th class="px-6 py-5 border-b border-slate-100 text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-sm">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-slate-50/50 transition-colors group">
                            <td class="px-6 py-4 text-[#316bf3] font-bold font-mono">
                                NCC-@item.SupplierId.ToString("D3")
                            </td>
                            <td class="px-6 py-4 font-bold text-slate-800">
                                @item.SupplierName
                            </td>
                            <td class="px-6 py-4 font-mono text-slate-600">
                                @(item.TaxCode ?? "N/A")
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex flex-col">
                                    <span class="font-semibold text-slate-700">@(item.PhoneNumber ?? "N/A")</span>
                                    <span class="text-[12px] text-slate-500">@(item.Email ?? "N/A")</span>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-slate-700">
                                @(item.ContactPerson ?? "N/A")
                            </td>
                            <td class="px-6 py-4">
                                @if (item.IsActive)
                                {
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-emerald-50 text-emerald-700 font-bold text-[11px] border border-emerald-200 whitespace-nowrap">
                                        Đang hợp tác
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-slate-100 text-slate-600 font-bold text-[11px] border border-slate-200 whitespace-nowrap">
                                        Ngừng giao dịch
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center justify-center gap-2">
                                    <a href="/Supplier/Edit/@item.SupplierId" class="p-1.5 text-blue-600 hover:bg-blue-50 rounded-lg transition-colors" title="Chỉnh sửa">
                                        <span class="material-symbols-outlined text-[20px]">edit</span>
                                    </a>
                                    <button type="button" onclick="openDeleteModal('@item.SupplierId')" class="p-1.5 text-rose-500 hover:bg-rose-50 rounded-lg transition-colors" title="Xóa">
                                        <span class="material-symbols-outlined text-[20px]">delete</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="px-6 py-4 flex items-center justify-between bg-white border-t border-slate-100">
            <span class="text-sm font-medium text-slate-500">Danh sách dữ liệu trực tiếp</span>
            <div class="flex items-center gap-2">
                <button class="p-2 border border-slate-200 rounded-lg text-slate-400 cursor-not-allowed transition-all">
                    <span class="material-symbols-outlined">chevron_left</span>
                </button>
                <button class="w-9 h-9 flex items-center justify-center bg-secondary text-white rounded-lg font-bold shadow-md shadow-blue-500/20">
                    1
                </button>
                <button class="p-2 border border-slate-200 text-slate-600 hover:bg-slate-50 rounded-lg transition-all">
                    <span class="material-symbols-outlined">chevron_right</span>
                </button>
            </div>
        </div>
    </section>
</div>

<!-- Delete Modal -->
<div id="deleteModal" class="fixed inset-0 z-[100] hidden bg-slate-900/50 backdrop-blur-sm flex items-center justify-center transition-opacity duration-300">
    <div class="bg-white rounded-xl shadow-xl max-w-md w-full mx-4 p-6 transform transition-all duration-300 scale-95 opacity-0" id="deleteModalContent">
        <div class="flex items-start gap-4 mb-5">
            <div class="p-3 bg-rose-100 text-rose-600 rounded-full flex-shrink-0">
                <span class="material-symbols-outlined text-2xl">warning</span>
            </div>
            <div>
                <h3 class="text-lg font-bold text-slate-800 mb-1">Xác nhận ngừng hợp tác</h3>
                <p class="text-sm text-slate-500 leading-relaxed">Bạn có chắc chắn muốn ngừng hợp tác với nhà cung cấp này không? Hành động này không thể hoàn tác.</p>
            </div>
        </div>
        <div class="flex justify-end gap-3 mt-6">
            <button type="button" onclick="closeDeleteModal()" class="px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold text-sm rounded-lg transition-colors">
                Hủy
            </button>
            <form id="deleteForm" method="post" class="m-0">
                @Html.AntiForgeryToken()
                <button type="submit" class="px-4 py-2 bg-rose-500 hover:bg-rose-600 text-white font-bold text-sm rounded-lg shadow-md shadow-rose-500/20 transition-colors">
                    Đồng ý
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openDeleteModal(supplierId) {
            const modal = document.getElementById('deleteModal');
            const modalContent = document.getElementById('deleteModalContent');
            const deleteForm = document.getElementById('deleteForm');
            
            // Update form action with specific supplier ID
            deleteForm.action = '/Supplier/Delete/' + supplierId;
            
            // Show modal backdrop
            modal.classList.remove('hidden');
            
            // Small delay to allow display:block to apply before animating opacity/scale
            setTimeout(() => {
                modalContent.classList.remove('scale-95', 'opacity-0');
                modalContent.classList.add('scale-100', 'opacity-100');
            }, 10);
        }

        function closeDeleteModal() {
            const modal = document.getElementById('deleteModal');
            const modalContent = document.getElementById('deleteModalContent');
            
            // Animate out
            modalContent.classList.remove('scale-100', 'opacity-100');
            modalContent.classList.add('scale-95', 'opacity-0');
            
            // Hide after animation finishes
            setTimeout(() => {
                modal.classList.add('hidden');
            }, 300);
        }
    </script>
}