@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Thêm Nhà Cung Cấp Mới";
}

<div class="p-6">
    <div class="mb-6 flex items-center justify-between">
        <div>
            <h2 class="text-2xl font-bold text-slate-800">Thêm Nhà Cung Cấp Mới</h2>
            <p class="text-sm text-slate-500 mt-1">Điền thông tin chi tiết về đối tác cung cấp dịch vụ/sản phẩm</p>
        </div>
        <a href="/Supplier/Index" class="px-4 py-2 text-sm font-semibold text-slate-600 bg-white border border-slate-300 rounded-lg hover:bg-slate-50 transition-colors shadow-sm">
            Quay lại
        </a>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="mb-4 p-4 bg-red-50 border-l-4 border-red-500 text-red-700 rounded-r-lg text-sm">
            @ViewBag.Error
        </div>
    }

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 max-w-3xl mx-auto">
        <form method="post" action="/Supplier/Create">
            @Html.AntiForgeryToken()
            
            <h3 class="text-lg font-bold text-slate-800 mb-4 pb-2 border-b border-slate-100">Thông tin Doanh nghiệp</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                <div class="md:col-span-2">
                    <label class="block text-sm font-bold text-slate-700 mb-1">Tên nhà cung cấp <span class="text-red-500">*</span></label>
                    <input type="text" name="supplierName" required class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-colors" placeholder="VD: Công ty TNHH Dịch vụ Xe Ô tô ABC" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1">Mã số thuế</label>
                    <input type="text" name="taxCode" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-colors" placeholder="VD: 0312345678" />
                </div>
                <div class="md:col-span-2">
                    <label class="block text-sm font-bold text-slate-700 mb-1">Địa chỉ</label>
                    <input type="text" name="address" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-colors" placeholder="VD: 123 Đường ABC, Quận X, TP.HCM" />
                </div>
            </div>

            <h3 class="text-lg font-bold text-slate-800 mb-4 pb-2 border-b border-slate-100">Thông tin Liên hệ</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1">Người liên hệ</label>
                    <input type="text" name="contactPerson" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-colors" placeholder="VD: Nguyễn Văn B" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1">Số điện thoại</label>
                    <input type="text" name="phoneNumber" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-colors" placeholder="VD: 09xxxxxxxx" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1">Email liên hệ</label>
                    <input type="email" name="email" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-colors" placeholder="VD: contact@company.com" />
                </div>
            </div>

            <div class="flex justify-end gap-3 pt-4 border-t border-slate-100">
                <a href="/Supplier/Index" class="px-5 py-2.5 text-sm font-bold text-slate-600 hover:text-slate-800 transition-colors">
                    Hủy bỏ
                </a>
                <button type="submit" class="px-6 py-2.5 bg-blue-600 text-white rounded-lg text-sm font-bold hover:bg-blue-700 shadow-md transition-colors">
                    Lưu Nhà Cung Cấp
                </button>
            </div>
        </form>
    </div>
</div>
