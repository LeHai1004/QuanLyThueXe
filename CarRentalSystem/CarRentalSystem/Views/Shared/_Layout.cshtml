<!DOCTYPE html>
<html lang="vi" class="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Car Rental System</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
        darkMode: "class",
        theme: {
        extend: {
        colors: {
        background: "#f8f9ff",
        surface: "#f8f9ff",
        primary: "#00236f",
        secondary: "#0058be",
        "outline-variant": "#c5c5d3",
        error: "#ba1a1a",
        "on-surface": "#0b1c30",
        "on-surface-variant": "#444651",
        "surface-container": "#e5eeff",
        "surface-container-lowest": "#ffffff"
        },
        fontFamily: {
        sans: ["Inter", "sans-serif"],
        }
        }
        }
        };
    </script>
    <style>
        body {
        font-family: "Inter", sans-serif;
        background-color: #f8f9ff;
        }

        .material-symbols-outlined {
        font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="text-on-surface flex flex-col min-h-screen">
    <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-outline-variant shadow-sm">
        <div class="max-w-[1280px] mx-auto px-4 md:px-12 py-4 flex items-center justify-between">
            <div class="flex items-center gap-2">
                <div class="w-10 h-10 bg-[#00236f] rounded-lg flex items-center justify-center">
                    <span class="material-symbols-outlined text-white">directions_car</span>
                </div>
                <a asp-controller="Home" asp-action="Index" class="text-[18px] font-bold text-[#00236f] tracking-tight uppercase">
                    CAR <span class="text-[#0058be]">RENTAL SYSTEM</span>
                </a>
            </div>
            <nav class="hidden lg:flex items-center space-x-8">
                <a asp-controller="Home" asp-action="Index" class="text-sm font-semibold text-[#00236f] hover:text-[#0058be] transition-colors">Trang chủ</a>
                <a asp-controller="Vehicle" asp-action="CustomerList" class="text-sm font-medium text-on-surface-variant hover:text-[#00236f] transition-colors">Đặt xe</a>
                <a asp-controller="Vehicle" asp-action="CustomerIndex" class="text-sm font-medium text-on-surface-variant hover:text-[#00236f] transition-colors">Dịch vụ</a>
                <a href="#" class="text-sm font-medium text-on-surface-variant hover:text-[#00236f] transition-colors">Về chúng tôi</a>
                <a href="#" class="text-sm font-medium text-on-surface-variant hover:text-[#00236f] transition-colors">Liên hệ</a>
            </nav>
            <div class="flex items-center gap-4">
                <button class="p-2 text-on-surface-variant hover:bg-surface-container rounded-full transition-colors">
                    <span class="material-symbols-outlined">search</span>
                </button>
                @if (Context.Session.GetString("AccountId") != null)
                {
                    <button class="p-2 text-on-surface-variant hover:bg-surface-container rounded-full transition-colors relative">
                        <span class="material-symbols-outlined">notifications</span>
                        <span class="absolute top-2 right-2 w-2 h-2 bg-error rounded-full border-2 border-white"></span>
                    </button>
                    <div class="h-8 w-[1px] bg-outline-variant mx-2 hidden sm:block"></div>
                    <div class="relative group">
                        <button id="userMenuBtn" class="flex items-center space-x-3 p-1.5 rounded-full hover:bg-surface-container transition-colors">
                            <div class="w-9 h-9 rounded-full bg-[#0058be] flex items-center justify-center text-white font-semibold">
                                @(Context.Session.GetString("FullName")?.Substring(0, 1).ToUpper() ?? "U")
                            </div>
                            <div class="hidden md:flex flex-col items-start">
                                <span class="text-sm font-semibold text-[#0b1c30] leading-tight">@Context.Session.GetString("FullName")</span>
                                <span class="text-[10px] text-[#444651] uppercase tracking-wider font-semibold">@Context.Session.GetString("RoleName")</span>
                            </div>
                            <span class="material-symbols-outlined text-[#444651] text-xl">keyboard_arrow_down</span>
                        </button>
                        <div id="userDropdown" class="hidden absolute right-0 mt-2 w-56 bg-white rounded-xl shadow-xl border border-outline-variant overflow-hidden z-[100]">
                            <div class="py-2">
                                <a href="#" class="flex items-center gap-3 px-4 py-3 text-sm text-on-surface hover:bg-surface-container transition-colors">
                                    <span class="material-symbols-outlined text-outline">person</span> Hồ sơ cá nhân
                                </a>
                                <a asp-controller="Booking" asp-action="History" class="flex items-center gap-3 px-4 py-3 text-sm text-on-surface hover:bg-surface-container transition-colors">
                                    <span class="material-symbols-outlined text-outline">history</span> Lịch sử thuê xe
                                </a>
                                <a asp-controller="Booking" asp-action="MyInvoices" class="flex items-center gap-3 px-4 py-3 text-sm text-on-surface hover:bg-surface-container transition-colors">
                                    <span class="material-symbols-outlined text-outline">receipt_long</span> Hóa đơn của tôi
                                </a>
                                <a href="#" class="flex items-center gap-3 px-4 py-3 text-sm text-on-surface hover:bg-surface-container transition-colors">
                                    <span class="material-symbols-outlined text-outline">star</span> Đánh giá của tôi
                                </a>
                                <div class="border-t border-outline-variant my-1"></div>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    <button type="submit" class="w-full flex items-center gap-3 px-4 py-3 text-sm text-error hover:bg-red-50 transition-colors font-semibold">
                                        <span class="material-symbols-outlined">logout</span> Đăng xuất
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="h-8 w-[1px] bg-outline-variant mx-2 hidden sm:block"></div>
                    <a asp-controller="Account" asp-action="Login" class="text-[#00236f] font-bold text-sm hover:underline">Đăng nhập</a>
                    <a asp-controller="Account" asp-action="Register" class="bg-[#00236f] text-white px-6 py-2.5 rounded-lg font-bold text-sm hover:bg-blue-900 transition-colors shadow-md">Đăng ký</a>
                }
            </div>
        </div>
    </header>
    <main class="flex-grow pt-4">
        @RenderBody()
    </main>
    <footer class="bg-[#0b1c30] text-white py-16 mt-auto">
        <div class="max-w-[1280px] mx-auto px-4 md:px-12">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 text-left">
                <div class="space-y-6">
                    <div class="flex items-center gap-2">
                        <div class="w-10 h-10 bg-[#0058be] rounded-lg flex items-center justify-center">
                            <span class="material-symbols-outlined text-white">directions_car</span>
                        </div>
                        <span class="text-xl font-bold tracking-tight text-white uppercase">LUXE<span class="text-[#adc6ff]">DRIVE</span></span>
                    </div>
                    <p class="text-sm text-gray-400 leading-relaxed">Cung cấp dịch vụ thuê xe uy tín, nhanh chóng và tiện lợi cho mọi hành trình của bạn.</p>
                </div>
                <div>
                    <h4 class="text-sm font-bold uppercase tracking-widest mb-6 text-white">Về chúng tôi</h4>
                    <ul class="space-y-4 text-sm">
                        <li><a href="#" class="text-gray-400 hover:text-white transition-colors">Giới thiệu</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-white transition-colors">Đội ngũ</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-white transition-colors">Tuyển dụng</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-sm font-bold uppercase tracking-widest mb-6 text-white">Dịch vụ & Khám phá</h4>
                    <ul class="space-y-4 text-sm">
                        <li><a href="#" class="text-gray-400 hover:text-white transition-colors">Bảng giá thuê xe</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-white transition-colors">Quy trình thuê xe</a></li>
                        <li><a href="#" class="text-gray-400 hover:text-white transition-colors">Địa điểm thuê xe</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-sm font-bold uppercase tracking-widest mb-6 text-white">Liên hệ</h4>
                    <ul class="space-y-4 text-sm mb-8 text-gray-400">
                        <li class="flex items-center gap-3"><span class="material-symbols-outlined text-[#0058be]">call</span> 0123 456 789</li>
                        <li class="flex items-center gap-3"><span class="material-symbols-outlined text-[#0058be]">mail</span> contact@thuexe.vn</li>
                        <li class="flex items-start gap-3"><span class="material-symbols-outlined text-[#0058be]">location_on</span> 123 Đường Láng, Hà Nội</li>
                    </ul>
                </div>
            </div>
            <div class="mt-12 pt-8 border-t border-white/10 text-center text-xs text-gray-500">
                <p>© 2026 Hệ thống thuê xe. Bản quyền thuộc về chúng tôi.</p>
            </div>
        </div>
    </footer>
    <script>
        const userMenuBtn = document.getElementById("userMenuBtn");
        const userDropdown = document.getElementById("userDropdown");
        if (userMenuBtn && userDropdown) {
        userMenuBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        userDropdown.classList.toggle("hidden");
        });
        document.addEventListener("click", (e) => {
        if (!userDropdown.contains(e.target) && !userMenuBtn.contains(e.target)) {
        userDropdown.classList.add("hidden");
        }
        });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>