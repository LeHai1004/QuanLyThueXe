<!DOCTYPE html>
<html class="light" lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - RoyalCar Staff</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
        darkMode: "class",
        theme: {
        extend: {
        colors: {
        primary: "#00236f",
        secondary: "#0051d5",
        tertiary: "#4b1c00",
        "on-primary": "#ffffff",
        "primary-container": "#1e3a8a",
        "on-primary-container": "#90a8ff",
        "secondary-container": "#316bf3",
        "on-secondary-container": "#fefcff",
        surface: "#faf8ff",
        "on-surface": "#1a1b21",
        "surface-variant": "#e3e1e9",
        "on-surface-variant": "#444651",
        outline: "#757682",
        "outline-variant": "#c5c5d3",
        background: "#faf8ff",
        "surface-container-lowest": "#ffffff",
        "surface-container-low": "#f4f3fa",
        "surface-container": "#eeedf4",
        "surface-container-high": "#e9e7ef",
        "surface-container-highest": "#e3e1e9",
        error: "#ba1a1a",
        "error-container": "#ffdad6",
        "on-error": "#ffffff",
        "sidebar-bg": "#1E293B",
        },
        borderRadius: {
        DEFAULT: "0.25rem",
        lg: "0.5rem",
        xl: "0.75rem",
        full: "9999px",
        },
        spacing: {
        "container-padding": "32px",
        "base-unit": "4px",
        gutter: "24px",
        "sidebar-width": "260px",
        },
        fontFamily: {
        h1: ["Inter"],
        h2: ["Inter"],
        "body-lg": ["Inter"],
        "body-md": ["Inter"],
        "label-md": ["Inter"],
        "status-pill": ["Inter"],
        },
        fontSize: {
        h1: ["24px", { lineHeight: "32px", letterSpacing: "-0.02em", fontWeight: "600" }],
        h2: ["20px", { lineHeight: "28px", letterSpacing: "-0.01em", fontWeight: "600" }],
        "body-lg": ["16px", { lineHeight: "24px", fontWeight: "400" }],
        "body-md": ["14px", { lineHeight: "20px", fontWeight: "400" }],
        "label-md": ["13px", { lineHeight: "18px", letterSpacing: "0.01em", fontWeight: "500" }],
        "status-pill": ["12px", { lineHeight: "16px", fontWeight: "600" }],
        },
        },
        },
        };
    </script>
    <style>
        body {
        font-family: "Inter", sans-serif;
        background-color: #f8fafc;
        }

        .material-symbols-outlined {
        font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24;
        }

        .sidebar-active {
        background-color: #316bf3;
        color: #ffffff;
        }

        .custom-scrollbar::-webkit-scrollbar {
        display: none;
        }

        .custom-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="flex min-h-screen text-on-surface">
    <aside class="fixed left-0 top-0 h-screen w-sidebar-width bg-sidebar-bg text-white flex flex-col z-50 overflow-hidden">
        <div class="px-6 py-8">
            <div class="font-h1 text-h1 tracking-tight">RoyalCar</div>
        </div>
        <div class="px-6 mb-8">
            <div class="flex items-center gap-3 p-3 bg-white/10 rounded-xl">
                <img alt="Staff Avatar" class="w-10 h-10 rounded-full object-cover border border-white/20" src="https://ui-avatars.com/api/?name=Staff&background=316bf3&color=fff" />
                <div class="overflow-hidden">
                    <p class="text-body-md font-semibold truncate">@(Context.Session.GetString("FullName") ?? "Nhân viên")</p>
                    <p class="text-[11px] text-white/60 uppercase tracking-wider truncate">@(Context.Session.GetString("RoleName") ?? "Nhân viên vận hành")</p>
                </div>
            </div>
        </div>
        <nav class="flex-grow px-4 space-y-1 overflow-y-auto custom-scrollbar">
            @{
                var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

                string NavClass(string controller, string action = "Index")
                {
                    bool isActive = string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
                                 && string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
                    return isActive
                        ? "sidebar-active flex items-center gap-3 px-4 py-3 rounded-lg transition-all"
                        : "flex items-center gap-3 px-4 py-3 rounded-lg text-white/70 hover:text-white hover:bg-white/5 transition-all";
                }
            }

            <a class="@NavClass("Dashboard", "Index")" asp-controller="Dashboard" asp-action="Index">
                <span class="material-symbols-outlined">dashboard</span>
                <span class="font-body-md">Dashboard</span>
            </a>
            <a class="@NavClass("Booking", "Index")" asp-controller="Booking" asp-action="Index">
                <span class="material-symbols-outlined">calendar_today</span>
                <span class="font-body-md">Quản lý Đặt xe</span>
            </a>
            <a class="@NavClass("Vehicle", "Index")" asp-controller="Vehicle" asp-action="Index">
                <span class="material-symbols-outlined">directions_car</span>
                <span class="font-body-md">Quản lý Xe</span>
            </a>
            <a class="@NavClass("ImportReceipt", "Create")" asp-controller="ImportReceipt" asp-action="Create">
                <span class="material-symbols-outlined">description</span>
                <span class="font-body-md">Lập phiếu nhập</span>
            </a>
            <a class="@NavClass("Dashboard", "Report")" asp-controller="Dashboard" asp-action="Report">
                <span class="material-symbols-outlined">analytics</span>
                <span class="font-body-md">Báo cáo</span>
            </a>
        </nav>
        <div class="px-4 py-4 space-y-1 border-t border-white/10 mt-auto">
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-white/70 hover:text-white hover:bg-white/5 transition-all" asp-controller="Account" asp-action="Settings">
                <span class="material-symbols-outlined">settings</span>
                <span class="font-body-md">Cài đặt</span>
            </a>
            <form asp-controller="Account" asp-action="Logout" method="post" class="w-full">
                <button type="submit" class="w-full flex items-center gap-3 px-4 py-3 rounded-lg text-white/70 hover:text-white hover:bg-red-500/20 hover:text-red-400 transition-all text-left">
                    <span class="material-symbols-outlined">logout</span>
                    <span class="font-body-md">Đăng xuất</span>
                </button>
            </form>
        </div>
    </aside>
    <main class="ml-sidebar-width flex-grow min-h-screen flex flex-col">
        <header class="bg-white border-b border-outline-variant/30 px-container-padding py-6 flex justify-between items-center sticky top-0 z-40">
            <div>
                <h1 class="font-h1 text-h1 text-primary">@ViewData["Title"]</h1>
                <p class="text-on-surface-variant font-body-md mt-1">
                    Chào mừng, @(Context.Session.GetString("FullName") ?? "bạn") • @DateTime.Now.ToString("dd/MM/yyyy")
                </p>
            </div>
            <div class="flex items-center gap-4">
                @await RenderSectionAsync("HeaderSearch", required: false)
                <button class="p-2.5 bg-surface-container-low hover:bg-surface-container-high rounded-full transition-colors relative">
                    <span class="material-symbols-outlined text-on-surface-variant">notifications</span>
                    <span class="absolute top-2 right-2 w-2 h-2 bg-error rounded-full border-2 border-white"></span>
                </button>
                <button class="p-2.5 bg-surface-container-low hover:bg-surface-container-high rounded-full transition-colors">
                    <span class="material-symbols-outlined text-on-surface-variant">help_outline</span>
                </button>
            </div>
        </header>
        <div class="p-container-padding flex-1">
            @RenderBody()
        </div>
    </main>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>