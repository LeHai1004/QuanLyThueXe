@model CarRentalSystem.Models.VehicleCategory

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Chỉnh Sửa Loại Xe";
}

@section HeaderSearch {
    <nav class="flex items-center gap-2 text-sm text-slate-400">
        <a asp-controller="VehicleCategory" asp-action="Index"
           class="hover:text-secondary transition-colors font-medium">Loại xe</a>
        <span class="material-symbols-outlined text-base">chevron_right</span>
        <span class="text-[#1E293B] font-bold">Chỉnh sửa</span>
    </nav>
}

<div class="mt-8 max-w-2xl mx-auto w-full">

    @* Info banner *@
    <div class="mb-6 flex items-center gap-3 px-5 py-4 bg-amber-50 border border-amber-200 rounded-xl shadow-sm">
        <span class="material-symbols-outlined text-amber-500">info</span>
        <p class="text-sm font-medium text-amber-800">
            Đang chỉnh sửa loại xe <strong class="font-bold text-amber-900">@Model.CategoryName</strong>.
            Lưu ý: Bất kỳ thay đổi nào cũng sẽ áp dụng lên toàn bộ danh sách xe thuộc phân loại này.
        </p>
    </div>

    @* Card *@
    <div class="bg-white rounded-2xl shadow-[0_8px_30px_rgb(0,0,0,0.06)] border border-slate-100 overflow-hidden">

        @* Card Header *@
        <div class="px-10 py-7 border-b border-slate-100 flex items-center justify-between">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-xl bg-amber-50 flex items-center justify-center border border-amber-100">
                    <span class="material-symbols-outlined text-amber-500 text-2xl">edit_note</span>
                </div>
                <div>
                    <h2 class="text-2xl font-extrabold text-[#1E293B]">Chỉnh sửa loại xe</h2>
                    <p class="text-sm font-medium text-slate-400 mt-0.5 tracking-wide">Cập nhật thông tin chi tiết bên dưới</p>
                </div>
            </div>
        </div>

        @* Form *@
        <form asp-action="Edit" class="px-10 py-8 space-y-6">
            @Html.AntiForgeryToken()

            <input asp-for="CategoryId" type="hidden" />

            @* Tên loại xe *@
            <div class="space-y-2">
                <label asp-for="CategoryName"
                       class="block text-xs font-bold text-[#1E293B] uppercase tracking-widest">
                    Tên loại xe <span class="text-red-500">*</span>
                </label>
                <input asp-for="CategoryName"
                       placeholder="VD: SUV, Sedan, Pickup..."
                       class="w-full px-5 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm text-[#1E293B]
                focus:outline-none focus:ring-2 focus:ring-secondary/25 focus:border-secondary
                transition-all placeholder:text-slate-400 font-medium" />
                <span asp-validation-for="CategoryName" class="text-red-500 text-xs font-semibold"></span>
            </div>

            @* Mô tả *@
            <div class="space-y-2">
                <label asp-for="Description"
                       class="block text-xs font-bold text-[#1E293B] uppercase tracking-widest">
                    Mô tả
                </label>
                <textarea asp-for="Description" rows="4"
                          placeholder="Mô tả ngắn về loại xe này..."
                          class="w-full px-5 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm text-[#1E293B]
                focus:outline-none focus:ring-2 focus:ring-secondary/25 focus:border-secondary
                transition-all resize-none placeholder:text-slate-400 font-medium"></textarea>
                <span asp-validation-for="Description" class="text-red-500 text-xs font-semibold"></span>
            </div>

            @* Trạng thái hiển thị *@
            <div class="space-y-2">
                <label class="block text-xs font-bold text-[#1E293B] uppercase tracking-widest">
                    Trạng thái hiển thị
                </label>
                <div class="p-4 bg-blue-50/50 rounded-xl border border-blue-100 flex items-center justify-between">
                    <div>
                        <h4 class="text-sm font-bold text-slate-700">Cho phép hoạt động</h4>
                        <p class="text-xs font-medium text-slate-500 mt-0.5">Bật để khách hàng có thể nhìn thấy loại xe này trên ứng dụng</p>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input asp-for="IsActive" type="checkbox" class="sr-only peer">
                        <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-secondary"></div>
                    </label>
                </div>
            </div>

            @* Actions *@
            <div class="border-t border-slate-100 pt-8 mt-4 flex items-center justify-end gap-3">
                <a asp-controller="VehicleCategory" asp-action="Index"
                   class="px-6 py-3 rounded-xl border border-slate-200 text-sm font-bold text-slate-600
                    hover:bg-slate-50 hover:text-slate-800 transition-all">
                    Hủy bỏ
                </a>
                <button type="submit"
                        class="px-8 py-3 bg-secondary text-white rounded-xl font-bold text-sm
                    shadow-lg shadow-secondary/30 hover:bg-primary transition-all duration-300
                    active:scale-95 flex items-center gap-2">
                    <span class="material-symbols-outlined text-[20px]">save</span>
                    Lưu thay đổi
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}