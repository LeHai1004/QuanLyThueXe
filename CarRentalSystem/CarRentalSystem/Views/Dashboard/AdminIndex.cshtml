@model IEnumerable<CarRentalSystem.Models.Booking>
@{
    ViewData["Title"] = "Dashboard Admin";
    Layout = "_AdminLayout";
}

<div class="space-y-6">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-4 mt-2">
        <div>
            <h1 class="text-2xl font-bold text-primary">Tổng quan hệ thống</h1>
            <p class="text-on-surface-variant mt-1">Chào mừng quay trở lại, @Context.Session.GetString("FullName")</p>
        </div>
        <div>
            <button class="bg-[#00236f] text-white px-5 py-2.5 rounded-xl font-bold text-sm shadow-md hover:bg-blue-900 transition-all flex items-center gap-2">
                <span class="material-symbols-outlined text-[20px]">download</span>
                Tải báo cáo
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
        <div class="bg-white p-6 rounded-xl border border-outline-variant/50 shadow-sm hover:shadow-md transition-shadow">
            <p class="text-[13px] font-bold text-on-surface-variant mb-3 uppercase tracking-wider">
                Doanh thu (Đã hoàn thành)
            </p>
            <div class="flex items-end justify-between">
                <h3 class="text-2xl font-bold text-primary">@Convert.ToDecimal(ViewBag.Revenue).ToString("N0")đ</h3>
                <span class="text-[11px] font-bold text-emerald-600 bg-emerald-50 px-2 py-1 rounded whitespace-nowrap">+12.5%</span>
            </div>
        </div>

        <div class="bg-white p-6 rounded-xl border border-outline-variant/50 shadow-sm hover:shadow-md transition-shadow">
            <p class="text-[13px] font-bold text-on-surface-variant mb-3 uppercase tracking-wider">
                Xe đang cho thuê
            </p>
            <div class="flex items-end justify-between">
                <h3 class="text-2xl font-bold text-primary">@ViewBag.RentedCars</h3>
                <span class="text-[11px] font-bold text-blue-600 bg-blue-50 px-2 py-1 rounded whitespace-nowrap">Trong đội xe @(ViewBag.RentedCars + ViewBag.AvailableCars)</span>
            </div>
        </div>

        <div class="bg-white p-6 rounded-xl border border-outline-variant/50 shadow-sm hover:shadow-md transition-shadow">
            <p class="text-[13px] font-bold text-on-surface-variant mb-3 uppercase tracking-wider">
                Tổng đơn hàng
            </p>
            <div class="flex items-end justify-between">
                <h3 class="text-2xl font-bold text-primary">@ViewBag.TotalOrders</h3>
                <span class="text-[11px] font-bold text-emerald-600 bg-emerald-50 px-2 py-1 rounded whitespace-nowrap">+8%</span>
            </div>
        </div>

        <div class="bg-white p-6 rounded-xl border border-outline-variant/50 shadow-sm hover:shadow-md transition-shadow">
            <p class="text-[13px] font-bold text-on-surface-variant mb-3 uppercase tracking-wider">
                Khách hàng mới (Tuần)
            </p>
            <div class="flex items-end justify-between">
                <h3 class="text-2xl font-bold text-primary">@ViewBag.NewCustomers</h3>
                <span class="text-[11px] font-bold text-emerald-600 bg-emerald-50 px-2 py-1 rounded whitespace-nowrap">+5 tuần này</span>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-10 gap-10 mb-10">
        <div class="lg:col-span-7 bg-white p-8 rounded-xl border border-outline-variant/50 shadow-sm">
            <div class="flex justify-between items-start mb-8">
                <div>
                    <h2 class="text-lg font-bold text-on-surface mb-1">
                        Biểu đồ xu hướng doanh thu 6 tháng
                    </h2>
                    <p class="text-sm text-on-surface-variant">
                        Thống kê lợi nhuận ròng từ dịch vụ cho thuê xe
                    </p>
                </div>
                <select class="bg-slate-50 border border-outline-variant/50 text-sm rounded-lg font-semibold px-3 py-1 outline-none focus:ring-1 focus:ring-secondary">
                    <option>Tháng 1 - Tháng 6</option>
                    <option>Tháng 7 - Tháng 12</option>
                </select>
            </div>
            <div class="h-[300px] w-full relative">
                <svg class="w-full h-full" preserveaspectratio="none" viewbox="0 0 800 300">
                    <defs>
                        <lineargradient id="chartGradient" x1="0" x2="0" y1="0" y2="1">
                            <stop offset="0%" stop-color="#316bf3" stop-opacity="0.2"></stop>
                            <stop offset="100%" stop-color="#316bf3" stop-opacity="0"></stop>
                        </lineargradient>
                    </defs>
                    <line stroke="#F1F5F9" stroke-dasharray="4" x1="0" x2="800" y1="50" y2="50"></line>
                    <line stroke="#F1F5F9" stroke-dasharray="4" x1="0" x2="800" y1="125" y2="125"></line>
                    <line stroke="#F1F5F9" stroke-dasharray="4" x1="0" x2="800" y1="200" y2="200"></line>
                    <line stroke="#F1F5F9" stroke-dasharray="4" x1="0" x2="800" y1="275" y2="275"></line>
                    <path d="M0,250 Q100,220 200,230 T400,100 T600,150 T800,50 L800,300 L0,300 Z" fill="url(#chartGradient)"></path>
                    <path d="M0,250 Q100,220 200,230 T400,100 T600,150 T800,50" fill="none" stroke="#316bf3" stroke-linecap="round" stroke-width="3"></path>
                    <circle cx="0" cy="250" fill="#316bf3" r="4"></circle>
                    <circle cx="200" cy="230" fill="#316bf3" r="4"></circle>
                    <circle cx="400" cy="100" fill="#316bf3" r="4"></circle>
                    <circle cx="600" cy="150" fill="#316bf3" r="4"></circle>
                    <circle cx="800" cy="50" fill="#316bf3" r="4"></circle>
                </svg>
                <div class="flex justify-between mt-4 px-2 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">
                    <span>Tháng 1</span><span>Tháng 2</span><span>Tháng 3</span><span>Tháng 4</span><span>Tháng 5</span><span>Tháng 6</span>
                </div>
            </div>
        </div>

        <div class="lg:col-span-3 bg-white p-8 rounded-xl border border-outline-variant/50 shadow-sm">
            <h2 class="text-lg font-bold text-on-surface mb-6">Top 3 xe thuê nhiều nhất</h2>
            <div class="flex flex-col gap-6">
                <div class="flex flex-col gap-2">
                    <div class="flex items-center gap-3">
                        <img src="https://images.unsplash.com/photo-1550355291-bbee04a92027?auto=format&fit=crop&w=100&q=80" class="w-12 h-12 rounded-lg object-cover border border-slate-100" />
                        <div class="flex-1">
                            <p class="text-sm font-bold text-on-surface">Mercedes S450</p>
                            <p class="text-xs text-on-surface-variant font-medium">54 lượt thuê</p>
                        </div>
                        <span class="text-xs font-bold text-emerald-600">+12%</span>
                    </div>
                    <div class="w-full bg-slate-100 h-1.5 rounded-full overflow-hidden">
                        <div class="bg-secondary h-full" style="width: 85%"></div>
                    </div>
                </div>

                <div class="flex flex-col gap-2">
                    <div class="flex items-center gap-3">
                        <img src="https://images.unsplash.com/photo-1583121274602-3e2820c69888?auto=format&fit=crop&w=100&q=80" class="w-12 h-12 rounded-lg object-cover border border-slate-100" />
                        <div class="flex-1">
                            <p class="text-sm font-bold text-on-surface">Ferrari 488</p>
                            <p class="text-xs text-on-surface-variant font-medium">48 lượt thuê</p>
                        </div>
                        <span class="text-xs font-bold text-emerald-600">+8%</span>
                    </div>
                    <div class="w-full bg-slate-100 h-1.5 rounded-full overflow-hidden">
                        <div class="bg-secondary h-full" style="width: 72%"></div>
                    </div>
                </div>

                <div class="flex flex-col gap-2">
                    <div class="flex items-center gap-3">
                        <img src="https://images.unsplash.com/photo-1549317661-bd32c8ce0db2?auto=format&fit=crop&w=100&q=80" class="w-12 h-12 rounded-lg object-cover border border-slate-100" />
                        <div class="flex-1">
                            <p class="text-sm font-bold text-on-surface">Audi A6</p>
                            <p class="text-xs text-on-surface-variant font-medium">41 lượt thuê</p>
                        </div>
                        <span class="text-xs font-bold text-red-500">-2%</span>
                    </div>
                    <div class="w-full bg-slate-100 h-1.5 rounded-full overflow-hidden">
                        <div class="bg-secondary h-full" style="width: 65%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="bg-white p-5 rounded-xl border border-outline-variant/50 flex items-center gap-5 shadow-sm">
            <div class="w-12 h-12 rounded-lg bg-emerald-50 text-emerald-600 flex items-center justify-center">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1">person_check</span>
            </div>
            <div>
                <p class="text-2xl font-black text-on-surface">12</p>
                <p class="text-[11px] font-bold text-on-surface-variant uppercase tracking-widest whitespace-nowrap">
                    Nhân viên Online
                </p>
            </div>
        </div>

        <div class="bg-white p-5 rounded-xl border border-outline-variant/50 flex items-center gap-5 shadow-sm">
            <div class="w-12 h-12 rounded-lg bg-amber-50 text-amber-600 flex items-center justify-center">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1">build</span>
            </div>
            <div>
                <p class="text-2xl font-black text-on-surface">2</p>
                <p class="text-[11px] font-bold text-on-surface-variant uppercase tracking-widest whitespace-nowrap">
                    Xe Đang bảo trì
                </p>
            </div>
        </div>

        <div class="bg-white p-5 rounded-xl border border-outline-variant/50 flex items-center gap-5 shadow-sm">
            <div class="w-12 h-12 rounded-lg bg-red-50 text-red-600 flex items-center justify-center">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1">pending_actions</span>
            </div>
            <div>
                <p class="text-2xl font-black text-on-surface">3</p>
                <p class="text-[11px] font-bold text-on-surface-variant uppercase tracking-widest whitespace-nowrap">
                    Phiếu chờ duyệt
                </p>
            </div>
        </div>
    </div>
</div>