@model IEnumerable<CarRentalSystem.Models.Booking>
@{
    ViewData["Title"] = "Trang tổng quan nhân viên";
    Layout = "_StaffLayout";
}

<header class="bg-white border-b border-outline-variant/30 px-container-padding py-6 flex justify-between items-center mb-6">
    <div>
        <h1 class="font-h1 text-h1 text-primary">
            Trang tổng quan nhân viên
        </h1>
        <p class="text-on-surface-variant font-body-md mt-1">
            Chào mừng, @Context.Session.GetString("FullName") • @DateTime.Now.ToString("dd MMMM, yyyy")
        </p>
    </div>
    <div class="flex items-center gap-4">
        <button class="p-2.5 bg-surface-container-low hover:bg-surface-container-high rounded-full transition-colors relative">
            <span class="material-symbols-outlined text-on-surface-variant" style="font-variation-settings: 'FILL' 1">notifications</span>
            <span class="absolute top-2 right-2 w-2 h-2 bg-error rounded-full border-2 border-white"></span>
        </button>
        <button class="p-2.5 bg-surface-container-low hover:bg-surface-container-high rounded-full transition-colors">
            <span class="material-symbols-outlined text-on-surface-variant">help_outline</span>
        </button>
    </div>
</header>

<div class="px-container-padding pb-8 space-y-gutter">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-gutter">
        <div class="bg-white p-6 rounded-xl shadow-sm border border-outline-variant/30">
            <p class="text-on-surface-variant text-label-md font-medium uppercase tracking-wider mb-2">Tổng đơn hàng</p>
            <div class="flex items-end justify-between">
                <span class="text-[28px] font-bold text-primary">@ViewBag.TotalOrders</span>
            </div>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-sm border border-outline-variant/30">
            <p class="text-on-surface-variant text-label-md font-medium uppercase tracking-wider mb-2">Xe đang thuê</p>
            <div class="flex items-end justify-between">
                <span class="text-[28px] font-bold text-primary">@ViewBag.RentedCars</span>
            </div>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-sm border border-outline-variant/30">
            <p class="text-on-surface-variant text-label-md font-medium uppercase tracking-wider mb-2">Xe sẵn sàng</p>
            <div class="flex items-end justify-between">
                <span class="text-[28px] font-bold text-primary">@ViewBag.AvailableCars</span>
            </div>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-sm border border-outline-variant/30">
            <p class="text-on-surface-variant text-label-md font-medium uppercase tracking-wider mb-2">Doanh thu (Đã HT)</p>
            <div class="flex items-end justify-between">
                <span class="text-[28px] font-bold text-primary">@Convert.ToDecimal(ViewBag.Revenue).ToString("N0")đ</span>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-10 gap-gutter">
        <div class="lg:col-span-7 bg-white rounded-xl shadow-sm border border-outline-variant/30 overflow-hidden flex flex-col">
            <div class="px-6 py-5 border-b border-outline-variant/20 flex justify-between items-center">
                <h2 class="font-h2 text-h2 text-primary">Đơn đặt xe gần đây</h2>
                <a href="/Booking/Index" class="text-secondary font-label-md font-semibold hover:underline">Xem tất cả</a>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-surface-container-low">
                        <tr>
                            <th class="px-6 py-4 text-[12px] font-bold text-on-surface-variant uppercase tracking-wider">Mã đơn</th>
                            <th class="px-6 py-4 text-[12px] font-bold text-on-surface-variant uppercase tracking-wider">Khách hàng</th>
                            <th class="px-6 py-4 text-[12px] font-bold text-on-surface-variant uppercase tracking-wider">Xe</th>
                            <th class="px-6 py-4 text-[12px] font-bold text-on-surface-variant uppercase tracking-wider">Tổng tiền</th>
                            <th class="px-6 py-4 text-[12px] font-bold text-on-surface-variant uppercase tracking-wider">Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant/20">
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-surface-container-lowest transition-colors">
                                <td class="px-6 py-4 font-bold text-primary text-body-md">#RC-@item.BookingId.ToString("D4")</td>
                                <td class="px-6 py-4 text-body-md">@(item.Customer?.UserProfile?.FullName ?? "Khách hàng ẩn")</td>
                                <td class="px-6 py-4 text-body-md">@(item.Vehicle?.VehicleName ?? "Xe không tồn tại")</td>
                                <td class="px-6 py-4 text-body-md font-semibold text-primary">@item.TotalAmount.ToString("N0")đ</td>
                                <td class="px-6 py-4">
                                    @if (item.Status == "Cho xac nhan")
                                    {
                                        <span class="text-status-pill font-status-pill text-amber-700 bg-amber-100 px-3 py-1 rounded-full whitespace-nowrap">Chờ xác nhận</span>
                                    }
                                    else if (item.Status == "Da xac nhan")
                                    {
                                        <span class="text-status-pill font-status-pill text-blue-700 bg-blue-100 px-3 py-1 rounded-full whitespace-nowrap">Đã xác nhận</span>
                                    }
                                    else if (item.Status == "Dang thue")
                                    {
                                        <span class="text-status-pill font-status-pill text-secondary bg-secondary-fixed px-3 py-1 rounded-full whitespace-nowrap">Đang thuê</span>
                                    }
                                    else if (item.Status == "Hoan thanh")
                                    {
                                        <span class="text-status-pill font-status-pill text-emerald-700 bg-emerald-100 px-3 py-1 rounded-full whitespace-nowrap">Hoàn thành</span>
                                    }
                                    else
                                    {
                                        <span class="text-status-pill font-status-pill text-red-700 bg-red-100 px-3 py-1 rounded-full whitespace-nowrap">Đã hủy</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="lg:col-span-3 space-y-gutter">
            <div class="bg-white rounded-xl shadow-sm border border-outline-variant/30 overflow-hidden">
                <div class="px-6 py-4 border-b border-outline-variant/20 flex items-center justify-between">
                    <h2 class="font-h2 text-h2 text-primary">Thông báo mới</h2>
                    <span class="flex h-2 w-2 rounded-full bg-error animate-pulse"></span>
                </div>
                <div class="p-6 space-y-5">
                    <div class="flex gap-4 items-start group cursor-pointer">
                        <div class="w-10 h-10 rounded-full bg-secondary-fixed flex items-center justify-center shrink-0">
                            <span class="material-symbols-outlined text-secondary">directions_car</span>
                        </div>
                        <div class="overflow-hidden">
                            <p class="text-body-md font-semibold text-on-surface group-hover:text-secondary transition-colors truncate">Xe #RC-8892 đã trả</p>
                            <p class="text-label-md text-on-surface-variant line-clamp-2 mt-0.5">Khách hàng Phạm Minh Đức vừa hoàn tất thủ tục trả xe.</p>
                            <p class="text-[11px] text-outline mt-1.5">10 phút trước</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-xl shadow-sm border border-outline-variant/30 overflow-hidden">
                <div class="px-6 py-4 border-b border-outline-variant/20">
                    <h2 class="font-h2 text-h2 text-primary">Thao tác nhanh</h2>
                </div>
                <div class="p-4 grid grid-cols-2 gap-3">
                    <a href="/Booking/Index" class="flex flex-col items-center justify-center p-4 rounded-xl bg-surface-container-low hover:bg-secondary-container hover:text-white transition-all duration-200 gap-2 border border-outline-variant/10 group">
                        <span class="material-symbols-outlined text-[28px] text-primary group-hover:text-white">event_note</span>
                        <span class="text-label-md font-semibold">Duyệt Đơn</span>
                    </a>
                    <button class="flex flex-col items-center justify-center p-4 rounded-xl bg-surface-container-low hover:bg-secondary-container hover:text-white transition-all duration-200 gap-2 border border-outline-variant/10 group">
                        <span class="material-symbols-outlined text-[28px] text-primary group-hover:text-white">input</span>
                        <span class="text-label-md font-semibold">Nhập Xe</span>
                    </button>
                    <button class="flex flex-col items-center justify-center p-4 rounded-xl bg-surface-container-low hover:bg-secondary-container hover:text-white transition-all duration-200 gap-2 border border-outline-variant/10 group">
                        <span class="material-symbols-outlined text-[28px] text-primary group-hover:text-white">print</span>
                        <span class="text-label-md font-semibold">In Phiếu</span>
                    </button>
                    <button class="flex flex-col items-center justify-center p-4 rounded-xl bg-surface-container-low hover:bg-secondary-container hover:text-white transition-all duration-200 gap-2 border border-outline-variant/10 group">
                        <span class="material-symbols-outlined text-[28px] text-primary group-hover:text-white">contact_support</span>
                        <span class="text-label-md font-semibold">Hỗ Trợ</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter mt-2">
        <div class="md:col-span-2 relative h-72 rounded-2xl overflow-hidden shadow-lg group">
            <img alt="Fleet Preview" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" src="https://images.unsplash.com/photo-1549317661-bd32c8ce0db2?auto=format&fit=crop&w=1200&q=80" />
            <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-8">
                <h3 class="text-white font-h1 text-h1">Quản lý đội xe hiện đại</h3>
                <p class="text-white/80 text-body-md mt-2 max-w-md">Hệ thống theo dõi thông minh vị trí và tình trạng kỹ thuật của hơn 120 đầu xe thời gian thực.</p>
            </div>
        </div>
        <div class="bg-primary p-8 rounded-2xl flex flex-col justify-between text-white shadow-lg">
            <div class="flex justify-between items-start">
                <div class="w-14 h-14 rounded-2xl bg-white/20 flex items-center justify-center">
                    <span class="material-symbols-outlined text-white text-[32px]">trending_up</span>
                </div>
                <span class="text-label-md bg-emerald-500 text-white px-3 py-1 rounded-full font-bold uppercase tracking-wider">Trực tiếp</span>
            </div>
            <div>
                <p class="text-white/60 text-label-md uppercase font-bold tracking-widest">Hiệu suất vận hành</p>
                <h4 class="text-[40px] font-bold mt-1">94.2%</h4>
                <div class="w-full bg-white/10 h-2 rounded-full mt-6 overflow-hidden">
                    <div class="bg-secondary-fixed w-[94%] h-full rounded-full shadow-[0_0_12px_rgba(180,197,255,0.4)]"></div>
                </div>
                <p class="text-white/60 text-[12px] mt-3">Tháng này • Cao hơn 2.4% so với tháng trước</p>
            </div>
        </div>
    </div>
</div>