@model IEnumerable<CarRentalSystem.Models.Booking>
@using CarRentalSystem.Constants
@using CarRentalSystem.Helpers
@{
    ViewData["Title"] = "Trang tổng quan nhân viên";
    Layout = "_StaffLayout";
}

<header class="bg-white border-b border-outline-variant/30 px-container-padding py-6 flex justify-between items-center mb-6">
    <div>
        <h1 class="font-h1 text-h1 text-primary">
            Trang tổng quan nhân viên
        </h1>
        <p class="text-on-surface-variant font-body-md mt-1">
            Chào mừng, @Context.Session.GetString("FullName") • @DateTime.Now.ToString("dd MMMM, yyyy")
        </p>
    </div>
    <div class="flex items-center gap-4">
        <button class="p-2.5 bg-surface-container-low hover:bg-surface-container-high rounded-full transition-colors relative">
            <span class="material-symbols-outlined text-on-surface-variant" style="font-variation-settings: 'FILL' 1">notifications</span>
            <span class="absolute top-2 right-2 w-2 h-2 bg-error rounded-full border-2 border-white"></span>
        </button>
        <button class="p-2.5 bg-surface-container-low hover:bg-surface-container-high rounded-full transition-colors">
            <span class="material-symbols-outlined text-on-surface-variant">help_outline</span>
        </button>
    </div>
</header>

<div class="px-container-padding space-y-8 pb-10">

    @* ===== STAT CARDS ===== *@
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white p-5 rounded-xl border border-outline-variant/50 flex items-center gap-5 shadow-sm">
            <div class="w-12 h-12 rounded-lg bg-blue-50 text-secondary flex items-center justify-center">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1">receipt_long</span>
            </div>
            <div>
                <p class="text-2xl font-black text-on-surface">@ViewBag.TotalOrders</p>
                <p class="text-[11px] font-bold text-on-surface-variant uppercase tracking-widest whitespace-nowrap">Tổng đơn thuê</p>
            </div>
        </div>

        <div class="bg-white p-5 rounded-xl border border-outline-variant/50 flex items-center gap-5 shadow-sm">
            <div class="w-12 h-12 rounded-lg bg-emerald-50 text-emerald-600 flex items-center justify-center">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1">directions_car</span>
            </div>
            <div>
                <p class="text-2xl font-black text-on-surface">@ViewBag.RentedCars</p>
                <p class="text-[11px] font-bold text-on-surface-variant uppercase tracking-widest whitespace-nowrap">Xe đang thuê</p>
            </div>
        </div>

        <div class="bg-white p-5 rounded-xl border border-outline-variant/50 flex items-center gap-5 shadow-sm">
            <div class="w-12 h-12 rounded-lg bg-amber-50 text-amber-600 flex items-center justify-center">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1">garage</span>
            </div>
            <div>
                <p class="text-2xl font-black text-on-surface">@ViewBag.AvailableCars</p>
                <p class="text-[11px] font-bold text-on-surface-variant uppercase tracking-widest whitespace-nowrap">Xe sẵn sàng</p>
            </div>
        </div>

        <div class="bg-white p-5 rounded-xl border border-outline-variant/50 flex items-center gap-5 shadow-sm">
            <div class="w-12 h-12 rounded-lg bg-red-50 text-red-500 flex items-center justify-center">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1">pending_actions</span>
            </div>
            <div>
                <p class="text-2xl font-black text-on-surface">
                    @(Model.Count(b => b.Status == BookingStatus.Pending))
                </p>
                <p class="text-[11px] font-bold text-on-surface-variant uppercase tracking-widest whitespace-nowrap">Đơn chờ duyệt</p>
            </div>
        </div>
    </div>

    @* ===== TABLE + RIGHT CARDS ===== *@
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

        @* Bảng đơn gần đây *@
        <div class="lg:col-span-8 bg-white rounded-2xl shadow-sm border border-outline-variant/50 flex flex-col overflow-hidden">
            <div class="px-6 py-5 border-b border-outline-variant/30 flex items-center justify-between">
                <h3 class="font-h2 text-h2 text-primary">Các yêu cầu đặt xe mới nhất</h3>
                <a href="/Booking/Index" class="text-sm font-semibold text-secondary hover:underline">Xem tất cả</a>
            </div>
            <div class="overflow-x-auto flex-1">
                <table class="w-full text-left">
                    <thead>
                        <tr class="bg-surface-container-lowest border-b border-outline-variant/30">
                            <th class="px-6 py-4 text-[12px] font-bold text-on-surface-variant uppercase tracking-wider">Khách hàng</th>
                            <th class="px-6 py-4 text-[12px] font-bold text-on-surface-variant uppercase tracking-wider">Phương tiện</th>
                            <th class="px-6 py-4 text-[12px] font-bold text-on-surface-variant uppercase tracking-wider">Thời gian</th>
                            <th class="px-6 py-4 text-[12px] font-bold text-on-surface-variant uppercase tracking-wider text-right">Tổng thanh toán</th>
                            <th class="px-6 py-4 text-[12px] font-bold text-on-surface-variant uppercase tracking-wider text-center">Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant/20">
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-surface-container-low transition-colors">
                                <td class="px-6 py-4">
                                    <p class="font-bold text-on-surface">@(item.Customer?.UserProfile?.FullName ?? "Khách vãng lai")</p>
                                </td>
                                <td class="px-6 py-4 font-semibold text-on-surface-variant">
                                    @(item.Vehicle?.VehicleName ?? "N/A")
                                </td>
                                <td class="px-6 py-4">
                                    <p class="text-sm font-medium text-outline">@item.PickupDateTime.ToString("dd/MM/yyyy")</p>
                                </td>
                                <td class="px-6 py-4 text-right font-bold text-on-surface">
                                    @CurrencyHelper.FormatVnd(item.TotalAmount)
                                </td>
                                <td class="px-6 py-4 text-center">
                                    @if (item.Status == BookingStatus.Pending)
                                    {
                                        <span class="px-2.5 py-1 rounded-full border border-amber-200 bg-amber-50 text-amber-700 text-xs font-bold whitespace-nowrap">Chờ duyệt</span>
                                    }
                                    else if (item.Status == BookingStatus.Confirmed)
                                    {
                                        <span class="px-2.5 py-1 rounded-full border border-blue-200 bg-blue-50 text-blue-700 text-xs font-bold whitespace-nowrap">Đã xác nhận</span>
                                    }
                                    else if (item.Status == BookingStatus.Active)
                                    {
                                        <span class="px-2.5 py-1 rounded-full border border-secondary/20 bg-secondary/10 text-secondary text-xs font-bold whitespace-nowrap">Đang thuê</span>
                                    }
                                    else if (item.Status == BookingStatus.Completed)
                                    {
                                        <span class="px-2.5 py-1 rounded-full border border-emerald-200 bg-emerald-50 text-emerald-700 text-xs font-bold whitespace-nowrap">Hoàn thành</span>
                                    }
                                    else if (item.Status == BookingStatus.Cancelled)
                                    {
                                        <span class="px-2.5 py-1 rounded-full border border-rose-200 bg-rose-50 text-rose-700 text-xs font-bold whitespace-nowrap">Đã hủy</span>
                                    }
                                    else
                                    {
                                        <span class="px-2.5 py-1 rounded-full border border-slate-200 bg-slate-50 text-slate-600 text-xs font-bold whitespace-nowrap">@item.Status</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* Cột phải *@
        <div class="lg:col-span-4 space-y-6">
            @* Ảnh đội xe *@
            <div class="relative rounded-2xl overflow-hidden shadow-lg aspect-[4/3] group">
                <img src="https://images.unsplash.com/photo-1542362567-b07e54358753?auto=format&fit=crop&w=800&q=80"
                     alt="Fleet" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                <div class="absolute inset-0 bg-gradient-to-t from-primary/90 to-transparent"></div>
                <div class="absolute bottom-0 left-0 p-6">
                    <h3 class="text-white font-h1 text-h1">Quản lý đội xe hiện đại</h3>
                    <p class="text-white/80 text-body-md mt-1">Hệ thống theo dõi tình trạng kỹ thuật hơn 120 đầu xe thời gian thực.</p>
                </div>
            </div>

            @* Thao tác nhanh *@
            <div class="bg-white rounded-2xl shadow-sm border border-outline-variant/50 overflow-hidden">
                <div class="px-6 py-4 border-b border-outline-variant/20">
                    <h2 class="font-h2 text-h2 text-primary">Thao tác nhanh</h2>
                </div>
                <div class="p-4 grid grid-cols-2 gap-3">
                    <a href="/Booking/Index"
                       class="flex flex-col items-center justify-center p-4 rounded-xl bg-surface-container-low hover:bg-secondary-container hover:text-white transition-all duration-200 gap-2 border border-outline-variant/10 group">
                        <span class="material-symbols-outlined text-[28px] text-primary group-hover:text-white">event_note</span>
                        <span class="text-label-md font-semibold">Duyệt Đơn</span>
                    </a>
                    <a href="/ImportReceipt/Index"
                       class="flex flex-col items-center justify-center p-4 rounded-xl bg-surface-container-low hover:bg-secondary-container hover:text-white transition-all duration-200 gap-2 border border-outline-variant/10 group">
                        <span class="material-symbols-outlined text-[28px] text-primary group-hover:text-white">input</span>
                        <span class="text-label-md font-semibold">Nhập Xe</span>
                    </a>
                    <a href="/Maintenance/Index"
                       class="flex flex-col items-center justify-center p-4 rounded-xl bg-surface-container-low hover:bg-secondary-container hover:text-white transition-all duration-200 gap-2 border border-outline-variant/10 group">
                        <span class="material-symbols-outlined text-[28px] text-primary group-hover:text-white">build</span>
                        <span class="text-label-md font-semibold">Bảo Dưỡng</span>
                    </a>
                    <a href="/Home/LienHe"
                       class="flex flex-col items-center justify-center p-4 rounded-xl bg-surface-container-low hover:bg-secondary-container hover:text-white transition-all duration-200 gap-2 border border-outline-variant/10 group">
                        <span class="material-symbols-outlined text-[28px] text-primary group-hover:text-white">contact_support</span>
                        <span class="text-label-md font-semibold">Hỗ Trợ</span>
                    </a>
                </div>
            </div>
        </div>
    </div>

    @* ===== BANNER + HIỆU SUẤT ===== *@
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="md:col-span-2 relative h-64 rounded-2xl overflow-hidden shadow-lg group">
            <img alt="Fleet Preview"
                 class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                 src="https://images.unsplash.com/photo-1549317661-bd32c8ce0db2?auto=format&fit=crop&w=1200&q=80" />
            <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-8">
                <h3 class="text-white font-h1 text-h1">Hệ thống giám sát thông minh</h3>
                <p class="text-white/80 text-body-md mt-2 max-w-md">Theo dõi vị trí và tình trạng kỹ thuật đội xe theo thời gian thực.</p>
            </div>
        </div>
        <div class="bg-primary p-8 rounded-2xl flex flex-col justify-between text-white shadow-lg">
            <div class="flex justify-between items-start">
                <div class="w-14 h-14 rounded-2xl bg-white/20 flex items-center justify-center">
                    <span class="material-symbols-outlined text-white text-[32px]">trending_up</span>
                </div>
                <span class="text-xs bg-emerald-500 text-white px-3 py-1 rounded-full font-bold uppercase tracking-wider">Trực tiếp</span>
            </div>
            <div>
                <p class="text-white/60 text-xs uppercase font-bold tracking-widest">Hiệu suất vận hành</p>
                <h4 class="text-[40px] font-bold mt-1">94.2%</h4>
                <div class="w-full bg-white/10 h-2 rounded-full mt-6 overflow-hidden">
                    <div class="bg-secondary-fixed w-[94%] h-full rounded-full shadow-[0_0_12px_rgba(180,197,255,0.4)]"></div>
                </div>
                <p class="text-white/60 text-[12px] mt-3">Tháng này • Cao hơn 2.4% so với tháng trước</p>
            </div>
        </div>
    </div>
</div>
