@{
    ViewData["Title"] = "Báo cáo thống kê";
    Layout = "_AdminLayout";
}

<div class="space-y-8 flex-1 overflow-y-auto">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
            <h1 class="font-h1 text-h1 text-[#0F172A]">Báo cáo & Thống kê</h1>
            <p class="text-on-surface-variant mt-1 flex items-center gap-2">
                <span class="material-symbols-outlined text-secondary text-sm">calendar_month</span>
                Thời kỳ báo cáo: Tháng @DateTime.Now.Month, @DateTime.Now.Year
            </p>
        </div>
        <div class="flex items-center gap-4">
            <div class="flex items-center bg-white border border-slate-200 rounded-lg px-4 py-2.5 shadow-sm">
                <span class="material-symbols-outlined text-slate-400 mr-2">date_range</span>
                <span class="font-body-md text-on-surface">01/@DateTime.Now.ToString("MM/yyyy") - @DateTime.DaysInMonth(DateTime.Now.Year, DateTime.Now.Month)/@DateTime.Now.ToString("MM/yyyy")</span>
            </div>
            <button class="bg-secondary text-white px-6 py-2.5 rounded-lg flex items-center gap-2 hover:bg-blue-700 transition-all shadow-md active:scale-95 font-semibold">
                <span class="material-symbols-outlined">picture_as_pdf</span>
                <span class="font-label-md">Xuất báo cáo PDF</span>
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200 hover:shadow-md transition-shadow">
            <div class="flex justify-between items-start mb-4">
                <div class="w-12 h-12 bg-blue-50 flex items-center justify-center rounded-xl text-secondary">
                    <span class="material-symbols-outlined text-2xl">payments</span>
                </div>
            </div>
            <p class="text-on-surface-variant text-body-md font-medium uppercase tracking-wider text-[11px]">Tổng doanh thu</p>
            <h3 class="text-2xl font-bold text-[#0F172A] mt-1">
                @ViewBag.TotalRevenue.ToString("N0") <span class="text-sm font-normal text-on-surface-variant">VNĐ</span>
            </h3>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200 hover:shadow-md transition-shadow">
            <div class="flex justify-between items-start mb-4">
                <div class="w-12 h-12 bg-green-50 flex items-center justify-center rounded-xl text-green-600">
                    <span class="material-symbols-outlined text-2xl">account_balance_wallet</span>
                </div>
            </div>
            <p class="text-on-surface-variant text-body-md font-medium uppercase tracking-wider text-[11px]">Lợi nhuận ròng</p>
            <h3 class="text-2xl font-bold text-[#0F172A] mt-1">
                @ViewBag.NetProfit.ToString("N0") <span class="text-sm font-normal text-on-surface-variant">VNĐ</span>
            </h3>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200 hover:shadow-md transition-shadow">
            <div class="flex justify-between items-start mb-4">
                <div class="w-12 h-12 bg-orange-50 flex items-center justify-center rounded-xl text-orange-600">
                    <span class="material-symbols-outlined text-2xl">shopping_cart</span>
                </div>
            </div>
            <p class="text-on-surface-variant text-body-md font-medium uppercase tracking-wider text-[11px]">Tổng số đơn</p>
            <h3 class="text-2xl font-bold text-[#0F172A] mt-1">
                @ViewBag.TotalBookings.ToString("N0") <span class="text-sm font-normal text-on-surface-variant">Giao dịch</span>
            </h3>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200 hover:shadow-md transition-shadow">
            <div class="flex justify-between items-start mb-4">
                <div class="w-12 h-12 bg-purple-50 flex items-center justify-center rounded-xl text-purple-600">
                    <span class="material-symbols-outlined text-2xl">speed</span>
                </div>
            </div>
            <p class="text-on-surface-variant text-body-md font-medium uppercase tracking-wider text-[11px]">Tỷ lệ lấp đầy xe</p>
            <h3 class="text-2xl font-bold text-[#0F172A] mt-1">
                @ViewBag.OccupancyRate.ToString("0.0")%
            </h3>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 bg-white p-8 rounded-xl shadow-sm border border-slate-200">
            <div class="flex justify-between items-center mb-8">
                <h4 class="font-h2 text-h2 text-[#0F172A]">Biểu đồ xu hướng doanh thu 6 tháng qua</h4>
                <div class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-secondary"></span>
                    <span class="text-label-md text-on-surface-variant">Doanh thu</span>
                </div>
            </div>
            <div class="relative h-[300px] w-full">
                <svg class="w-full h-full" preserveaspectratio="none" viewbox="0 0 800 300">
                    <path d="M0,250 Q100,220 200,240 T400,150 T600,100 T800,50" fill="none" stroke="#3B82F6" stroke-linecap="round" stroke-width="4"></path>
                    <path d="M0,250 Q100,220 200,240 T400,150 T600,100 T800,50 L800,300 L0,300 Z" fill="url(#grad1)" opacity="0.1"></path>
                    <defs>
                        <lineargradient id="grad1" x1="0%" x2="0%" y1="0%" y2="100%">
                            <stop offset="0%" style="stop-color: #3b82f6; stop-opacity: 1"></stop>
                            <stop offset="100%" style="stop-color: #3b82f6; stop-opacity: 0"></stop>
                        </lineargradient>
                    </defs>
                </svg>
            </div>
        </div>
        <div class="bg-white p-8 rounded-xl shadow-sm border border-slate-200">
            <h4 class="font-h2 text-h2 text-[#0F172A] mb-8">Phân bổ Khách hàng</h4>
            <div class="flex flex-col items-center">
                <div class="relative w-48 h-48 mb-8">
                    <svg class="w-full h-full transform -rotate-90">
                        <circle class="text-slate-100" cx="96" cy="96" fill="transparent" r="80" stroke="currentColor" stroke-width="24"></circle>
                        <circle class="text-secondary" cx="96" cy="96" fill="transparent" r="80" stroke="currentColor" stroke-dasharray="502" stroke-dashoffset="150" stroke-linecap="round" stroke-width="24"></circle>
                        <circle class="text-orange-400" cx="96" cy="96" fill="transparent" r="80" stroke="currentColor" stroke-dasharray="502" stroke-dashoffset="400" stroke-linecap="round" stroke-width="24"></circle>
                    </svg>
                    <div class="absolute inset-0 flex flex-col items-center justify-center">
                        <span class="text-2xl font-bold text-[#0F172A]">@ViewBag.TotalBookings</span>
                        <span class="text-[12px] text-on-surface-variant font-medium">Tổng Đơn</span>
                    </div>
                </div>
                <div class="w-full space-y-4">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <span class="w-3 h-3 rounded-full bg-secondary"></span>
                            <span class="text-body-md text-on-surface">Khách cũ quay lại</span>
                        </div>
                        <span class="text-body-md font-bold text-[#0F172A]">65%</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <span class="w-3 h-3 rounded-full bg-orange-400"></span>
                            <span class="text-body-md text-on-surface">Khách mới</span>
                        </div>
                        <span class="text-body-md font-bold text-[#0F172A]">35%</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden mb-8">
        <div class="px-8 py-6 border-b border-slate-100 flex justify-between items-center">
            <h4 class="font-h2 text-h2 text-[#0F172A]">Chi tiết doanh thu theo Điểm giao xe</h4>
            <button class="text-secondary font-semibold text-sm hover:underline flex items-center gap-1">
                Xem tất cả chi nhánh
                <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </button>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="bg-slate-50">
                        <th class="px-8 py-4 text-[11px] font-bold text-slate-500 uppercase tracking-widest">Tên chi nhánh</th>
                        <th class="px-8 py-4 text-[11px] font-bold text-slate-500 uppercase tracking-widest">Địa chỉ</th>
                        <th class="px-8 py-4 text-[11px] font-bold text-slate-500 uppercase tracking-widest text-center">Số lượng đơn</th>
                        <th class="px-8 py-4 text-[11px] font-bold text-slate-500 uppercase tracking-widest text-right">Doanh thu (VNĐ)</th>
                        <th class="px-8 py-4 text-[11px] font-bold text-slate-500 uppercase tracking-widest text-right">Tăng trưởng</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var item in ViewBag.BranchStats)
                    {
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-8 py-5 font-semibold text-secondary">
                                <a href="#" class="hover:underline">@item.BranchName</a>
                            </td>
                            <td class="px-8 py-5 text-on-surface-variant text-sm">@item.Address</td>
                            <td class="px-8 py-5 text-center font-medium">@item.BookingCount</td>
                            <td class="px-8 py-5 text-right font-bold text-[#0F172A]">@item.Revenue.ToString("N0")</td>
                            <td class="px-8 py-5 text-right">
                                @if (item.Growth > 0)
                                {
                                    <span class="text-green-600 font-bold text-sm">+@item.Growth%</span>
                                }
                                else if (item.Growth < 0)
                                {
                                    <span class="text-red-500 font-bold text-sm">@item.Growth%</span>
                                }
                                else
                                {
                                    <span class="text-slate-500 font-bold text-sm">0%</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>