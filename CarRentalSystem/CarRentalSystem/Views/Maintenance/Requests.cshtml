@model IEnumerable<CarRentalSystem.Models.MaintenanceLog>
@using CarRentalSystem.Constants
@{
    ViewData["Title"] = "Duyệt yêu cầu bảo dưỡng";
    Layout = "_AdminLayout";
}

<div class="space-y-6">
    <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
            <h1 class="font-h1 text-h1 text-primary">Yêu cầu bảo dưỡng</h1>
            <p class="text-slate-500 text-sm mt-1">Duyệt các yêu cầu bảo dưỡng từ nhân viên</p>
        </div>
    </header>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="p-4 rounded-lg bg-emerald-50 border border-emerald-200 text-emerald-800 flex items-center gap-3">
            <span class="material-symbols-outlined text-emerald-600">check_circle</span>
            <p class="font-medium text-sm">@TempData["SuccessMessage"]</p>
        </div>
    }

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <table class="w-full text-left text-sm whitespace-nowrap">
            <thead class="bg-slate-50 border-b border-slate-200 text-slate-500 uppercase text-xs font-semibold">
                <tr>
                    <th class="px-6 py-4">Xe</th>
                    <th class="px-6 py-4">Nhân viên yêu cầu</th>
                    <th class="px-6 py-4">Loại / Chi phí</th>
                    <th class="px-6 py-4">Ngày yêu cầu</th>
                    <th class="px-6 py-4">Mô tả</th>
                    <th class="px-6 py-4 text-right">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-6 py-4">
                                <div class="font-medium text-primary">@item.Vehicle.VehicleName</div>
                                <div class="text-slate-500 text-xs">@item.Vehicle.LicensePlate</div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <img src="@(item.Staff?.UserProfile?.AvatarUrl ?? "/images/default-avatar.png")" class="w-8 h-8 rounded-full object-cover border border-slate-200" />
                                    <div>
                                        <div class="font-medium">@item.Staff?.UserProfile?.FullName</div>
                                        <div class="text-xs text-slate-500">@item.Staff?.StaffCode</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <div>@item.MaintenanceType</div>
                                <div class="font-medium text-emerald-600">@item.Cost.ToString("N0") đ</div>
                            </td>
                            <td class="px-6 py-4">
                                @item.MaintenanceDate.ToString("dd/MM/yyyy")
                            </td>
                            <td class="px-6 py-4">
                                <div class="max-w-[200px] truncate" title="@item.Description">@item.Description</div>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <form asp-controller="Maintenance" asp-action="ApproveRequest" asp-route-id="@item.MaintenanceId" method="post" class="inline">
                                        <button type="submit" class="px-3 py-1.5 bg-emerald-50 text-emerald-700 hover:bg-emerald-100 rounded font-medium text-xs border border-emerald-200 transition-colors">Duyệt</button>
                                    </form>
                                    <button type="button" onclick="openRejectModal(@item.MaintenanceId)" class="px-3 py-1.5 bg-rose-50 text-rose-700 hover:bg-rose-100 rounded font-medium text-xs border border-rose-200 transition-colors">Từ chối</button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="px-6 py-8 text-center text-slate-500">
                            Không có yêu cầu bảo dưỡng nào đang chờ duyệt.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Reject Modal -->
<div id="rejectModal" class="fixed inset-0 bg-slate-900/50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md overflow-hidden transform scale-95 opacity-0 transition-all duration-200" id="rejectModalContent">
        <form asp-controller="Maintenance" asp-action="RejectRequest" method="post">
            <input type="hidden" id="rejectMaintenanceId" name="id" value="" />
            <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
                <h3 class="font-bold text-lg text-slate-800">Từ chối yêu cầu</h3>
                <button type="button" onclick="closeRejectModal()" class="text-slate-400 hover:text-slate-600">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div class="p-6 space-y-4">
                <p class="text-sm text-slate-600">Vui lòng nhập lý do từ chối yêu cầu bảo dưỡng này. Lý do sẽ được gửi đến nhân viên.</p>
                <div>
                    <textarea name="reason" rows="3" class="w-full p-3 rounded-lg border border-slate-200 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-rose-500/20 focus:border-rose-500 outline-none font-body-md text-sm resize-none" placeholder="Nhập lý do từ chối..." required></textarea>
                </div>
            </div>
            <div class="px-6 py-4 border-t border-slate-100 bg-slate-50 flex justify-end gap-3">
                <button type="button" onclick="closeRejectModal()" class="px-4 py-2 text-slate-600 font-medium text-sm hover:bg-slate-200 rounded-lg transition-colors">Hủy</button>
                <button type="submit" class="px-4 py-2 bg-rose-600 text-white font-medium text-sm hover:bg-rose-700 rounded-lg transition-colors shadow-sm">Xác nhận từ chối</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openRejectModal(id) {
        document.getElementById('rejectMaintenanceId').value = id;
        const modal = document.getElementById('rejectModal');
        const content = document.getElementById('rejectModalContent');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        setTimeout(() => {
            content.classList.remove('scale-95', 'opacity-0');
            content.classList.add('scale-100', 'opacity-100');
        }, 10);
    }

    function closeRejectModal() {
        const modal = document.getElementById('rejectModal');
        const content = document.getElementById('rejectModalContent');
        content.classList.remove('scale-100', 'opacity-100');
        content.classList.add('scale-95', 'opacity-0');
        setTimeout(() => {
            modal.classList.remove('flex');
            modal.classList.add('hidden');
        }, 200);
    }
</script>
