@model IEnumerable<CarRentalSystem.Models.MaintenanceLog>
@using CarRentalSystem.Constants
@{
    ViewData["Title"] = "Nhiệm vụ của tôi";
    Layout = "_StaffLayout";
}

<div class="space-y-8 mt-4">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
            <h1 class="text-2xl font-bold text-primary mb-1">Nhiệm vụ bảo dưỡng</h1>
            <p class="text-sm text-slate-500 font-medium">Danh sách các xe được phân công sửa chữa / bảo dưỡng</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="bg-white p-12 rounded-2xl border border-slate-200 text-center shadow-sm">
            <span class="material-symbols-outlined text-6xl text-slate-300 mb-4">task_alt</span>
            <h3 class="text-lg font-bold text-slate-700">Tuyệt vời! Bạn không có nhiệm vụ nào tồn đọng.</h3>
            <p class="text-slate-500 mt-2">Khi có quản lý phân công bảo dưỡng xe, nhiệm vụ sẽ xuất hiện tại đây.</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var task in Model)
            {
                string borderClass = "border-slate-200";
                if (task.Status == MaintenanceStatus.Pending) borderClass = "border-amber-400 shadow-amber-500/20";
                else if (task.Status == MaintenanceStatus.Requested) borderClass = "border-blue-400 shadow-blue-500/20";
                else if (task.Status == MaintenanceStatus.Rejected) borderClass = "border-rose-400 shadow-rose-500/20";

                <div class="bg-white rounded-2xl shadow-sm border @borderClass overflow-hidden flex flex-col hover:shadow-md transition-shadow relative">
                    @if (task.Status == MaintenanceStatus.Pending)
                    {
                        <div class="absolute top-0 right-0 bg-amber-100 text-amber-700 px-3 py-1 rounded-bl-xl text-xs font-bold shadow-sm">
                            Chờ xử lý
                        </div>
                    }
                    else if (task.Status == MaintenanceStatus.Completed)
                    {
                        <div class="absolute top-0 right-0 bg-emerald-100 text-emerald-700 px-3 py-1 rounded-bl-xl text-xs font-bold shadow-sm">
                            Đã hoàn thành
                        </div>
                    }
                    else if (task.Status == MaintenanceStatus.Requested)
                    {
                        <div class="absolute top-0 right-0 bg-blue-100 text-blue-700 px-3 py-1 rounded-bl-xl text-xs font-bold shadow-sm">
                            Đang chờ duyệt
                        </div>
                    }
                    else if (task.Status == MaintenanceStatus.Rejected)
                    {
                        <div class="absolute top-0 right-0 bg-rose-100 text-rose-700 px-3 py-1 rounded-bl-xl text-xs font-bold shadow-sm">
                            Bị từ chối
                        </div>
                    }

                    <div class="p-6">
                        <div class="flex items-center gap-4 mb-4">
                            <div class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center text-slate-500">
                                <span class="material-symbols-outlined text-2xl">directions_car</span>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg text-slate-800">@task.Vehicle.VehicleName</h3>
                                <p class="text-xs font-semibold text-slate-500 bg-slate-100 px-2 py-0.5 rounded inline-block mt-1">@task.Vehicle.LicensePlate</p>
                            </div>
                        </div>

                        <div class="space-y-3 mb-6">
                            <div class="flex justify-between items-center text-sm border-b border-slate-100 pb-2">
                                <span class="text-slate-500 font-medium">Hạng mục:</span>
                                <span class="font-bold text-slate-700">@task.MaintenanceType</span>
                            </div>
                            <div class="flex justify-between items-center text-sm border-b border-slate-100 pb-2">
                                <span class="text-slate-500 font-medium">Ngày lập phiếu:</span>
                                <span class="font-bold text-slate-700">@task.MaintenanceDate.ToString("dd/MM/yyyy")</span>
                            </div>
                            <div class="flex justify-between items-center text-sm border-b border-slate-100 pb-2">
                                <span class="text-slate-500 font-medium">Chi phí dự kiến:</span>
                                <span class="font-bold text-secondary">@task.Cost.ToString("N0") VNĐ</span>
                            </div>
                            <div class="text-sm">
                                <span class="text-slate-500 font-medium block mb-1">Mô tả công việc:</span>
                                <p class="text-slate-700 bg-slate-50 p-3 rounded-lg text-xs leading-relaxed">@task.Description</p>
                            </div>
                        </div>

                        @if (task.Status == MaintenanceStatus.Pending)
                        {
                            <button type="button" onclick="document.getElementById('modal-@task.MaintenanceId').classList.remove('hidden')" class="w-full py-3 bg-emerald-600 text-white font-bold rounded-xl hover:bg-emerald-700 transition-colors shadow-md shadow-emerald-500/30 flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined">check_circle</span>
                                Đã hoàn thành
                            </button>

                            <!-- Confirm Modal -->
                            <div id="modal-@task.MaintenanceId" class="hidden fixed inset-0 z-[100] flex items-center justify-center bg-black/50 backdrop-blur-sm transition-opacity">
                                <div class="bg-white rounded-3xl p-6 md:p-8 max-w-sm w-full mx-4 shadow-2xl transform transition-all">
                                    <div class="flex items-center justify-center w-16 h-16 rounded-full bg-emerald-50 border-4 border-emerald-100 text-emerald-600 mx-auto mb-5">
                                        <span class="material-symbols-outlined text-3xl">task_alt</span>
                                    </div>
                                    <h3 class="text-xl font-bold text-slate-800 text-center mb-2">Xác nhận hoàn thành</h3>
                                    <p class="text-slate-500 text-sm text-center mb-8 leading-relaxed">Bạn có chắc chắn đã hoàn thành việc sửa chữa và muốn bàn giao chiếc <span class="font-bold text-slate-700">@task.Vehicle.VehicleName</span> này?</p>
                                    
                                    <div class="flex gap-3">
                                        <button type="button" onclick="document.getElementById('modal-@task.MaintenanceId').classList.add('hidden')" class="flex-1 py-3 bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold rounded-xl transition-colors">
                                            Hủy bỏ
                                        </button>
                                        <form asp-action="CompleteTask" method="post" class="flex-1">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@task.MaintenanceId" />
                                            <button type="submit" class="w-full py-3 bg-emerald-600 hover:bg-emerald-700 text-white font-bold rounded-xl shadow-md shadow-emerald-500/20 transition-colors">
                                                Xác nhận
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>
