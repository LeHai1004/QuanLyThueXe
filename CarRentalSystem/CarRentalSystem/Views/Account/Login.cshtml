@{
    ViewData["Title"] = "Đăng nhập & Đăng ký";
    Layout = "_Layout";
}

<style>
    .tab-active {
        border-bottom: 2px solid #1e3a8a;
        color: #1e3a8a;
        font-weight: 600;
    }

    .tab-inactive {
        color: #757682;
    }

    .material-symbols-outlined {
        font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24;
    }
</style>

<main class="flex-grow flex items-center justify-center py-16 px-4 md:px-8 bg-[#f8f9ff]">
    <div class="w-full max-w-[1100px] bg-white rounded-3xl overflow-hidden shadow-[0_20px_50px_rgba(30,58,138,0.08)] border border-slate-100 flex flex-col md:flex-row min-h-[700px]">

        <!-- Left Side - Visual -->
        <section class="relative hidden md:block md:w-1/2 lg:w-3/5 overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-tr from-primary/80 to-transparent z-10"></div>
            <img class="absolute inset-0 w-full h-full object-cover"
                 src="https://lh3.googleusercontent.com/aida-public/AB6AXuBoqtgI4z3aksWCqdqb_DYF6Yv4V1M13PtpQmade0fbjF_O0B2XEoifkwRx6WAGJJP1N6IvItWRF6jMhdBxLs3E7L594u8Sr0nSklrHui-J-TxI5ujZasykUXFP7uubnehAHfDp9frWXNYh-0iDMNY7fGDV1oLdqK7X6ZKufYdv2cipZ08h_EIW3rQGCaytvzN4fNEjuu900Zry0R6jvToTOHcjhL5gTj0Wpsi6ngYh7UAs8VFkX-DVKD6IArUk6--m-9UMzHnMPl1l"
                 alt="Luxury Car" />

            <div class="absolute bottom-12 left-12 z-20 text-white max-w-md">
                <h2 class="text-4xl font-bold mb-4 leading-tight">Trải nghiệm hành trình đẳng cấp</h2>
                <p class="text-lg opacity-90">Khám phá bộ sưu tập những dòng xe sang trọng bậc nhất, mang lại sự tiện nghi và an toàn tuyệt đối cho mọi chuyến đi.</p>

                <div class="mt-8 flex items-center gap-4">
                    <div class="flex -space-x-3">
                        <img class="w-9 h-9 rounded-full border-2 border-white object-cover"
                             src="https://lh3.googleusercontent.com/aida-public/AB6AXuA7oMPJhkIvdpZY9VnkST5b6WMC3TlQHW2IfErAUrGPk4iPXvKY2PbPYQpcV6wlUVvdTE5KXHIY4J6rSRDFH3s65ghnejFwfdDehX0U-WYE3hFHibAPPRjkxgW-D6-MPqmvm3r6jU8_bgHClqLxX09wA-fTSijrqdeTmx3uYxzLU1HJ_mhebbffHO1JgbLlWsirhXbI97wur3JPUoJ6iyew5N5gcVEIknR-CUGTffyrzUBn0-eZK5QCuk01iv9JvU8aVHr13JX8huKa" />
                        <img class="w-9 h-9 rounded-full border-2 border-white object-cover"
                             src="https://lh3.googleusercontent.com/aida-public/AB6AXuBXK2o7IvgR4PEw406xx4yXWUdDAGExKK6UJ0HrN7NbQXzXCQ0iEYsGhG2I_R4sGKZ3zY0uq6jDYWux_PBiMVlVcsLylXDIErV1EUwG_PF93VQavU5VQRa4Ja5Qr5AMFFC1oe2BhjATFeFNETlwHqO0rGslohSncgrxBfxEGsJd5mxpTwYTP7lq0CK-GcF0cMNqDWVpy97jeH-E-6Mu4pjtzUO1vNI_4kRtlm1jolXHWqHxDj3EqKfdJSGcc-0Z_xSILlkzwD4sCnmw" />
                    </div>
                    <span class="text-sm font-medium text-white/90">+5,000 khách hàng tin dùng</span>
                </div>
            </div>
        </section>

        <!-- Right Side - Form -->
        <section class="w-full md:w-1/2 lg:w-2/5 p-8 md:p-12 flex flex-col justify-center bg-white">
            <div class="mb-10 text-center md:text-left">
                <h1 class="text-3xl font-bold text-[#00236f] mb-2">Chào mừng trở lại</h1>
                <p class="text-slate-600">Đăng nhập để quản lý các chuyến đi của bạn.</p>
            </div>

            <!-- Tab -->
            <div class="flex border-b border-slate-200 mb-8">
                <button class="flex-1 py-4 text-center font-semibold text-base transition-all tab-active" id="loginTab">Đăng nhập</button>
                <button class="flex-1 py-4 text-center font-semibold text-base transition-all tab-inactive" id="registerTab">Đăng ký</button>
            </div>

            <!-- Login Form -->
            <form id="loginForm" asp-action="Login" method="post" class="space-y-6 block">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="p-4 bg-emerald-50 text-emerald-600 border border-emerald-200 rounded-2xl text-sm flex items-center gap-3">
                        <span class="material-symbols-outlined">check_circle</span>
                        @TempData["SuccessMessage"]
                    </div>
                }
                @if (ViewBag.LoginError != null)
                {
                    <div class="p-4 bg-red-50 text-red-600 border border-red-200 rounded-2xl text-sm flex items-center gap-3">
                        <span class="material-symbols-outlined">error</span>
                        @ViewBag.LoginError
                    </div>
                }

                <div class="space-y-2">
                    <label class="block text-sm font-semibold text-slate-700">Email hoặc Số điện thoại</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">mail</span>
                        <input name="email" type="text"
                               class="w-full pl-12 pr-4 py-4 rounded-2xl border border-slate-200 focus:border-[#00236f] focus:ring-2 focus:ring-[#00236f]/20 bg-slate-50 hover:bg-white transition-all"
                               placeholder="email@example.com" required />
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="block text-sm font-semibold text-slate-700">Mật khẩu</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">lock</span>
                        <input name="password" type="password"
                               class="w-full pl-12 pr-4 py-4 rounded-2xl border border-slate-200 focus:border-[#00236f] focus:ring-2 focus:ring-[#00236f]/20 bg-slate-50 hover:bg-white transition-all"
                               placeholder="••••••••" required />
                    </div>
                </div>

                <div class="flex items-center justify-between text-sm">
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" class="w-4 h-4 accent-[#00236f]" />
                        <span class="text-slate-600">Ghi nhớ đăng nhập</span>
                    </label>
                    <a href="#" class="text-primary hover:underline">Quên mật khẩu?</a>
                </div>

                <button type="submit"
                        class="w-full bg-[#00236f] hover:bg-[#001a42] text-white py-4 rounded-2xl font-bold text-base transition-all active:scale-[0.98] shadow-lg flex items-center justify-center gap-2">
                    Đăng nhập
                    <span class="material-symbols-outlined">arrow_forward</span>
                </button>
            </form>

            <!-- Register Form -->
            <form id="registerForm" asp-action="Register" method="post" class="space-y-5 hidden">
                @if (ViewBag.RegisterError != null)
                {
                    <div class="p-4 bg-red-50 text-red-600 border border-red-200 rounded-2xl text-sm flex items-center gap-3">
                        <span class="material-symbols-outlined">error</span>
                        @ViewBag.RegisterError
                    </div>
                }

                <div class="space-y-2">
                    <label class="block text-sm font-semibold text-slate-700">Họ và tên</label>
                    <input name="fullName" type="text" required
                           class="w-full px-4 py-4 rounded-2xl border border-slate-200 focus:border-[#00236f] focus:ring-2 focus:ring-[#00236f]/20 bg-slate-50 hover:bg-white transition-all"
                           placeholder="Nguyễn Văn A" />
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-2">
                        <label class="block text-sm font-semibold text-slate-700">Số điện thoại</label>
                        <input name="phoneNumber" type="tel" required
                               class="w-full px-4 py-4 rounded-2xl border border-slate-200 focus:border-[#00236f] focus:ring-2 focus:ring-[#00236f]/20 bg-slate-50 hover:bg-white transition-all"
                               placeholder="0901 234 567" />
                    </div>
                    <div class="space-y-2">
                        <label class="block text-sm font-semibold text-slate-700">Số CCCD</label>
                        <input name="nationalId" type="text" required
                               class="w-full px-4 py-4 rounded-2xl border border-slate-200 focus:border-[#00236f] focus:ring-2 focus:ring-[#00236f]/20 bg-slate-50 hover:bg-white transition-all"
                               placeholder="012345678912" />
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="block text-sm font-semibold text-slate-700">Email</label>
                    <input name="email" type="email" required
                           class="w-full px-4 py-4 rounded-2xl border border-slate-200 focus:border-[#00236f] focus:ring-2 focus:ring-[#00236f]/20 bg-slate-50 hover:bg-white transition-all"
                           placeholder="example@gmail.com" />
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-2">
                        <label class="block text-sm font-semibold text-slate-700">Mật khẩu</label>
                        <input name="password" type="password" required
                               class="w-full px-4 py-4 rounded-2xl border border-slate-200 focus:border-[#00236f] focus:ring-2 focus:ring-[#00236f]/20 bg-slate-50 hover:bg-white transition-all"
                               placeholder="••••••••" />
                    </div>
                    <div class="space-y-2">
                        <label class="block text-sm font-semibold text-slate-700">Nhập lại mật khẩu</label>
                        <input name="confirmPassword" type="password" required
                               class="w-full px-4 py-4 rounded-2xl border border-slate-200 focus:border-[#00236f] focus:ring-2 focus:ring-[#00236f]/20 bg-slate-50 hover:bg-white transition-all"
                               placeholder="••••••••" />
                    </div>
                </div>

                <button type="submit"
                        class="w-full bg-[#00236f] hover:bg-[#001a42] text-white py-4 rounded-2xl font-bold text-base transition-all active:scale-[0.98] shadow-lg mt-4 flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined">person_add</span>
                    Đăng ký tài khoản
                </button>
            </form>
        </section>
    </div>
</main>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const loginTab = document.getElementById("loginTab");
            const registerTab = document.getElementById("registerTab");
            const loginForm = document.getElementById("loginForm");
            const registerForm = document.getElementById("registerForm");

            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.get('tab') === 'register' || '@(ViewBag.RegisterError != null)' === 'True') {
                registerTab.classList.replace("tab-inactive", "tab-active");
                loginTab.classList.replace("tab-active", "tab-inactive");
                registerForm.classList.remove("hidden");
                loginForm.classList.add("hidden");
            }

            loginTab.addEventListener("click", () => {
                loginTab.classList.replace("tab-inactive", "tab-active");
                registerTab.classList.replace("tab-active", "tab-inactive");
                loginForm.classList.remove("hidden");
                registerForm.classList.add("hidden");
            });

            registerTab.addEventListener("click", () => {
                registerTab.classList.replace("tab-inactive", "tab-active");
                loginTab.classList.replace("tab-active", "tab-inactive");
                registerForm.classList.remove("hidden");
                loginForm.classList.add("hidden");
            });
        });
    </script>
}