@model CarRentalSystem.Models.Staff
@{
    ViewData["Title"] = "Chi tiết Nhân viên";
    Layout = "_AdminLayout";
    
    var fullName = Model.UserProfile?.FullName ?? "Unknown";
    var nameParts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
    string initials = nameParts.Length > 1
        ? (nameParts[0][0].ToString() + nameParts[^1][0].ToString()).ToUpper()
        : fullName.Substring(0, Math.Min(2, fullName.Length)).ToUpper();
}

<div class="space-y-8 mt-4">
    <div class="flex justify-between items-end mb-6">
        <div>
            <a href="/Staff/Index" class="flex items-center text-sm font-bold text-slate-500 hover:text-[#316bf3] transition-colors mb-2 w-max">
                <span class="material-symbols-outlined text-[16px] mr-1">arrow_back</span>
                Quay lại danh sách
            </a>
            <h2 class="font-h1 text-2xl font-bold text-[#1E293B] mb-1">
                Chi tiết Nhân viên NV-@Model.StaffId.ToString("D4")
            </h2>
        </div>
        @if (Model.IsActive)
        {
            <span class="bg-emerald-50 text-emerald-600 border border-emerald-200 px-4 py-2 rounded-full text-[13px] font-bold">Đang làm việc</span>
        }
        else
        {
            <span class="bg-slate-100 text-slate-600 border border-slate-200 px-4 py-2 rounded-full text-[13px] font-bold">Đã nghỉ việc</span>
        }
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Thông tin cá nhân -->
        <div class="col-span-1 bg-white rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.05)] border border-slate-100 overflow-hidden">
            <div class="p-8 flex flex-col items-center border-b border-slate-100 bg-slate-50/50">
                <div class="w-24 h-24 rounded-full overflow-hidden mb-4 border-4 border-white shadow-md flex items-center justify-center font-bold text-3xl bg-blue-100 text-blue-700">
                    @initials
                </div>
                <h3 class="font-bold text-xl text-[#1E293B] text-center">@fullName</h3>
                <p class="text-sm font-medium text-slate-500 mt-1">@(Model.Position ?? "Nhân viên")</p>
            </div>
            <div class="p-8 space-y-6">
                <div>
                    <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-1">Email</p>
                    <p class="text-[15px] font-semibold text-slate-800">@(Model.UserProfile?.Account?.Email ?? "Chưa cập nhật Email")</p>
                </div>
                <div>
                    <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-1">Số điện thoại</p>
                    <p class="text-[15px] font-semibold text-slate-800">@(Model.UserProfile?.PhoneNumber ?? "Chưa cập nhật")</p>
                </div>
                <div>
                    <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-1">Giới tính & Sinh nhật</p>
                    <p class="text-[15px] font-semibold text-slate-800">
                        @(Model.UserProfile?.Gender ?? "N/A") 
                        @if(Model.UserProfile?.DateOfBirth != null)
                        {
                            <span> - @Model.UserProfile.DateOfBirth.Value.ToString("dd/MM/yyyy")</span>
                        }
                    </p>
                </div>
                <div>
                    <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-1">Địa chỉ</p>
                    <p class="text-[15px] font-semibold text-slate-800 leading-relaxed">
                        @(Model.UserProfile?.StreetAddress ?? "")
                        @(Model.UserProfile?.Ward != null ? ", " + Model.UserProfile.Ward : "")
                        @(Model.UserProfile?.District != null ? ", " + Model.UserProfile.District : "")
                        @(Model.UserProfile?.City != null ? ", " + Model.UserProfile.City : "")
                    </p>
                </div>
            </div>
        </div>

        <!-- Thông tin Công việc -->
        <div class="col-span-1 md:col-span-2 space-y-8">
            <div class="bg-white rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.05)] border border-slate-100 overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50">
                    <h3 class="font-bold text-[#1E293B]">Thông tin Công việc</h3>
                </div>
                <div class="p-6 grid grid-cols-2 gap-8">
                    <div>
                        <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-1">Mã Nhân viên</p>
                        <p class="text-[15px] font-bold text-[#316bf3]">@(Model.StaffCode ?? "Chưa cấp")</p>
                    </div>
                    <div>
                        <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-1">Phòng ban</p>
                        <p class="text-[15px] font-semibold text-slate-800">@(Model.Department ?? "Chưa cập nhật")</p>
                    </div>
                    <div>
                        <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-1">Chi nhánh</p>
                        <p class="text-[15px] font-semibold text-slate-800">@(Model.Branch ?? "Chưa cập nhật")</p>
                    </div>
                    <div>
                        <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-1">Ngày vào làm</p>
                        <p class="text-[15px] font-semibold text-slate-800">@(Model.HireDate?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
