@using CarRentalSystem.Helpers
@model IEnumerable<CarRentalSystem.Models.Staff>
@{
    ViewData["Title"] = "Danh sách Nhân viên";
    Layout = "_AdminLayout";

    // Mảng màu nền cho Avatar chữ cái
    string[] avatarColors = { "bg-blue-100 text-blue-700", "bg-emerald-100 text-emerald-700", "bg-amber-100 text-amber-700", "bg-purple-100 text-purple-700", "bg-rose-100 text-rose-700" };
}

<div class="space-y-8 mt-4">
    <div>
        <h2 class="font-h1 text-h1 text-primary">Danh sách Nhân viên</h2>
        <p class="text-on-surface-variant font-body-md mt-1">Quản lý nhân sự và phân quyền hệ thống</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200">
            <h3 class="font-h2 text-h2 mb-4 text-[#1E293B]">Hoạt động nổi bật</h3>
            <div class="space-y-4">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-lg bg-blue-50 flex items-center justify-center text-blue-600">
                        <span class="material-symbols-outlined text-2xl">verified_user</span>
                    </div>
                    <div class="flex-1">
                        <p class="font-bold text-[#1E293B]">Đã duyệt 12 đơn xe</p>
                        <p class="text-[12px] text-slate-500">Hôm nay • Phòng Kinh doanh</p>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-lg bg-orange-50 flex items-center justify-center text-orange-600">
                        <span class="material-symbols-outlined text-2xl">build</span>
                    </div>
                    <div class="flex-1">
                        <p class="font-bold text-[#1E293B]">Hoàn tất bảo dưỡng</p>
                        <p class="text-[12px] text-slate-500">Hôm qua • Đội Kỹ thuật</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200 flex flex-col justify-between">
            <div>
                <h3 class="font-h2 text-h2 mb-6 text-[#1E293B]">Thống kê nhanh</h3>
                <div class="space-y-6">
                    <div>
                        <p class="text-slate-500 text-sm mb-1 font-semibold uppercase tracking-wider">Tổng doanh thu</p>
                        <div class="flex items-baseline gap-2">
                            <span class="text-3xl font-bold text-primary">@CurrencyHelper.FormatVnd(ViewBag.TotalRevenue)</span>
                            <span class="text-sm font-medium text-slate-500">VNĐ</span>
                        </div>
                    </div>
                    <div>
                        <p class="text-slate-500 text-sm mb-1 font-semibold uppercase tracking-wider">Tổng nhân sự</p>
                        <div class="flex items-baseline gap-2">
                            <span class="text-3xl font-black text-primary">@Model.Count()</span>
                            <span class="text-sm font-medium text-slate-500">Thành viên</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200">
            <h3 class="font-h2 text-h2 mb-4 text-[#1E293B]">Thông báo nội bộ</h3>
            <div class="space-y-2">
                <div class="flex gap-4 p-3 rounded-lg hover:bg-slate-50 transition-colors cursor-pointer border border-transparent hover:border-slate-100">
                    <div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center text-blue-600 shrink-0">
                        <span class="material-symbols-outlined">campaign</span>
                    </div>
                    <div>
                        <p class="text-sm font-bold text-[#1E293B]">Cập nhật chính sách nhân sự 2026</p>
                        <p class="text-[12px] text-slate-500 mt-0.5">2 giờ trước • Quản trị hệ thống</p>
                    </div>
                </div>
                <div class="flex gap-4 p-3 rounded-lg hover:bg-slate-50 transition-colors cursor-pointer border border-transparent hover:border-slate-100">
                    <div class="w-10 h-10 rounded-full bg-red-50 flex items-center justify-center text-red-500 shrink-0">
                        <span class="material-symbols-outlined">admin_panel_settings</span>
                    </div>
                    <div>
                        <p class="text-sm font-bold text-[#1E293B]">Đánh giá KPI quý II/2026</p>
                        <p class="text-[12px] text-slate-500 mt-0.5">5 giờ trước • Ban Giám đốc</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-white p-4 rounded-xl shadow-sm border border-slate-200 flex flex-wrap items-center justify-between gap-4">
        <form method="get" action="/Staff/Index" class="flex flex-wrap items-center gap-3">
            <div class="relative w-72">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg">search</span>
                <input name="search" value="@ViewBag.SearchString" class="w-full pl-10 pr-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-secondary/20 focus:border-secondary outline-none transition-all" placeholder="Tìm tên, mã NV hoặc Email..." type="text" />
            </div>
            <select name="department" class="bg-slate-50 border border-slate-200 rounded-lg text-sm px-4 py-2 focus:ring-2 focus:ring-secondary/20 outline-none cursor-pointer">
                <option value="Tất cả" selected="@(ViewBag.CurrentDepartment == "Tất cả" || string.IsNullOrEmpty(ViewBag.CurrentDepartment) ? "selected" : null)">Phòng ban: Tất cả</option>
                <option value="Kinh doanh" selected="@(ViewBag.CurrentDepartment == "Kinh doanh" ? "selected" : null)">Kinh doanh</option>
                <option value="Vận hành" selected="@(ViewBag.CurrentDepartment == "Vận hành" ? "selected" : null)">Vận hành</option>
                <option value="Kỹ thuật" selected="@(ViewBag.CurrentDepartment == "Kỹ thuật" ? "selected" : null)">Kỹ thuật</option>
            </select>
            <button type="submit" class="px-5 py-2 bg-slate-800 text-white rounded-lg font-bold text-sm hover:bg-slate-900 transition-all shadow-md">Lọc</button>
            @if (!string.IsNullOrEmpty(ViewBag.SearchString) || !string.IsNullOrEmpty(ViewBag.CurrentDepartment))
            {
                <a href="/Staff/Index" class="px-3 py-2 text-slate-500 hover:text-slate-800 font-bold text-sm transition-colors">Xóa lọc</a>
            }
        </form>
        <a href="/Staff/Create" class="bg-secondary text-white px-4 py-2 rounded-lg font-bold text-sm flex items-center gap-1.5 hover:bg-blue-700 transition-all active:scale-95 shadow-md shadow-secondary/20">
            <span class="material-symbols-outlined text-[18px]">person_add</span>
            Thêm nhân viên mới
        </a>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead class="bg-slate-50 border-b border-slate-200">
                    <tr>
                        <th class="px-6 py-5 text-[12px] font-bold text-slate-500 uppercase tracking-widest">Mã NV</th>
                        <th class="px-6 py-5 text-[12px] font-bold text-slate-500 uppercase tracking-widest">Nhân viên</th>
                        <th class="px-6 py-5 text-[12px] font-bold text-slate-500 uppercase tracking-widest">Liên hệ</th>
                        <th class="px-6 py-5 text-[12px] font-bold text-slate-500 uppercase tracking-widest">Phòng ban/Vai trò</th>
                        <th class="px-6 py-5 text-[12px] font-bold text-slate-500 uppercase tracking-widest text-center">Trạng thái</th>
                        <th class="px-6 py-5 text-[12px] font-bold text-slate-500 uppercase tracking-widest text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @{
                        int colorIndex = 0;
                    }
                    @foreach (var item in Model)
                    {
                        // Logic tạo Avatar chữ cái
                        var fullName = item.UserProfile?.FullName ?? "Unknown";
                        var nameParts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                        string initials = nameParts.Length > 1
                            ? (nameParts[0][0].ToString() + nameParts[^1][0].ToString()).ToUpper()
                            : fullName.Substring(0, Math.Min(2, fullName.Length)).ToUpper();

                        string colorClass = avatarColors[colorIndex % avatarColors.Length];
                        colorIndex++;

                        <tr class="hover:bg-slate-50/50 transition-colors group">
                            <td class="px-6 py-5 font-mono text-sm font-bold text-[#316bf3]">
                                NV-@item.StaffId.ToString("D4")
                            </td>
                            <td class="px-6 py-5">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-sm @colorClass">
                                        @initials
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="font-bold text-[#1E293B]">@fullName</span>
                                        <span class="text-[12px] text-slate-500">Tham gia: @(item.UserProfile?.CreatedAt.ToVnDate() ?? "N/A")</span>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-5">
                                <div class="flex flex-col">
                                    <span class="text-sm font-semibold text-[#1E293B]">@(item.UserProfile?.Account?.Email ?? "N/A")</span>
                                    <span class="text-[13px] text-slate-500">@(item.UserProfile?.PhoneNumber ?? "N/A")</span>
                                </div>
                            </td>
                            <td class="px-6 py-5">
                                <span class="bg-slate-100 text-slate-600 px-3 py-1 rounded-full text-[12px] font-bold border border-slate-200">@(item.Position ?? "Nhân viên") - @(item.Department ?? "Chưa phân bổ")</span>
                            </td>
                            <td class="px-6 py-5 text-center">
                                <span class="bg-emerald-50 text-emerald-600 border border-emerald-200 px-3 py-1 rounded-full text-[11px] font-bold whitespace-nowrap">Đang làm việc</span>
                            </td>
                            <td class="px-6 py-5 text-right">
                                <div class="flex justify-end gap-2">
                                    <a href="/Staff/Details/@item.StaffId" class="p-2 text-slate-400 hover:text-[#316bf3] hover:bg-blue-50 rounded-lg transition-colors inline-block" title="Chi tiết">
                                        <span class="material-symbols-outlined text-[20px]">visibility</span>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="px-6 py-4 flex items-center justify-between border-t border-slate-100 bg-white">
            <p class="text-sm font-medium text-slate-500">Hiển thị toàn bộ danh sách</p>
            <div class="flex items-center gap-2">
                <button class="px-4 py-2 border border-slate-200 rounded-lg text-sm font-medium hover:bg-slate-50 transition-colors text-slate-400 cursor-not-allowed">Trước</button>
                <button class="w-9 h-9 bg-secondary text-white rounded-lg font-bold shadow-md shadow-blue-500/20">1</button>
                <button class="px-4 py-2 border border-slate-200 rounded-lg text-sm font-medium hover:bg-slate-50 transition-colors text-slate-600">Tiếp</button>
            </div>
        </div>
    </div>
</div>