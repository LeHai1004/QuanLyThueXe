@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Thêm Nhân Viên Mới";
}

<div class="p-6">
    <div class="mb-6 flex items-center justify-between">
        <div>
            <h2 class="text-2xl font-bold text-slate-800">Thêm Nhân Viên Mới</h2>
            <p class="text-sm text-slate-500 mt-1">Điền thông tin chi tiết để tạo tài khoản nhân viên</p>
        </div>
        <a href="/Staff/Index" class="px-4 py-2 text-sm font-semibold text-slate-600 bg-white border border-slate-300 rounded-lg hover:bg-slate-50 transition-colors shadow-sm">
            Quay lại
        </a>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="mb-4 p-4 bg-red-50 border-l-4 border-red-500 text-red-700 rounded-r-lg text-sm">
            @ViewBag.Error
        </div>
    }

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 max-w-3xl mx-auto">
        <form method="post" action="/Staff/Create">
            @Html.AntiForgeryToken()
            
            <h3 class="text-lg font-bold text-slate-800 mb-4 pb-2 border-b border-slate-100">Thông tin đăng nhập</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1">Email <span class="text-red-500">*</span></label>
                    <input type="email" name="email" required class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-colors" placeholder="VD: nhanvien@company.com" />
                </div>
                <div></div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1">Mật khẩu <span class="text-red-500">*</span></label>
                    <input type="password" name="password" required class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-colors" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1">Xác nhận mật khẩu <span class="text-red-500">*</span></label>
                    <input type="password" name="confirmPassword" required class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-colors" />
                </div>
            </div>

            <h3 class="text-lg font-bold text-slate-800 mb-4 pb-2 border-b border-slate-100">Thông tin cá nhân & Công việc</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1">Họ và tên <span class="text-red-500">*</span></label>
                    <input type="text" name="fullName" required class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-colors" placeholder="Nguyễn Văn A" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1">Số điện thoại <span class="text-red-500">*</span></label>
                    <input type="text" name="phoneNumber" required class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-colors" placeholder="09xxxxxxxx" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1">Phòng ban</label>
                    <select name="department" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-colors">
                        <option value="Vận hành">Vận hành</option>
                        <option value="Kỹ thuật">Kỹ thuật</option>
                        <option value="Kế toán">Kế toán</option>
                        <option value="Chăm sóc khách hàng">Chăm sóc khách hàng</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1">Chức vụ</label>
                    <input type="text" name="position" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-colors" placeholder="VD: Nhân viên điều phối" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1">Chi nhánh (Branch)</label>
                    <input type="text" name="branch" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-colors" placeholder="VD: CN Hồ Chí Minh" />
                </div>
            </div>

            <div class="flex justify-end gap-3 pt-4 border-t border-slate-100">
                <a href="/Staff/Index" class="px-5 py-2.5 text-sm font-bold text-slate-600 hover:text-slate-800 transition-colors">
                    Hủy bỏ
                </a>
                <button type="submit" class="px-6 py-2.5 bg-blue-600 text-white rounded-lg text-sm font-bold hover:bg-blue-700 shadow-md transition-colors">
                    Tạo Nhân Viên
                </button>
            </div>
        </form>
    </div>
</div>
