@model CarRentalSystem.Models.Staff

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chỉnh sửa Nhân Viên";
}

<div class="p-6">
    <div class="mb-6 flex items-center justify-between">
        <div>
            <h2 class="text-2xl font-bold text-slate-800">Chỉnh sửa Nhân Viên</h2>
            <p class="text-sm text-slate-500 mt-1">Cập nhật thông tin chi tiết của nhân viên</p>
        </div>
        <a href="/Staff/Index" class="px-4 py-2 text-sm font-semibold text-slate-600 bg-white border border-slate-300 rounded-lg hover:bg-slate-50 transition-colors shadow-sm">
            Quay lại
        </a>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="mb-4 p-4 bg-red-50 border-l-4 border-red-500 text-red-700 rounded-r-lg text-sm">
            @ViewBag.Error
        </div>
    }

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 max-w-3xl mx-auto">
        <form method="post" action="/Staff/Edit/@Model.StaffId">
            @Html.AntiForgeryToken()
            <input type="hidden" name="StaffId" value="@Model.StaffId" />
            
            <h3 class="text-lg font-bold text-slate-800 mb-4 pb-2 border-b border-slate-100">Thông tin đăng nhập</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1">Email (Không thể thay đổi)</label>
                    <input type="email" disabled value="@Model.UserProfile?.Account?.Email" class="w-full px-4 py-2 bg-slate-100 border border-slate-200 rounded-lg text-slate-500 outline-none" />
                </div>
            </div>

            <h3 class="text-lg font-bold text-slate-800 mb-4 pb-2 border-b border-slate-100">Thông tin cá nhân & Công việc</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1">Họ và tên <span class="text-red-500">*</span></label>
                    <input type="text" name="fullName" required value="@Model.UserProfile?.FullName" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-colors" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1">Số điện thoại <span class="text-red-500">*</span></label>
                    <input type="text" name="phoneNumber" required value="@Model.UserProfile?.PhoneNumber" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-colors" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1">Phòng ban</label>
                    <select name="department" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-colors">
                        <option value="Vận hành" selected="@(Model.Department == "Vận hành" ? "selected" : null)">Vận hành</option>
                        <option value="Kỹ thuật" selected="@(Model.Department == "Kỹ thuật" ? "selected" : null)">Kỹ thuật</option>
                        <option value="Kế toán" selected="@(Model.Department == "Kế toán" ? "selected" : null)">Kế toán</option>
                        <option value="Chăm sóc khách hàng" selected="@(Model.Department == "Chăm sóc khách hàng" ? "selected" : null)">Chăm sóc khách hàng</option>
                        <option value="Kinh doanh" selected="@(Model.Department == "Kinh doanh" ? "selected" : null)">Kinh doanh</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1">Chức vụ</label>
                    <input type="text" name="position" value="@Model.Position" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-colors" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1">Chi nhánh (Branch)</label>
                    <input type="text" name="branch" value="@Model.Branch" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-colors" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1">Trạng thái làm việc</label>
                    <div class="mt-2 flex items-center gap-2">
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" name="isActive" value="true" checked="@(Model.IsActive ? "checked" : null)" class="sr-only peer">
                            <div class="w-11 h-6 bg-slate-200 rounded-full peer peer-checked:after:translate-x-full peer-checked:bg-blue-600 after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all"></div>
                        </label>
                        <span class="text-sm font-medium text-slate-600">Đang hoạt động</span>
                    </div>
                </div>
            </div>

            <div class="flex justify-end gap-3 pt-4 border-t border-slate-100">
                <a href="/Staff/Index" class="px-5 py-2.5 text-sm font-bold text-slate-600 hover:text-slate-800 transition-colors">
                    Hủy bỏ
                </a>
                <button type="submit" class="px-6 py-2.5 bg-blue-600 text-white rounded-lg text-sm font-bold hover:bg-blue-700 shadow-md transition-colors flex items-center gap-2">
                    <span class="material-symbols-outlined text-[20px]">save</span> Lưu thay đổi
                </button>
            </div>
        </form>
    </div>
</div>
